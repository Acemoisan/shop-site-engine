---
interface Props { phone: string; bookingUrl?: string; heading?: string }
const { phone, bookingUrl, heading = "Ready when you are." } = Astro.props;
---
<section id="book" class="bg-primary text-primary-foreground px-6 py-20 text-center">
  <h2 class="font-display text-4xl font-semibold uppercase tracking-wide">{heading}</h2>
  <div class="mt-6 flex justify-center gap-4">
    <a href={`tel:${phone}`} class="rounded-[var(--radius)] bg-accent px-6 py-3 font-semibold text-foreground">Call</a>
    {bookingUrl && <a href={bookingUrl} class="rounded-[var(--radius)] border border-primary-foreground px-6 py-3 font-semibold">Book online</a>}
  </div>
</section>
