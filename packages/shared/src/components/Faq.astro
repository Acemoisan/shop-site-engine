---
interface Item { q: string; a: string }
interface Props { heading?: string; items: Item[] }
const { heading = "Questions, answered", items } = Astro.props;
---
<section id="faq" class="mx-auto max-w-3xl px-6 py-20 sm:py-28">
  <h2 class="font-display text-3xl font-bold tracking-tight text-foreground sm:text-4xl">{heading}</h2>
  <div class="mt-10 divide-y divide-border border-y border-border">
    {items.map((f) => (
      <details class="group py-5">
        <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-medium text-foreground">
          <span>{f.q}</span>
          <span class="text-xl leading-none text-primary transition group-open:rotate-45">+</span>
        </summary>
        <p class="mt-3 text-sm leading-relaxed text-muted-foreground">{f.a}</p>
      </details>
    ))}
  </div>
</section>
