---
import Icon from "./Icon.astro";
interface Item { icon: string; title: string; body: string }
interface Props { label?: string; heading: string; items: Item[] }
const { label, heading, items } = Astro.props;
---
<section id="features" class="scroll-mt-20">
  <div class="mx-auto max-w-6xl px-6 py-20 sm:py-28">
    <div class="max-w-2xl">
      {label && <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">{label}</p>}
      <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-foreground sm:text-4xl">{heading}</h2>
    </div>
    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {items.map((b) => (
        <div class="group rounded-[var(--radius)] border border-border bg-card p-7 shadow-sm transition hover:-translate-y-1 hover:shadow-md">
          <div class="grid h-11 w-11 place-items-center rounded-xl bg-primary/10 text-primary transition group-hover:bg-primary group-hover:text-primary-foreground">
            <Icon name={b.icon} class="h-5 w-5" />
          </div>
          <h3 class="mt-5 font-display text-lg font-semibold text-foreground">{b.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{b.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
