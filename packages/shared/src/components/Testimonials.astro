---
interface Item { quote: string; name: string }
interface Props { label?: string; heading?: string; items: Item[] }
const { label, heading = "What people say", items } = Astro.props;
---
<section class="bg-muted">
  <div class="mx-auto max-w-6xl px-6 py-20 sm:py-28">
    {label && <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">{label}</p>}
    <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-foreground sm:text-4xl">{heading}</h2>
    <div class="mt-12 grid gap-6 sm:grid-cols-3">
      {items.map((t) => (
        <figure class="rounded-[var(--radius)] border border-border bg-card p-7 shadow-sm">
          <p class="text-accent">★★★★★</p>
          <blockquote class="mt-3 leading-relaxed text-foreground">“{t.quote}”</blockquote>
          <figcaption class="mt-5 text-sm font-semibold text-primary">{t.name}</figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
