---
interface Item { value: string; label: string }
interface Props { items: Item[] }
const { items } = Astro.props;
---
<section class="border-y border-border bg-muted">
  <div class="mx-auto grid max-w-5xl gap-8 px-6 py-14 sm:grid-cols-3">
    {items.map((s) => (
      <div class="text-center">
        <p class="font-display text-4xl font-bold text-primary">{s.value}</p>
        <p class="mt-2 text-sm text-muted-foreground">{s.label}</p>
      </div>
    ))}
  </div>
</section>
