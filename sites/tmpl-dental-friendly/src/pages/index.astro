---
const brand = "Brightwater Dental & Wellness";
const phone = "(403) 555-0142";
const phoneHref = "tel:+14035550142";

const nav = [
  { label: "Services", href: "#services" },
  { label: "Your Team", href: "#team" },
  { label: "Reviews", href: "#reviews" },
  { label: "First Visit", href: "#first-visit" },
  { label: "Visit Us", href: "#visit" },
];

const services = [
  { name: "New Patient Exam, X-rays & Cleaning", price: "$189", note: "Free for kids under 6", seed: "bw-exam", icon: "tooth" },
  { name: "Professional Teeth Whitening", price: "from $349", note: "Brighter in one visit", seed: "bw-white", icon: "sparkle" },
  { name: "Invisalign Clear Aligners", price: "from $4,500", note: "Free consultation", seed: "bw-invis", icon: "align" },
  { name: "Dental Implants", price: "from $3,200", note: "per tooth", seed: "bw-implant", icon: "anchor" },
  { name: "Emergency / Same-Day Visit", price: "from $120", note: "Seen this week", seed: "bw-emerg", icon: "shield" },
  { name: "Brightwater Membership Plan", price: "$39/mo", note: "No insurance? No problem", seed: "bw-member", icon: "heart" },
];

const team = [
  { name: "Dr. Lena Okafor", role: "Principal Dentist · DDS", cred: "20+ yrs · Calgary", seed: "bw-lena" },
  { name: "Dr. Sam Whitford", role: "Cosmetic & Invisalign · DMD", cred: "Smile design", seed: "bw-sam" },
  { name: "Priya Anand, RDH", role: "Lead Hygienist", cred: "Gentle cleanings", seed: "bw-priya" },
];

const reviews = [
  { quote: "I used to dread the dentist. The team here is so calm and gentle — I actually look forward to my cleanings now.", who: "Priya S.", where: "Calgary · Google" },
  { quote: "Booked online Sunday night, seen Monday for a chipped tooth. Painless and friendly the whole way.", who: "Marcus L.", where: "Google review" },
  { quote: "They explained everything without the jargon and never pushed extra treatments. Honest, kind care.", who: "Dana R.", where: "RateMDs" },
];

const steps = [
  { n: "1", t: "Warm welcome", d: "A friendly hello, a cup of tea, and zero rush. We learn what makes you anxious." },
  { n: "2", t: "Gentle exam", d: "Digital X-rays and a thorough look — explained in plain language as we go." },
  { n: "3", t: "Your plan", d: "Clear options and transparent pricing. No surprises, no pressure to add on." },
  { n: "4", t: "Easy booking", d: "Direct insurance billing and same-week follow-ups scheduled before you leave." },
];

const hours = [
  { d: "Mon – Thu", h: "8:00am – 6:00pm" },
  { d: "Friday", h: "8:00am – 4:00pm" },
  { d: "Saturday", h: "9:00am – 2:00pm (alt.)" },
  { d: "Sunday", h: "Closed" },
];

const insurers = ["Sun Life", "Blue Cross", "Manulife", "Canada Life", "Green Shield", "Direct Bill"];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Brightwater Dental & Wellness — Gentle Family Dentistry in Calgary</title>
  <meta name="description" content="Gentle, modern dentistry your whole family will smile about. Same-week appointments, transparent pricing, and judgment-free care in Calgary. Rated 4.9★ from 380+ reviews." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700&family=Nunito:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <a class="skip" href="#main">Skip to content</a>

  <header class="topbar" id="top">
    <div class="wrap topbar-inner">
      <a href="#top" class="logo" aria-label="Brightwater Dental and Wellness home">
        <span class="logo-mark" aria-hidden="true">
          <svg viewBox="0 0 32 32" width="28" height="28"><path d="M16 4c-4 0-6 2-9 2S2 5 2 9c0 6 2 9 4 14 1 3 3 5 4 5s1-4 2-6 2-3 4-3 3 1 4 3 1 6 2 6 3-2 4-5c2-5 4-8 4-14 0-4-2-3-5-3s-5-2-9-2Z" fill="currentColor"/></svg>
        </span>
        <span class="logo-text">Brightwater<em>Dental & Wellness</em></span>
      </a>
      <nav class="mainnav" id="nav" aria-label="Primary">
        {nav.map((n) => <a href={n.href}>{n.label}</a>)}
      </nav>
      <div class="topbar-cta">
        <a class="phone-link" href={phoneHref}>
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M6.6 10.8a15 15 0 006.6 6.6l2.2-2.2a1 1 0 011-.24 11 11 0 003.5.56 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1 11 11 0 00.56 3.5 1 1 0 01-.24 1Z" fill="currentColor"/></svg>
          <span>{phone}</span>
        </a>
        <a class="btn btn-primary" href="#visit">Book Appointment</a>
        <button class="burger" id="burger" aria-label="Open menu" aria-expanded="false" aria-controls="nav"><span></span><span></span><span></span></button>
      </div>
    </div>
  </header>

  <main id="main">
    <!-- HERO -->
    <section class="hero">
      <span class="blob blob-a" aria-hidden="true"></span>
      <span class="blob blob-b" aria-hidden="true"></span>
      <div class="wrap hero-grid">
        <div class="hero-copy reveal">
          <span class="pill"><span class="dot" aria-hidden="true"></span> Accepting new patients · Calgary</span>
          <h1>Gentle, modern dentistry your whole family will <span class="hl">smile</span> about.</h1>
          <p class="lede">Relaxed, judgment-free care with same-week appointments and transparent pricing. Dentistry that puts you at ease.</p>
          <div class="hero-actions">
            <a class="btn btn-primary btn-lg" href="#visit">Request Appointment</a>
            <a class="btn btn-ghost btn-lg" href={phoneHref}>Call {phone}</a>
          </div>
          <div class="hero-trust">
            <div class="stars" aria-label="Rated 4.9 out of 5 stars">★★★★★</div>
            <p><strong>4.9</strong> from <strong>380+</strong> Google reviews · New patients always welcome</p>
          </div>
        </div>
        <div class="hero-media reveal">
          <div class="hero-photo">
            <img src="https://picsum.photos/seed/bw-hero-smile/720/860" alt="A relaxed patient smiling in a bright, modern dental chair" loading="eager" width="720" height="860" />
          </div>
          <div class="hero-badge">
            <span class="badge-num">Same week</span>
            <span class="badge-lbl">appointments available</span>
          </div>
        </div>
      </div>
    </section>

    <!-- TRUST STRIP -->
    <section class="trust" aria-label="Why patients trust us">
      <div class="wrap trust-grid">
        <div class="trust-item"><strong>4.9★</strong><span>380+ Google reviews</span></div>
        <div class="trust-item"><strong>20+ yrs</strong><span>Caring for Calgary</span></div>
        <div class="trust-item"><strong>Direct</strong><span>Insurance billing</span></div>
        <div class="trust-item"><strong>Free</strong><span>Parking on-site</span></div>
      </div>
      <div class="marquee" aria-hidden="true">
        <div class="marquee-track">
          {[...insurers, ...insurers].map((i) => <span class="chip">{i}</span>)}
        </div>
      </div>
    </section>

    <!-- SERVICES -->
    <section class="section" id="services">
      <div class="wrap">
        <div class="section-head reveal">
          <span class="eyebrow">Our care</span>
          <h2>Services with honest, up-front pricing</h2>
          <p>Plain-language treatment and prices you can see before you sit down. No surprises.</p>
        </div>
        <div class="cards">
          {services.map((s) => (
            <article class="card reveal">
              <div class="card-ico" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="26" height="26"><use href={`#i-${s.icon}`}></use></svg>
              </div>
              <h3>{s.name}</h3>
              <p class="card-note">{s.note}</p>
              <div class="card-foot">
                <span class="price">{s.price}</span>
                <a class="card-link" href="#visit">Book →</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- BEFORE / AFTER -->
    <section class="section section-tint" id="gallery">
      <div class="wrap ba-grid">
        <div class="section-head reveal" style="text-align:left;margin:0;">
          <span class="eyebrow">Real results</span>
          <h2>See the smile difference</h2>
          <p>Drag the handle to compare a real whitening &amp; alignment outcome. Evenly lit, no filters.</p>
          <ul class="ba-list">
            <li>Whitening visible in a single visit</li>
            <li>Invisalign alignment over ~8 months</li>
            <li>Natural-looking, conservative cosmetic work</li>
          </ul>
        </div>
        <figure class="ba reveal" id="ba" aria-label="Before and after smile comparison">
          <img class="ba-img ba-after" src="https://picsum.photos/seed/bw-after/900/680" alt="Patient smile after whitening and alignment treatment" width="900" height="680" />
          <div class="ba-clip" id="baClip">
            <img class="ba-img ba-before" src="https://picsum.photos/seed/bw-before/900/680?grayscale" alt="Patient smile before treatment" width="900" height="680" />
          </div>
          <span class="ba-tag ba-tag-before">Before</span>
          <span class="ba-tag ba-tag-after">After</span>
          <input class="ba-range" id="baRange" type="range" min="0" max="100" value="50" aria-label="Reveal before and after" />
          <span class="ba-handle" id="baHandle" aria-hidden="true"><span></span></span>
        </figure>
      </div>
    </section>

    <!-- TEAM -->
    <section class="section" id="team">
      <div class="wrap">
        <div class="section-head reveal">
          <span class="eyebrow">Meet your team</span>
          <h2>Familiar faces who genuinely care</h2>
          <p>The same trusted clinicians, visit after visit — that's how nervous patients become regulars.</p>
        </div>
        <div class="team-grid">
          {team.map((m) => (
            <article class="member reveal">
              <div class="member-photo">
                <img src={`https://picsum.photos/seed/${m.seed}/420/480`} alt={`Portrait of ${m.name}`} width="420" height="480" />
              </div>
              <h3>{m.name}</h3>
              <p class="member-role">{m.role}</p>
              <p class="member-cred">{m.cred}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- REVIEWS -->
    <section class="section section-deep" id="reviews">
      <div class="wrap">
        <div class="section-head reveal">
          <span class="eyebrow eyebrow-light">In their words</span>
          <h2>Loved by Calgary families</h2>
          <div class="stars stars-lg" aria-label="Average 4.9 stars">★★★★★</div>
        </div>
        <div class="reviews-grid">
          {reviews.map((r) => (
            <figure class="quote reveal">
              <div class="stars" aria-hidden="true">★★★★★</div>
              <blockquote>{r.quote}</blockquote>
              <figcaption><strong>{r.who}</strong><span>{r.where}</span></figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <!-- FIRST VISIT -->
    <section class="section" id="first-visit">
      <div class="wrap">
        <div class="section-head reveal">
          <span class="eyebrow">What to expect</span>
          <h2>Your first visit, step by step</h2>
          <p>We designed every visit around one goal: helping anxious patients feel calm and in control.</p>
        </div>
        <ol class="steps">
          {steps.map((s) => (
            <li class="step reveal">
              <span class="step-n">{s.n}</span>
              <div>
                <h3>{s.t}</h3>
                <p>{s.d}</p>
              </div>
            </li>
          ))}
        </ol>
        <div class="offer reveal">
          <div>
            <span class="eyebrow eyebrow-light">No insurance? No problem</span>
            <h3>Brightwater Membership Plan — $39/month</h3>
            <p>Cleanings, exams, X-rays and member-only savings on every treatment. Direct billing for everyone else.</p>
          </div>
          <a class="btn btn-light btn-lg" href="#visit">Join the plan</a>
        </div>
      </div>
    </section>

    <!-- VISIT / BOOKING -->
    <section class="section section-tint" id="visit">
      <div class="wrap visit-grid">
        <div class="reveal">
          <span class="eyebrow">Visit us</span>
          <h2>Book your appointment</h2>
          <p class="visit-lede">Tell us a little about you and a preferred time. We'll confirm by phone, usually the same day.</p>

          <form class="book-form" onsubmit="event.preventDefault(); this.reset(); document.getElementById('book-ok').hidden=false;">
            <div class="field">
              <label for="bf-name">Your name</label>
              <input id="bf-name" name="name" type="text" autocomplete="name" required placeholder="Jordan Smith" />
            </div>
            <div class="field-row">
              <div class="field">
                <label for="bf-phone">Phone</label>
                <input id="bf-phone" name="phone" type="tel" autocomplete="tel" required placeholder="(403) 555-0000" />
              </div>
              <div class="field">
                <label for="bf-time">Preferred time</label>
                <select id="bf-time" name="time">
                  <option>Weekday morning</option>
                  <option>Weekday afternoon</option>
                  <option>Saturday</option>
                  <option>As soon as possible</option>
                </select>
              </div>
            </div>
            <div class="field">
              <label for="bf-msg">What can we help with?</label>
              <textarea id="bf-msg" name="msg" rows="3" placeholder="Cleaning, chipped tooth, new patient…"></textarea>
            </div>
            <button class="btn btn-primary btn-lg btn-block" type="submit">Request appointment</button>
            <p class="ok" id="book-ok" hidden role="status">Thank you — we'll call to confirm shortly. 💙</p>
            <p class="form-note">Or call us directly: <a href={phoneHref}>{phone}</a></p>
          </form>
        </div>

        <aside class="visit-info reveal">
          <div class="map">
            <img src="https://picsum.photos/seed/bw-map/680/360?grayscale" alt="Map showing Brightwater Dental in downtown Calgary" width="680" height="360" />
            <a class="map-pin" href="https://maps.google.com/?q=1420+8th+Street+SW+Calgary" target="_blank" rel="noopener">Open in Maps →</a>
          </div>
          <div class="nap">
            <h3>Brightwater Dental &amp; Wellness</h3>
            <p class="addr">1420 8th Street SW, Suite 210<br/>Calgary, AB T2R 1J5</p>
            <a class="call-big" href={phoneHref}>📞 {phone}</a>
          </div>
          <table class="hours">
            <caption>Opening hours</caption>
            <tbody>
              {hours.map((h) => (
                <tr><th scope="row">{h.d}</th><td>{h.h}</td></tr>
              ))}
            </tbody>
          </table>
          <p class="perks">New patients always welcome · Most insurance accepted · Direct billing · Free parking · Wheelchair accessible</p>
        </aside>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="wrap footer-inner">
      <div class="footer-brand">
        <span class="logo-mark" aria-hidden="true">
          <svg viewBox="0 0 32 32" width="26" height="26"><path d="M16 4c-4 0-6 2-9 2S2 5 2 9c0 6 2 9 4 14 1 3 3 5 4 5s1-4 2-6 2-3 4-3 3 1 4 3 1 6 2 6 3-2 4-5c2-5 4-8 4-14 0-4-2-3-5-3s-5-2-9-2Z" fill="currentColor"/></svg>
        </span>
        <p>Brightwater Dental &amp; Wellness — gentle, modern dentistry that puts Calgary families at ease.</p>
      </div>
      <nav class="footer-nav" aria-label="Footer">
        {nav.map((n) => <a href={n.href}>{n.label}</a>)}
        <a href={phoneHref}>{phone}</a>
      </nav>
    </div>
    <div class="wrap footer-base">
      <span>© 2026 Brightwater Dental &amp; Wellness</span>
      <span>1420 8th Street SW · Calgary, AB</span>
    </div>
  </footer>

  <!-- Sticky mobile booking bar -->
  <div class="bookbar" aria-hidden="false">
    <a class="bookbar-call" href={phoneHref}>Call</a>
    <a class="bookbar-book btn-primary" href="#visit">Book Appointment</a>
  </div>

  <!-- Inline icon sprite -->
  <svg width="0" height="0" style="position:absolute" aria-hidden="true">
    <symbol id="i-tooth" viewBox="0 0 24 24"><path d="M12 3c-2.4 0-3.6 1-5.4 1S4 3.5 4 6c0 3.6 1 5.4 2 8 .8 2 1.4 3.4 2 3.4s.6-2.4 1-3.6 1-1.8 2-1.8 1.6.6 2 1.8.4 3.6 1 3.6 1.2-1.4 2-3.4c1-2.6 2-4.4 2-8 0-2.5-1-2-2.6-2S14.4 3 12 3Z" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></symbol>
    <symbol id="i-sparkle" viewBox="0 0 24 24"><path d="M12 3l1.8 5L19 10l-5.2 2L12 17l-1.8-5L5 10l5.2-2L12 3Z" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></symbol>
    <symbol id="i-align" viewBox="0 0 24 24"><path d="M4 7h16M4 12h16M4 17h16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></symbol>
    <symbol id="i-anchor" viewBox="0 0 24 24"><path d="M12 7v12M5 13a7 7 0 0014 0M8 19H5m11 0h3" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><circle cx="12" cy="5" r="2" fill="none" stroke="currentColor" stroke-width="1.6"/></symbol>
    <symbol id="i-shield" viewBox="0 0 24 24"><path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3Z" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M9 12l2 2 4-4" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></symbol>
    <symbol id="i-heart" viewBox="0 0 24 24"><path d="M12 20s-7-4.3-7-9.3A3.7 3.7 0 0112 8a3.7 3.7 0 017 2.7c0 5-7 9.3-7 9.3Z" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></symbol>
  </svg>

  <script is:inline>
    // Mobile nav
    const burger = document.getElementById('burger');
    const navEl = document.getElementById('nav');
    burger?.addEventListener('click', () => {
      const open = navEl.classList.toggle('open');
      burger.setAttribute('aria-expanded', String(open));
    });
    navEl?.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => { navEl.classList.remove('open'); burger.setAttribute('aria-expanded','false'); })
    );

    // Sticky header shadow
    const header = document.getElementById('top');
    addEventListener('scroll', () => header.classList.toggle('scrolled', scrollY > 8), { passive: true });

    // Before/after slider
    const range = document.getElementById('baRange');
    const clip = document.getElementById('baClip');
    const handle = document.getElementById('baHandle');
    function setBA(v) {
      clip.style.width = v + '%';
      handle.style.left = v + '%';
    }
    range?.addEventListener('input', (e) => setBA(e.target.value));
    if (range) setBA(50);

    // Scroll reveal
    const mq = matchMedia('(prefers-reduced-motion: reduce)');
    if (mq.matches) {
      document.querySelectorAll('.reveal').forEach((el) => el.classList.add('in'));
    } else {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((en) => { if (en.isIntersecting) { en.target.classList.add('in'); io.unobserve(en.target); } });
      }, { threshold: 0.12 });
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
    }
  </script>

  <style is:global>
    *,*::before,*::after { box-sizing: border-box; }
    html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
    @media (prefers-reduced-motion: reduce) { html { scroll-behavior: auto; } }
    body { margin: 0; }
    img { display: block; max-width: 100%; }
  </style>

  <style>
    :root {
      --bg: #f5fbfd;
      --fg: #0f2e3d;
      --primary: #0aa6c2;
      --primary-fg: #ffffff;
      --accent: #16c79a;
      --muted: #e2f1f6;
      --border: #cbe4ec;
      --deep: #0c3a4a;
      --radius: 22px;
      --radius-sm: 14px;
      --shadow: 0 18px 50px -22px rgba(10,90,110,.45);
      --shadow-sm: 0 8px 24px -14px rgba(10,90,110,.5);
      --font-display: "Poppins", system-ui, sans-serif;
      --font-body: "Nunito", system-ui, sans-serif;
      --wrap: 1180px;
    }

    body { background: var(--bg); color: var(--fg); font-family: var(--font-body); line-height: 1.6; font-size: 17px; }
    h1,h2,h3 { font-family: var(--font-display); line-height: 1.1; margin: 0; letter-spacing: -.02em; }
    p { margin: 0; }
    a { color: inherit; }
    .wrap { width: 100%; max-width: var(--wrap); margin: 0 auto; padding: 0 22px; }

    .skip { position: absolute; left: -999px; top: 0; background: var(--primary); color: #fff; padding: 10px 16px; border-radius: 0 0 12px 0; z-index: 200; }
    .skip:focus { left: 0; }

    :focus-visible { outline: 3px solid var(--accent); outline-offset: 2px; border-radius: 6px; }

    /* Buttons */
    .btn { display: inline-flex; align-items: center; justify-content: center; gap: 8px; font-family: var(--font-display); font-weight: 600; text-decoration: none; border: 0; cursor: pointer; border-radius: 999px; padding: 12px 22px; min-height: 44px; transition: transform .18s ease, box-shadow .18s ease, background .18s ease, color .18s ease; }
    .btn-lg { padding: 15px 28px; font-size: 1.02rem; }
    .btn-block { width: 100%; }
    .btn-primary { background: var(--primary); color: var(--primary-fg); box-shadow: var(--shadow-sm); }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 14px 30px -12px rgba(10,166,194,.7); background: #0993ad; }
    .btn-ghost { background: #fff; color: var(--deep); border: 2px solid var(--border); }
    .btn-ghost:hover { transform: translateY(-2px); border-color: var(--primary); color: var(--primary); }
    .btn-light { background: #fff; color: var(--deep); }
    .btn-light:hover { transform: translateY(-2px); box-shadow: var(--shadow-sm); }

    /* Header */
    .topbar { position: sticky; top: 0; z-index: 100; background: rgba(245,251,253,.85); backdrop-filter: blur(12px); border-bottom: 1px solid transparent; transition: border-color .2s, box-shadow .2s; }
    .topbar.scrolled { border-color: var(--border); box-shadow: 0 6px 20px -16px rgba(10,90,110,.6); }
    .topbar-inner { display: flex; align-items: center; gap: 18px; height: 70px; }
    .logo { display: flex; align-items: center; gap: 10px; text-decoration: none; color: var(--deep); margin-right: auto; }
    .logo-mark { display: grid; place-items: center; width: 40px; height: 40px; border-radius: 12px; background: linear-gradient(140deg, var(--primary), var(--accent)); color: #fff; box-shadow: var(--shadow-sm); }
    .logo-text { display: flex; flex-direction: column; font-family: var(--font-display); font-weight: 700; font-size: 1.05rem; line-height: 1.05; }
    .logo-text em { font-style: normal; font-weight: 500; font-size: .68rem; letter-spacing: .12em; text-transform: uppercase; color: var(--primary); }
    .mainnav { display: flex; gap: 6px; }
    .mainnav a { font-family: var(--font-display); font-weight: 500; font-size: .96rem; text-decoration: none; padding: 8px 12px; border-radius: 10px; color: var(--deep); transition: background .15s, color .15s; }
    .mainnav a:hover { background: var(--muted); color: var(--primary); }
    .topbar-cta { display: flex; align-items: center; gap: 12px; }
    .phone-link { display: inline-flex; align-items: center; gap: 7px; text-decoration: none; font-family: var(--font-display); font-weight: 600; color: var(--deep); white-space: nowrap; }
    .phone-link svg { color: var(--primary); }
    .phone-link:hover { color: var(--primary); }
    .burger { display: none; flex-direction: column; gap: 5px; width: 44px; height: 44px; background: #fff; border: 1px solid var(--border); border-radius: 12px; cursor: pointer; align-items: center; justify-content: center; }
    .burger span { width: 20px; height: 2px; background: var(--deep); border-radius: 2px; transition: .2s; }

    /* Hero */
    .hero { position: relative; overflow: hidden; padding: clamp(40px, 6vw, 84px) 0 clamp(48px, 6vw, 90px); }
    .blob { position: absolute; border-radius: 50%; filter: blur(8px); opacity: .5; z-index: 0; }
    .blob-a { width: 420px; height: 420px; background: radial-gradient(circle, rgba(22,199,154,.4), transparent 70%); top: -120px; right: -80px; }
    .blob-b { width: 360px; height: 360px; background: radial-gradient(circle, rgba(10,166,194,.32), transparent 70%); bottom: -140px; left: -120px; }
    .hero-grid { position: relative; z-index: 1; display: grid; grid-template-columns: 1.05fr .95fr; gap: clamp(28px, 4vw, 56px); align-items: center; }
    .pill { display: inline-flex; align-items: center; gap: 8px; background: #fff; border: 1px solid var(--border); color: var(--deep); font-family: var(--font-display); font-weight: 600; font-size: .82rem; padding: 7px 14px; border-radius: 999px; box-shadow: var(--shadow-sm); }
    .pill .dot { width: 9px; height: 9px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 0 4px rgba(22,199,154,.22); }
    .hero h1 { font-size: clamp(2.3rem, 5.4vw, 3.9rem); margin: 18px 0 16px; font-weight: 700; }
    .hl { color: var(--primary); position: relative; white-space: nowrap; }
    .hl::after { content: ""; position: absolute; left: -2%; right: -2%; bottom: 6%; height: 36%; background: rgba(22,199,154,.28); border-radius: 8px; z-index: -1; }
    .lede { font-size: clamp(1.05rem, 1.6vw, 1.2rem); color: #335a68; max-width: 30ch; }
    .hero-actions { display: flex; flex-wrap: wrap; gap: 12px; margin: 26px 0 22px; }
    .hero-trust { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
    .stars { color: #f5a623; letter-spacing: 2px; font-size: 1.05rem; }
    .stars-lg { font-size: 1.6rem; }
    .hero-trust p { font-size: .92rem; color: #335a68; }

    .hero-media { position: relative; }
    .hero-photo { position: relative; border-radius: 32px 32px 90px 32px; overflow: hidden; box-shadow: var(--shadow); border: 6px solid #fff; }
    .hero-photo img { width: 100%; height: 100%; object-fit: cover; aspect-ratio: 5/6; filter: saturate(1.02); }
    .hero-photo::after { content: ""; position: absolute; inset: 0; background: linear-gradient(180deg, transparent 55%, rgba(10,166,194,.16)); }
    .hero-badge { position: absolute; left: -14px; bottom: 28px; background: #fff; border-radius: 18px; padding: 14px 18px; box-shadow: var(--shadow); display: flex; flex-direction: column; border: 1px solid var(--border); }
    .badge-num { font-family: var(--font-display); font-weight: 700; color: var(--primary); font-size: 1.15rem; }
    .badge-lbl { font-size: .8rem; color: #335a68; }

    /* Trust strip */
    .trust { background: var(--deep); color: #eaf7fa; padding: 26px 0 0; }
    .trust-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; }
    .trust-item { text-align: center; display: flex; flex-direction: column; gap: 2px; padding: 6px; }
    .trust-item strong { font-family: var(--font-display); font-size: 1.5rem; color: var(--accent); }
    .trust-item span { font-size: .85rem; color: #b9dce4; }
    .marquee { overflow: hidden; margin-top: 22px; border-top: 1px solid rgba(255,255,255,.12); padding: 14px 0; -webkit-mask-image: linear-gradient(90deg, transparent, #000 12%, #000 88%, transparent); mask-image: linear-gradient(90deg, transparent, #000 12%, #000 88%, transparent); }
    .marquee-track { display: flex; gap: 40px; width: max-content; animation: scroll 26s linear infinite; }
    @media (prefers-reduced-motion: reduce) { .marquee-track { animation: none; } }
    .chip { font-family: var(--font-display); font-weight: 600; font-size: .92rem; color: #cfeef4; white-space: nowrap; opacity: .85; }
    @keyframes scroll { to { transform: translateX(-50%); } }

    /* Sections */
    .section { padding: clamp(56px, 7vw, 96px) 0; }
    .section-tint { background: linear-gradient(180deg, var(--muted), var(--bg)); }
    .section-deep { background: var(--deep); color: #eaf7fa; }
    .section-head { max-width: 620px; margin: 0 auto clamp(34px, 4vw, 52px); text-align: center; }
    .eyebrow { font-family: var(--font-display); font-weight: 600; font-size: .8rem; letter-spacing: .16em; text-transform: uppercase; color: var(--primary); }
    .eyebrow-light { color: var(--accent); }
    .section-head h2 { font-size: clamp(1.8rem, 3.6vw, 2.7rem); margin: 12px 0 12px; }
    .section-head p { color: #44697a; }
    .section-deep .section-head p { color: #b9dce4; }

    /* Service cards */
    .cards { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; }
    .card { background: #fff; border: 1px solid var(--border); border-radius: var(--radius); padding: 26px; display: flex; flex-direction: column; gap: 8px; transition: transform .2s, box-shadow .2s, border-color .2s; }
    .card:hover { transform: translateY(-5px); box-shadow: var(--shadow); border-color: var(--primary); }
    .card-ico { width: 52px; height: 52px; border-radius: 16px; display: grid; place-items: center; background: var(--muted); color: var(--primary); margin-bottom: 6px; }
    .card h3 { font-size: 1.12rem; }
    .card-note { color: #5d7f8c; font-size: .92rem; }
    .card-foot { margin-top: auto; padding-top: 14px; display: flex; align-items: center; justify-content: space-between; border-top: 1px dashed var(--border); }
    .price { font-family: var(--font-display); font-weight: 700; font-size: 1.2rem; color: var(--deep); }
    .card-link { font-family: var(--font-display); font-weight: 600; font-size: .92rem; color: var(--primary); text-decoration: none; }
    .card-link:hover { color: var(--accent); }

    /* Before / after */
    .ba-grid { display: grid; grid-template-columns: .9fr 1.1fr; gap: clamp(28px,4vw,56px); align-items: center; }
    .ba-list { list-style: none; padding: 0; margin: 20px 0 0; display: grid; gap: 10px; }
    .ba-list li { position: relative; padding-left: 30px; color: #44697a; }
    .ba-list li::before { content: "✓"; position: absolute; left: 0; top: 0; width: 20px; height: 20px; border-radius: 50%; background: var(--accent); color: #fff; font-size: .72rem; display: grid; place-items: center; }
    .ba { position: relative; margin: 0; border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow); border: 6px solid #fff; user-select: none; }
    .ba-img { width: 100%; aspect-ratio: 9/7; object-fit: cover; display: block; }
    .ba-clip { position: absolute; inset: 0; width: 50%; overflow: hidden; border-right: 3px solid #fff; }
    .ba-clip .ba-img { position: absolute; top: 0; left: 0; height: 100%; width: auto; max-width: none; }
    .ba { --baw: 100%; }
    .ba-clip .ba-before { width: calc(100% * (100 / 50)); }
    .ba-tag { position: absolute; top: 14px; font-family: var(--font-display); font-weight: 600; font-size: .72rem; letter-spacing: .08em; text-transform: uppercase; padding: 5px 11px; border-radius: 999px; background: rgba(12,58,74,.78); color: #fff; backdrop-filter: blur(4px); }
    .ba-tag-before { left: 14px; }
    .ba-tag-after { right: 14px; background: var(--primary); }
    .ba-range { position: absolute; inset: 0; width: 100%; height: 100%; margin: 0; opacity: 0; cursor: ew-resize; }
    .ba-handle { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 46px; height: 46px; border-radius: 50%; background: #fff; box-shadow: 0 6px 16px rgba(10,90,110,.5); display: grid; place-items: center; pointer-events: none; }
    .ba-handle span { width: 20px; height: 20px; border-radius: 50%; background: var(--primary); }
    .ba-handle::before, .ba-handle::after { content: ""; position: absolute; top: 50%; width: 7px; height: 7px; border-top: 2px solid var(--primary); border-right: 2px solid var(--primary); }
    .ba-handle::before { left: 8px; transform: translateY(-50%) rotate(-135deg); }
    .ba-handle::after { right: 8px; transform: translateY(-50%) rotate(45deg); }

    /* Team */
    .team-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 22px; }
    .member { text-align: center; background: #fff; border: 1px solid var(--border); border-radius: var(--radius); padding: 22px; transition: transform .2s, box-shadow .2s; }
    .member:hover { transform: translateY(-5px); box-shadow: var(--shadow); }
    .member-photo { border-radius: 20px; overflow: hidden; margin-bottom: 16px; aspect-ratio: 7/8; }
    .member-photo img { width: 100%; height: 100%; object-fit: cover; filter: saturate(.98); transition: transform .4s ease; }
    .member:hover .member-photo img { transform: scale(1.05); }
    .member h3 { font-size: 1.18rem; }
    .member-role { color: var(--primary); font-weight: 600; font-size: .92rem; margin-top: 4px; }
    .member-cred { color: #5d7f8c; font-size: .88rem; }

    /* Reviews */
    .reviews-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; }
    .quote { margin: 0; background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.14); border-radius: var(--radius); padding: 26px; display: flex; flex-direction: column; gap: 14px; }
    .quote blockquote { margin: 0; font-size: 1.04rem; color: #eaf7fa; }
    .quote figcaption { display: flex; flex-direction: column; margin-top: auto; }
    .quote figcaption strong { font-family: var(--font-display); color: #fff; }
    .quote figcaption span { font-size: .82rem; color: #9fcdd8; }

    /* Steps */
    .steps { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(4,1fr); gap: 18px; }
    .step { background: #fff; border: 1px solid var(--border); border-radius: var(--radius); padding: 24px; display: flex; flex-direction: column; gap: 14px; }
    .step-n { width: 46px; height: 46px; border-radius: 14px; background: linear-gradient(140deg, var(--primary), var(--accent)); color: #fff; font-family: var(--font-display); font-weight: 700; font-size: 1.25rem; display: grid; place-items: center; box-shadow: var(--shadow-sm); }
    .step h3 { font-size: 1.1rem; margin-bottom: 6px; }
    .step p { color: #5d7f8c; font-size: .94rem; }

    .offer { margin-top: 28px; background: linear-gradient(135deg, var(--primary), var(--deep)); color: #fff; border-radius: var(--radius); padding: clamp(26px, 4vw, 40px); display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap; box-shadow: var(--shadow); }
    .offer h3 { font-size: clamp(1.3rem, 2.4vw, 1.8rem); margin: 8px 0 8px; }
    .offer p { color: #d6f1f7; max-width: 46ch; }

    /* Visit */
    .visit-grid { display: grid; grid-template-columns: 1.05fr .95fr; gap: clamp(28px,4vw,52px); align-items: start; }
    .visit-grid h2 { font-size: clamp(1.8rem,3.6vw,2.7rem); margin: 12px 0 12px; }
    .visit-lede { color: #44697a; margin-bottom: 24px; }
    .book-form { background: #fff; border: 1px solid var(--border); border-radius: var(--radius); padding: clamp(22px,3vw,32px); box-shadow: var(--shadow-sm); }
    .field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; }
    .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .field label { font-family: var(--font-display); font-weight: 600; font-size: .88rem; color: var(--deep); }
    .field input, .field select, .field textarea { font-family: var(--font-body); font-size: 1rem; padding: 12px 14px; border: 1.5px solid var(--border); border-radius: var(--radius-sm); background: var(--bg); color: var(--fg); width: 100%; min-height: 44px; }
    .field textarea { resize: vertical; }
    .field input:focus, .field select:focus, .field textarea:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px rgba(10,166,194,.18); }
    .ok { margin-top: 14px; color: var(--accent); font-weight: 700; }
    .form-note { margin-top: 14px; text-align: center; color: #5d7f8c; font-size: .9rem; }
    .form-note a { color: var(--primary); font-weight: 700; }

    .visit-info { display: flex; flex-direction: column; gap: 18px; }
    .map { position: relative; border-radius: var(--radius); overflow: hidden; border: 1px solid var(--border); box-shadow: var(--shadow-sm); }
    .map img { width: 100%; height: 200px; object-fit: cover; filter: saturate(.7) hue-rotate(150deg) brightness(1.05); }
    .map::after { content: ""; position: absolute; inset: 0; background: radial-gradient(circle at 50% 45%, rgba(10,166,194,.18), rgba(12,58,74,.28)); }
    .map-pin { position: absolute; left: 14px; bottom: 14px; z-index: 1; background: #fff; color: var(--primary); font-family: var(--font-display); font-weight: 600; font-size: .85rem; text-decoration: none; padding: 8px 14px; border-radius: 999px; box-shadow: var(--shadow-sm); }
    .nap { background: #fff; border: 1px solid var(--border); border-radius: var(--radius); padding: 22px; }
    .nap h3 { font-size: 1.15rem; }
    .addr { color: #44697a; margin: 8px 0 12px; }
    .call-big { display: inline-flex; align-items: center; gap: 6px; font-family: var(--font-display); font-weight: 700; font-size: 1.15rem; color: var(--primary); text-decoration: none; }
    .hours { width: 100%; border-collapse: collapse; background: #fff; border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
    .hours caption { text-align: left; font-family: var(--font-display); font-weight: 600; padding: 14px 18px 0; color: var(--deep); }
    .hours th, .hours td { padding: 11px 18px; text-align: left; border-top: 1px solid var(--border); }
    .hours tr:first-child th, .hours tr:first-child td { border-top: 0; }
    .hours th { font-weight: 600; color: var(--deep); }
    .hours td { color: #44697a; text-align: right; }
    .perks { font-size: .88rem; color: #5d7f8c; }

    /* Footer */
    .footer { background: var(--deep); color: #cfeef4; padding: 48px 0 110px; }
    .footer-inner { display: flex; justify-content: space-between; gap: 28px; flex-wrap: wrap; padding-bottom: 26px; border-bottom: 1px solid rgba(255,255,255,.12); }
    .footer-brand { display: flex; gap: 14px; max-width: 420px; align-items: flex-start; }
    .footer-brand p { font-size: .96rem; color: #b9dce4; }
    .footer-nav { display: flex; flex-wrap: wrap; gap: 8px 20px; align-content: flex-start; }
    .footer-nav a { text-decoration: none; color: #cfeef4; font-family: var(--font-display); font-weight: 500; font-size: .94rem; }
    .footer-nav a:hover { color: var(--accent); }
    .footer-base { display: flex; justify-content: space-between; gap: 12px; flex-wrap: wrap; padding-top: 22px; font-size: .85rem; color: #8fc0cc; }

    /* Sticky mobile book bar */
    .bookbar { display: none; position: fixed; bottom: 0; left: 0; right: 0; z-index: 90; gap: 10px; padding: 10px 14px calc(10px + env(safe-area-inset-bottom)); background: rgba(245,251,253,.92); backdrop-filter: blur(10px); border-top: 1px solid var(--border); }
    .bookbar a { flex: 1; text-align: center; text-decoration: none; font-family: var(--font-display); font-weight: 600; padding: 14px; border-radius: 14px; min-height: 48px; display: flex; align-items: center; justify-content: center; }
    .bookbar-call { background: #fff; border: 1.5px solid var(--border); color: var(--deep); flex: 0 0 90px; }
    .bookbar-book { background: var(--primary); color: #fff; }

    /* Reveal */
    .reveal { opacity: 0; transform: translateY(22px); transition: opacity .6s ease, transform .6s ease; }
    .reveal.in { opacity: 1; transform: none; }
    @media (prefers-reduced-motion: reduce) { .reveal { opacity: 1; transform: none; transition: none; } }

    /* Responsive */
    @media (max-width: 980px) {
      .cards, .team-grid, .reviews-grid, .steps, .trust-grid { grid-template-columns: repeat(2,1fr); }
      .hero-grid, .ba-grid, .visit-grid { grid-template-columns: 1fr; }
      .ba-grid .section-head { text-align: left; }
      .hero-media { max-width: 520px; }
    }
    @media (max-width: 760px) {
      .mainnav { position: fixed; inset: 70px 0 auto; flex-direction: column; gap: 4px; background: var(--bg); border-bottom: 1px solid var(--border); padding: 14px 22px 20px; transform: translateY(-12px); opacity: 0; pointer-events: none; transition: .2s; box-shadow: var(--shadow); }
      .mainnav.open { transform: none; opacity: 1; pointer-events: auto; }
      .mainnav a { padding: 12px; }
      .burger { display: flex; }
      .phone-link span { display: none; }
      .topbar-cta .btn-primary { display: none; }
      .bookbar { display: flex; }
    }
    @media (max-width: 540px) {
      .cards, .team-grid, .reviews-grid, .steps, .trust-grid { grid-template-columns: 1fr; }
      .field-row { grid-template-columns: 1fr; }
      .hero-badge { left: 0; }
      .footer-base { justify-content: flex-start; }
    }
  </style>
</body>
</html>
