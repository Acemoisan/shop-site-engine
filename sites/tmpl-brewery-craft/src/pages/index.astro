---
const onTap = [
  { name: "Pulp Theory", style: "Hazy IPA", abv: "6.8%", ibu: "45", note: "Mango, guava, soft pillowy bitterness.", price: "$8 / 16oz", pack: "$22 / 4-pack", seed: "pulptheory" },
  { name: "Ironclad", style: "West Coast IPA", abv: "7.1%", ibu: "65", note: "Pine, grapefruit, dry snappy finish.", price: "$8 / 16oz", pack: "$20 / 4-pack", seed: "ironclad" },
  { name: "Riverstone", style: "Czech Pilsner", abv: "4.9%", ibu: "32", note: "Crisp, floral Saaz, clean lager bite.", price: "$7 / 16oz", pack: "$18 / 4-pack", seed: "riverstone" },
  { name: "Foundry Stout", style: "Oatmeal Stout", abv: "5.6%", ibu: "38", note: "Cocoa, espresso, smooth roast.", price: "$7.50 / 16oz", pack: "$19 / 4-pack", seed: "foundry" },
  { name: "Sundial", style: "Tropical Sour Ale", abv: "4.4%", ibu: "8", note: "Passionfruit, lime, bright tart.", price: "$8 / 12oz", pack: "Taproom only", seed: "sundial" },
  { name: "Last Light NA", style: "Non-Alc Hazy Pale", abv: "0.4%", ibu: "25", note: "All the juice, none of the buzz.", price: "$6 / 16oz", pack: "$16 / 4-pack", seed: "lastlight" },
];

const toGo = [
  { name: "Growler Fill", detail: "Any tap · 1.9L", price: "$24" },
  { name: "Crowler", detail: "Sealed fresh · 1L", price: "$14" },
  { name: "Gift Card", detail: "Spread the pour", price: "from $25" },
];

const events = [
  { day: "TUE", title: "Pub Trivia Night", time: "7:00pm · Free to play" },
  { day: "FRI", title: "Live Music + Food Truck", time: "8:00pm · Rotating local acts" },
  { day: "SAT", title: "Brewery Tour + Tasting", time: "2:00pm · $15 / flight included" },
  { day: "SUN", title: "Vinyl & Pints", time: "1:00pm · Bring a record" },
];

const hours = [
  { d: "Monday", h: "Closed", closed: true },
  { d: "Tue – Thu", h: "3:00pm – 10:00pm" },
  { d: "Friday", h: "12:00pm – 12:00am" },
  { d: "Saturday", h: "11:00am – 12:00am" },
  { d: "Sunday", h: "11:00am – 8:00pm" },
];

const reviews = [
  { q: "Best taproom in the city — Pulp Theory ruined every other hazy for me.", a: "Devon R.", meta: "Untappd 4.7★" },
  { q: "Dog-friendly patio, killer pilsner, and the food truck rotation is unreal on Fridays.", a: "Marisol T.", meta: "Regular since '19" },
  { q: "Brought visiting friends here and now it's our standing Saturday spot.", a: "Aaron L.", meta: "Saturday crew" },
];

const stats = [
  { n: "2014", l: "Brewing since" },
  { n: "24", l: "Taps pouring" },
  { n: "2", l: "Blocks from grain to glass" },
  { n: "4.7", l: "Untappd average" },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BarOrPub",
  name: "Ironwood Brewing Co.",
  description: "Independent craft brewery and taproom in Inglewood, Calgary. Small batch, hop-forward beer brewed two blocks from the glass.",
  telephone: "+1-403-555-0148",
  address: { "@type": "PostalAddress", streetAddress: "1142 Brewery Lane SE", addressLocality: "Calgary", addressRegion: "AB", postalCode: "T2G 1M9", addressCountry: "CA" },
  openingHours: ["Tu-Th 15:00-22:00", "Fr 12:00-24:00", "Sa 11:00-24:00", "Su 11:00-20:00"],
  servesCuisine: "Craft Beer",
  priceRange: "$$",
};
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Ironwood Brewing Co. — Honest Beer for the Neighborhood · Inglewood, Calgary</title>
  <meta name="description" content="Ironwood Brewing Co. is an independent craft brewery and taproom in Inglewood, Calgary. Small batch, hop-forward beer brewed two blocks from the glass. See what's on tap, hours, events and how to visit." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Alfa+Slab+One&family=Source+Sans+3:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <set:html value={`<script type="application/ld+json">${JSON.stringify(jsonLd)}</script>`} />
</head>
<body>
  <!-- Age gate -->
  <div class="agegate" id="agegate" aria-hidden="false">
    <div class="agegate__card" role="dialog" aria-modal="true" aria-labelledby="agetitle">
      <div class="crest crest--lg" aria-hidden="true">
        <span class="crest__top">EST · 2014</span>
        <span class="crest__mark">IB</span>
        <span class="crest__bot">INGLEWOOD</span>
      </div>
      <h2 id="agetitle">Pull Up a Stool</h2>
      <p>You must be 18+ to enter the taproom. Are you of legal drinking age in Alberta?</p>
      <div class="agegate__btns">
        <button class="btn btn--primary" id="ageyes" type="button">Yes, I'm 18+</button>
        <a class="btn btn--ghost" href="https://www.google.com" id="ageno">Not yet</a>
      </div>
    </div>
  </div>

  <!-- Nav -->
  <header class="nav" id="nav">
    <a class="nav__brand" href="#top">
      <span class="crest crest--sm" aria-hidden="true"><span class="crest__mark">IB</span></span>
      <span class="nav__word">Ironwood<span>Brewing Co.</span></span>
    </a>
    <button class="nav__toggle" id="navToggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
    <nav class="nav__links" id="navLinks" aria-label="Primary">
      <a href="#tap">On Tap</a>
      <a href="#story">Our Story</a>
      <a href="#events">Events</a>
      <a href="#togo">To-Go</a>
      <a href="#visit">Visit</a>
      <a class="btn btn--primary btn--sm" href="tel:+14035550148">Call (403) 555-0148</a>
    </nav>
  </header>

  <main id="top">
    <!-- Hero -->
    <section class="hero" id="hero">
      <div class="hero__media" aria-hidden="true"></div>
      <div class="hero__inner">
        <p class="kicker reveal">Independent · Hop-Forward · Calgary's Taproom Since 2014</p>
        <h1 class="reveal">Small Batch.<br /><span class="ink">Big Pour.</span><br />Brewed Two Blocks From Here.</h1>
        <p class="hero__tag reveal">Honest beer for the neighborhood.</p>
        <div class="hero__cta reveal">
          <a class="btn btn--primary" href="#tap">See What's On Tap</a>
          <a class="btn btn--outline" href="#visit">Visit the Taproom</a>
        </div>
        <p class="hero__note reveal">Live music Fridays · Trivia Tuesdays · Food truck every weekend</p>
      </div>
    </section>

    <!-- Marquee -->
    <div class="marquee" aria-hidden="true">
      <div class="marquee__track">
        <span>Fresh Beer</span><span class="dot">✦</span><span>Fewer Steps</span><span class="dot">✦</span>
        <span>Brewhouse To Glass</span><span class="dot">✦</span><span>Dog Friendly Patio</span><span class="dot">✦</span>
        <span>Food Truck Fridays</span><span class="dot">✦</span><span>Fresh Beer</span><span class="dot">✦</span>
        <span>Fewer Steps</span><span class="dot">✦</span><span>Brewhouse To Glass</span><span class="dot">✦</span>
        <span>Dog Friendly Patio</span><span class="dot">✦</span><span>Food Truck Fridays</span><span class="dot">✦</span>
      </div>
    </div>

    <!-- Stats -->
    <section class="stats" aria-label="By the numbers">
      {stats.map((s) => (
        <div class="stats__item reveal">
          <span class="stats__n">{s.n}</span>
          <span class="stats__l">{s.l}</span>
        </div>
      ))}
    </section>

    <!-- On Tap -->
    <section class="tap" id="tap">
      <div class="section-head">
        <p class="kicker">What's Pouring</p>
        <h2 class="display">On Tap Today</h2>
        <p class="lede">Twenty-four lines, rotating weekly. Pour it here, take it home, or fill a growler at the bar.</p>
      </div>
      <ul class="tap__list">
        {onTap.map((b, i) => (
          <li class="tap__card reveal">
            <div class="tap__can" aria-hidden="true">
              <img src={`https://picsum.photos/seed/${b.seed}/220/440`} alt="" loading="lazy" width="220" height="440" />
              <span class="tap__num">{String(i + 1).padStart(2, "0")}</span>
            </div>
            <div class="tap__body">
              <div class="tap__top">
                <h3>{b.name}</h3>
                <span class="tap__style">{b.style}</span>
              </div>
              <div class="chips">
                <span class="chip">{b.abv} ABV</span>
                <span class="chip">{b.ibu} IBU</span>
              </div>
              <p class="tap__note">{b.note}</p>
              <div class="tap__price">
                <span>{b.price}</span>
                <span class="tap__pack">{b.pack}</span>
              </div>
            </div>
          </li>
        ))}
      </ul>
    </section>

    <!-- Story -->
    <section class="story" id="story">
      <div class="story__img reveal">
        <img src="https://picsum.photos/seed/ironwoodbrewhouse/900/1100" alt="Gleaming copper and steel fermentation tanks in the Ironwood brewhouse." width="900" height="1100" loading="lazy" />
        <div class="story__badge crest crest--md" aria-hidden="true">
          <span class="crest__top">SINCE</span><span class="crest__mark">'14</span><span class="crest__bot">CALGARY</span>
        </div>
      </div>
      <div class="story__text reveal">
        <p class="kicker">Our Story</p>
        <h2 class="display">Grain, Water, Hops &amp; The Block We Love</h2>
        <p>Ironwood started with a homebrew kit, a corner unit on Brewery Lane, and a stubborn belief that the freshest beer is the one made closest to the glass it's poured into. Ten years later, we're still two blocks from where you're standing.</p>
        <p>We brew small so we can brew often — chasing the harvest, the seasonal hops, and the styles our regulars keep asking for. No macro shortcuts, no shipping it across the country to go stale. Just honest beer for the neighborhood that raised us.</p>
        <ul class="story__pts">
          <li><strong>Independent &amp; family-run</strong> — no investors telling us what to pour.</li>
          <li><strong>Locally sourced</strong> — Alberta grain, Pacific Northwest hops, Bow River water.</li>
          <li><strong>Always fresh</strong> — most kegs hit the tap within two weeks of brew day.</li>
        </ul>
      </div>
    </section>

    <!-- Events -->
    <section class="events" id="events">
      <div class="section-head section-head--light">
        <p class="kicker kicker--light">This Week</p>
        <h2 class="display">Always Something On</h2>
        <p class="lede lede--light">Trivia, live sets, food trucks and release parties. Pull up a stool and stay a while.</p>
      </div>
      <div class="events__grid">
        {events.map((e) => (
          <article class="event reveal">
            <span class="event__day">{e.day}</span>
            <div>
              <h3>{e.title}</h3>
              <p>{e.time}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- To-Go / Merch -->
    <section class="togo" id="togo">
      <div class="section-head">
        <p class="kicker">Take It Home</p>
        <h2 class="display">Cans, Fills &amp; Gift Cards</h2>
      </div>
      <div class="togo__grid">
        {toGo.map((t, i) => (
          <article class={`togo__card reveal ${i === 1 ? 'togo__card--feature' : ''}`}>
            <img src={`https://picsum.photos/seed/togo${i}/600/420`} alt={`${t.name} from Ironwood Brewing.`} width="600" height="420" loading="lazy" />
            <div class="togo__meta">
              <h3>{t.name}</h3>
              <p>{t.detail}</p>
              <span class="togo__price">{t.price}</span>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- Reviews -->
    <section class="reviews" aria-label="What people say">
      <div class="section-head section-head--light">
        <p class="kicker kicker--light">The Word Around Town</p>
        <h2 class="display">Poured &amp; Approved</h2>
      </div>
      <div class="reviews__grid">
        {reviews.map((r) => (
          <figure class="review reveal">
            <div class="review__stars" aria-hidden="true">★★★★★</div>
            <blockquote>{r.q}</blockquote>
            <figcaption><strong>{r.a}</strong><span>{r.meta}</span></figcaption>
          </figure>
        ))}
      </div>
    </section>

    <!-- Visit -->
    <section class="visit" id="visit">
      <div class="visit__hours reveal">
        <p class="kicker">Taproom</p>
        <h2 class="display">Hours <span class="open" id="openNow">Checking…</span></h2>
        <table class="hours">
          <tbody>
            {hours.map((h) => (
              <tr class={h.closed ? "is-closed" : ""}>
                <th scope="row">{h.d}</th>
                <td>{h.h}</td>
              </tr>
            ))}
          </tbody>
        </table>
        <div class="visit__nap">
          <p><strong>Ironwood Brewing Co.</strong><br />1142 Brewery Lane SE<br />Inglewood, Calgary, AB T2G 1M9</p>
          <div class="visit__icons">
            <span class="vi">🐾 Dog-friendly</span>
            <span class="vi">☀️ Heated patio</span>
            <span class="vi">🅿️ Free parking</span>
          </div>
          <div class="visit__actions">
            <a class="btn btn--primary" href="tel:+14035550148">Call (403) 555-0148</a>
            <a class="btn btn--outline" href="https://maps.google.com/?q=1142+Brewery+Lane+SE+Calgary" target="_blank" rel="noopener">Get Directions</a>
          </div>
        </div>
      </div>
      <div class="visit__map reveal" aria-hidden="true">
        <img src="https://picsum.photos/seed/inglewoodmap/800/900?grayscale" alt="" width="800" height="900" loading="lazy" />
        <span class="visit__pin">📍 Inglewood</span>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta">
      <div class="cta__inner reveal">
        <div class="crest crest--md" aria-hidden="true">
          <span class="crest__top">EST · 2014</span><span class="crest__mark">IB</span><span class="crest__bot">CALGARY</span>
        </div>
        <h2 class="display">Cold Beer's Waiting. Come Grab a Stool.</h2>
        <p>Two blocks from the brewhouse to your glass. We'll keep a line open.</p>
        <div class="cta__btns">
          <a class="btn btn--cream" href="tel:+14035550148">Call the Bar</a>
          <a class="btn btn--outline-cream" href="https://maps.google.com/?q=1142+Brewery+Lane+SE+Calgary" target="_blank" rel="noopener">Plan Your Visit</a>
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="footer__brand">
      <span class="crest crest--sm" aria-hidden="true"><span class="crest__mark">IB</span></span>
      <div>
        <strong>Ironwood Brewing Co.</strong>
        <p>Honest beer for the neighborhood since 2014.</p>
      </div>
    </div>
    <div class="footer__col">
      <h4>Visit</h4>
      <p>1142 Brewery Lane SE<br />Inglewood, Calgary, AB T2G 1M9</p>
      <a href="tel:+14035550148">(403) 555-0148</a>
    </div>
    <div class="footer__col">
      <h4>Follow</h4>
      <a href="#" rel="noopener">Untappd</a>
      <a href="#" rel="noopener">Instagram</a>
      <a href="#" rel="noopener">Newsletter</a>
    </div>
    <p class="footer__legal">© 2026 Ironwood Brewing Co. · Please drink responsibly · 18+</p>
  </footer>

  <script>
    // Age gate
    (function () {
      const gate = document.getElementById("agegate");
      try {
        if (localStorage.getItem("iw_age_ok") === "1") gate.remove();
      } catch (e) {}
      const yes = document.getElementById("ageyes");
      if (yes) yes.addEventListener("click", () => {
        try { localStorage.setItem("iw_age_ok", "1"); } catch (e) {}
        gate.style.opacity = "0";
        setTimeout(() => gate.remove(), 350);
      });
    })();

    // Nav toggle + scroll state
    const nav = document.getElementById("nav");
    const toggle = document.getElementById("navToggle");
    const links = document.getElementById("navLinks");
    toggle.addEventListener("click", () => {
      const open = links.classList.toggle("is-open");
      toggle.setAttribute("aria-expanded", String(open));
    });
    links.querySelectorAll("a").forEach((a) =>
      a.addEventListener("click", () => {
        links.classList.remove("is-open");
        toggle.setAttribute("aria-expanded", "false");
      })
    );
    window.addEventListener("scroll", () => {
      nav.classList.toggle("is-stuck", window.scrollY > 24);
    });

    // Open-now indicator
    (function () {
      const el = document.getElementById("openNow");
      if (!el) return;
      const day = new Date().getDay(); // 0 Sun
      const hr = new Date().getHours();
      // Mon closed (1); Tue-Thu 15-22; Fri 12-24; Sat 11-24; Sun 11-20
      let open = false;
      if (day === 2 || day === 3 || day === 4) open = hr >= 15 && hr < 22;
      else if (day === 5) open = hr >= 12;
      else if (day === 6) open = hr >= 11;
      else if (day === 0) open = hr >= 11 && hr < 20;
      el.textContent = open ? "Open Now" : "Closed Now";
      el.classList.add(open ? "is-open" : "is-shut");
    })();

    // Scroll reveal
    const mq = window.matchMedia("(prefers-reduced-motion: reduce)");
    const items = document.querySelectorAll(".reveal");
    if (mq.matches || !("IntersectionObserver" in window)) {
      items.forEach((i) => i.classList.add("in"));
    } else {
      const io = new IntersectionObserver((ents) => {
        ents.forEach((e) => {
          if (e.isIntersecting) { e.target.classList.add("in"); io.unobserve(e.target); }
        });
      }, { threshold: 0.12 });
      items.forEach((i) => io.observe(i));
    }
  </script>

  <style is:global>
    *, *::before, *::after { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { margin: 0; }
    img { display: block; max-width: 100%; }
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after { animation-duration: .001ms !important; transition-duration: .001ms !important; scroll-behavior: auto !important; }
    }
  </style>

  <style>
    :root {
      --bg: #F4ECD8;
      --fg: #231A12;
      --primary: #9E3B25;
      --primary-fg: #F8F1E0;
      --accent: #D99A2B;
      --muted: #E4D6B8;
      --border: #C9B68C;
      --ink: #2E2418;
      --display: "Alfa Slab One", Georgia, serif;
      --body: "Source Sans 3", system-ui, sans-serif;
      --shadow: 0 18px 40px -22px rgba(35,26,18,.55);
    }

    body {
      background-color: var(--bg);
      color: var(--fg);
      font-family: var(--body);
      font-size: 17px;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      background-image:
        radial-gradient(rgba(35,26,18,.035) 1px, transparent 1px),
        radial-gradient(rgba(35,26,18,.025) 1px, transparent 1px);
      background-size: 22px 22px, 22px 22px;
      background-position: 0 0, 11px 11px;
    }

    h1, h2, h3, h4 { font-family: var(--display); font-weight: 400; line-height: 1.02; letter-spacing: .2px; }
    .display { text-transform: none; }
    p { margin: 0 0 1rem; }
    a { color: inherit; }

    :focus-visible { outline: 3px solid var(--accent); outline-offset: 3px; border-radius: 4px; }

    /* Buttons */
    .btn {
      display: inline-flex; align-items: center; justify-content: center;
      min-height: 48px; padding: 0 1.4rem; gap: .5rem;
      font-family: var(--body); font-weight: 700; font-size: .95rem;
      text-decoration: none; border: 2px solid transparent; border-radius: 2px;
      cursor: pointer; letter-spacing: .03em; text-transform: uppercase;
      transition: transform .15s ease, box-shadow .2s ease, background .2s ease, color .2s ease;
    }
    .btn--sm { min-height: 42px; padding: 0 1rem; font-size: .82rem; }
    .btn--primary { background: var(--primary); color: var(--primary-fg); box-shadow: 0 4px 0 #6f2716; }
    .btn--primary:hover { transform: translateY(-2px); box-shadow: 0 6px 0 #6f2716; }
    .btn--primary:active { transform: translateY(2px); box-shadow: 0 1px 0 #6f2716; }
    .btn--outline { background: transparent; color: var(--fg); border-color: var(--fg); }
    .btn--outline:hover { background: var(--fg); color: var(--bg); }
    .btn--ghost { background: transparent; color: var(--muted); border-color: var(--border); }
    .btn--ghost:hover { color: var(--primary-fg); }
    .btn--cream { background: var(--bg); color: var(--primary); box-shadow: 0 4px 0 rgba(0,0,0,.35); }
    .btn--cream:hover { transform: translateY(-2px); }
    .btn--outline-cream { background: transparent; color: var(--bg); border-color: var(--bg); }
    .btn--outline-cream:hover { background: var(--bg); color: var(--primary); }

    .kicker {
      font-weight: 700; text-transform: uppercase; letter-spacing: .22em;
      font-size: .74rem; color: var(--primary); margin: 0 0 .9rem;
    }
    .kicker--light { color: var(--accent); }

    .section-head { max-width: 720px; margin: 0 auto clamp(2rem,5vw,3.5rem); text-align: center; }
    .section-head h2 { font-size: clamp(2.1rem, 6vw, 3.6rem); margin: 0 0 1rem; }
    .lede { font-size: 1.1rem; color: color-mix(in srgb, var(--fg) 78%, transparent); margin: 0; }
    .lede--light { color: color-mix(in srgb, var(--primary-fg) 82%, transparent); }
    .section-head--light h2, .section-head--light .kicker { color: var(--primary-fg); }
    .section-head--light .kicker { color: var(--accent); }

    main > section { padding: clamp(3.5rem, 8vw, 6rem) clamp(1.1rem, 4vw, 3rem); }

    /* Crest */
    .crest {
      position: relative; display: grid; place-items: center; border-radius: 50%;
      background: var(--primary); color: var(--primary-fg);
      border: 2px solid var(--accent); box-shadow: inset 0 0 0 4px var(--primary), inset 0 0 0 6px rgba(217,154,43,.5);
      text-align: center; flex: none;
    }
    .crest__mark { font-family: var(--display); line-height: 1; }
    .crest__top, .crest__bot { position: absolute; font-family: var(--body); font-weight: 700; letter-spacing: .16em; font-size: .5rem; text-transform: uppercase; color: var(--accent); }
    .crest__top { top: .55rem; } .crest__bot { bottom: .55rem; }
    .crest--sm { width: 40px; height: 40px; border-width: 1px; box-shadow: inset 0 0 0 2px var(--primary), inset 0 0 0 3px rgba(217,154,43,.5); }
    .crest--sm .crest__mark { font-size: 1.05rem; }
    .crest--md { width: 96px; height: 96px; } .crest--md .crest__mark { font-size: 2rem; }
    .crest--lg { width: 120px; height: 120px; margin: 0 auto 1.4rem; } .crest--lg .crest__mark { font-size: 2.6rem; }

    /* Age gate */
    .agegate {
      position: fixed; inset: 0; z-index: 100; display: grid; place-items: center;
      padding: 1.5rem; background: rgba(35,26,18,.92);
      background-image: linear-gradient(rgba(35,26,18,.86), rgba(35,26,18,.94)), url("https://picsum.photos/seed/ironwoodgate/1200/800");
      background-size: cover; background-position: center; transition: opacity .35s ease;
    }
    .agegate__card { max-width: 440px; text-align: center; background: var(--bg); border: 2px solid var(--border); border-radius: 4px; padding: 2.4rem 1.8rem; box-shadow: var(--shadow); }
    .agegate__card h2 { font-size: 2rem; margin: 0 0 .6rem; }
    .agegate__card p { color: color-mix(in srgb, var(--fg) 80%, transparent); }
    .agegate__btns { display: flex; flex-direction: column; gap: .7rem; margin-top: 1.4rem; }
    .agegate__btns .btn--ghost { color: var(--fg); }

    /* Nav */
    .nav {
      position: sticky; top: 0; z-index: 50;
      display: flex; align-items: center; justify-content: space-between;
      gap: 1rem; padding: .7rem clamp(1.1rem, 4vw, 3rem);
      background: color-mix(in srgb, var(--bg) 90%, transparent);
      backdrop-filter: blur(8px); border-bottom: 2px solid transparent;
      transition: border-color .25s ease, box-shadow .25s ease, background .25s ease;
    }
    .nav.is-stuck { border-color: var(--border); box-shadow: 0 8px 24px -18px rgba(35,26,18,.6); }
    .nav__brand { display: flex; align-items: center; gap: .65rem; text-decoration: none; font-family: var(--display); }
    .nav__word { display: flex; flex-direction: column; font-size: 1.15rem; line-height: .95; color: var(--fg); }
    .nav__word span { font-family: var(--body); font-weight: 600; font-size: .58rem; letter-spacing: .2em; text-transform: uppercase; color: var(--primary); }
    .nav__links { display: flex; align-items: center; gap: 1.5rem; }
    .nav__links a { text-decoration: none; font-weight: 600; font-size: .95rem; color: var(--fg); transition: color .15s; }
    .nav__links a:not(.btn):hover { color: var(--primary); }
    .nav__toggle { display: none; flex-direction: column; gap: 5px; width: 48px; height: 48px; background: none; border: none; cursor: pointer; align-items: center; justify-content: center; }
    .nav__toggle span { width: 26px; height: 3px; background: var(--fg); border-radius: 2px; transition: transform .25s, opacity .25s; }

    @media (max-width: 900px) {
      .nav__toggle { display: flex; }
      .nav__links {
        position: absolute; top: 100%; left: 0; right: 0; flex-direction: column;
        align-items: stretch; gap: .4rem; padding: 1rem clamp(1.1rem,4vw,3rem) 1.5rem;
        background: var(--bg); border-bottom: 2px solid var(--border);
        transform: translateY(-12px); opacity: 0; pointer-events: none; transition: .25s ease;
      }
      .nav__links.is-open { transform: translateY(0); opacity: 1; pointer-events: auto; box-shadow: var(--shadow); }
      .nav__links a { padding: .6rem 0; }
      .nav__links .btn { margin-top: .4rem; }
    }

    /* Hero */
    .hero { position: relative; padding: clamp(4rem,10vw,8rem) clamp(1.1rem,4vw,3rem) clamp(5rem,9vw,7rem); overflow: hidden; }
    .hero__media {
      position: absolute; inset: 0; z-index: 0;
      background-image: linear-gradient(120deg, rgba(158,59,37,.82), rgba(35,26,18,.78)), url("https://picsum.photos/seed/ironwoodpour/1600/1100");
      background-size: cover; background-position: center; filter: saturate(1.05) contrast(1.02);
    }
    .hero__media::after { content: ""; position: absolute; inset: 0; background: radial-gradient(120% 90% at 18% 18%, transparent 40%, rgba(35,26,18,.5)); }
    .hero__inner { position: relative; z-index: 1; max-width: 1180px; margin: 0 auto; color: var(--primary-fg); }
    .hero .kicker { color: var(--accent); }
    .hero h1 { font-size: clamp(2.6rem, 9vw, 6rem); margin: 0 0 1.2rem; text-shadow: 0 4px 20px rgba(0,0,0,.35); }
    .hero h1 .ink { color: var(--accent); }
    .hero__tag { font-family: var(--display); font-size: clamp(1.1rem,3vw,1.6rem); color: var(--bg); margin: 0 0 2rem; opacity: .95; }
    .hero__cta { display: flex; flex-wrap: wrap; gap: .8rem; }
    .hero__cta .btn--outline { border-color: var(--bg); color: var(--bg); }
    .hero__cta .btn--outline:hover { background: var(--bg); color: var(--primary); }
    .hero__note { margin: 1.8rem 0 0; font-weight: 600; letter-spacing: .04em; font-size: .9rem; color: color-mix(in srgb, var(--primary-fg) 85%, transparent); }

    /* Marquee */
    .marquee { background: var(--ink); color: var(--bg); overflow: hidden; border-block: 3px solid var(--accent); padding: .7rem 0; }
    .marquee__track { display: inline-flex; align-items: center; gap: 1.6rem; white-space: nowrap; font-family: var(--display); font-size: 1.05rem; letter-spacing: .04em; animation: scroll 28s linear infinite; }
    .marquee__track .dot { color: var(--accent); }
    @keyframes scroll { to { transform: translateX(-50%); } }
    @media (prefers-reduced-motion: reduce) { .marquee__track { animation: none; } }

    /* Stats */
    .stats { display: grid; grid-template-columns: repeat(4,1fr); gap: 1px; background: var(--border); border-block: 2px solid var(--border); padding: 0 !important; }
    .stats__item { background: var(--bg); padding: clamp(1.6rem,4vw,2.6rem) 1rem; text-align: center; }
    .stats__n { display: block; font-family: var(--display); font-size: clamp(2rem,5vw,3rem); color: var(--primary); line-height: 1; }
    .stats__l { display: block; margin-top: .5rem; font-size: .8rem; text-transform: uppercase; letter-spacing: .12em; font-weight: 600; color: color-mix(in srgb, var(--fg) 70%, transparent); }
    @media (max-width: 700px) { .stats { grid-template-columns: repeat(2,1fr); } }

    /* Tap list */
    .tap__list { list-style: none; margin: 0; padding: 0; max-width: 1180px; margin-inline: auto; display: grid; grid-template-columns: repeat(2,1fr); gap: clamp(1rem,2.5vw,1.6rem); }
    .tap__card { display: flex; gap: 1.2rem; background: var(--muted); border: 2px solid var(--border); border-radius: 4px; padding: 1.1rem; overflow: hidden; transition: transform .2s ease, box-shadow .2s ease, border-color .2s; }
    .tap__card:hover { transform: translateY(-4px); box-shadow: var(--shadow); border-color: var(--primary); }
    .tap__can { position: relative; flex: none; width: 92px; align-self: stretch; border-radius: 3px; overflow: hidden; }
    .tap__can img { width: 100%; height: 100%; object-fit: cover; filter: sepia(.28) saturate(1.1) contrast(1.02); mix-blend-mode: multiply; }
    .tap__num { position: absolute; top: .35rem; left: .35rem; font-family: var(--display); font-size: .8rem; color: var(--bg); background: var(--primary); border-radius: 2px; padding: .05rem .35rem; }
    .tap__body { flex: 1; min-width: 0; display: flex; flex-direction: column; }
    .tap__top { display: flex; align-items: baseline; justify-content: space-between; gap: .6rem; flex-wrap: wrap; }
    .tap__top h3 { font-size: 1.3rem; margin: 0; color: var(--fg); }
    .tap__style { font-weight: 700; font-size: .76rem; text-transform: uppercase; letter-spacing: .08em; color: var(--primary); }
    .chips { display: flex; gap: .4rem; margin: .55rem 0 .6rem; flex-wrap: wrap; }
    .chip { font-size: .72rem; font-weight: 700; letter-spacing: .04em; background: var(--bg); border: 1px solid var(--border); color: var(--ink); padding: .18rem .5rem; border-radius: 999px; }
    .tap__note { font-size: .92rem; color: color-mix(in srgb, var(--fg) 80%, transparent); margin: 0 0 .8rem; }
    .tap__price { margin-top: auto; display: flex; flex-wrap: wrap; align-items: baseline; gap: .3rem .7rem; padding-top: .6rem; border-top: 1px dashed var(--border); font-family: var(--display); color: var(--primary); }
    .tap__pack { font-family: var(--body); font-weight: 600; font-size: .82rem; color: color-mix(in srgb, var(--fg) 65%, transparent); }
    @media (max-width: 760px) { .tap__list { grid-template-columns: 1fr; } }
    @media (max-width: 420px) { .tap__card { flex-direction: column; } .tap__can { width: 100%; height: 180px; } }

    /* Story */
    .story { display: grid; grid-template-columns: .85fr 1fr; gap: clamp(1.6rem,4vw,3.5rem); align-items: center; max-width: 1180px; margin-inline: auto; }
    .story__img { position: relative; }
    .story__img img { width: 100%; height: 100%; max-height: 620px; object-fit: cover; border-radius: 4px; border: 2px solid var(--border); filter: sepia(.3) saturate(1.05) contrast(1.02); }
    .story__badge { position: absolute; bottom: -22px; right: -18px; box-shadow: var(--shadow); }
    .story__text h2 { font-size: clamp(1.9rem,5vw,3.2rem); margin: 0 0 1.1rem; }
    .story__text p { color: color-mix(in srgb, var(--fg) 82%, transparent); }
    .story__pts { list-style: none; margin: 1.4rem 0 0; padding: 0; display: grid; gap: .7rem; }
    .story__pts li { position: relative; padding-left: 1.7rem; font-size: .96rem; }
    .story__pts li::before { content: "✦"; position: absolute; left: 0; color: var(--accent); font-size: 1rem; }
    @media (max-width: 820px) { .story { grid-template-columns: 1fr; } .story__img { max-width: 460px; } .story__badge { right: 8px; } }

    /* Events */
    .events { background: var(--ink); color: var(--primary-fg); position: relative; }
    .events__grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 1rem; max-width: 1000px; margin-inline: auto; }
    .event { display: flex; gap: 1.1rem; align-items: center; background: color-mix(in srgb, var(--primary) 18%, transparent); border: 1px solid color-mix(in srgb, var(--accent) 45%, transparent); border-radius: 4px; padding: 1.2rem 1.3rem; transition: transform .2s, background .2s; }
    .event:hover { transform: translateY(-3px); background: color-mix(in srgb, var(--primary) 30%, transparent); }
    .event__day { font-family: var(--display); font-size: 1.05rem; color: var(--ink); background: var(--accent); border-radius: 3px; padding: .5rem .55rem; min-width: 56px; text-align: center; flex: none; }
    .event h3 { font-size: 1.15rem; margin: 0 0 .25rem; color: var(--bg); }
    .event p { margin: 0; font-size: .88rem; color: color-mix(in srgb, var(--primary-fg) 80%, transparent); }
    @media (max-width: 700px) { .events__grid { grid-template-columns: 1fr; } }

    /* To-Go */
    .togo__grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.2rem; max-width: 1180px; margin-inline: auto; }
    .togo__card { background: var(--muted); border: 2px solid var(--border); border-radius: 4px; overflow: hidden; transition: transform .2s, box-shadow .2s; }
    .togo__card:hover { transform: translateY(-5px) rotate(-.4deg); box-shadow: var(--shadow); }
    .togo__card img { width: 100%; height: 200px; object-fit: cover; filter: sepia(.25) saturate(1.1); }
    .togo__meta { padding: 1.2rem 1.3rem 1.4rem; }
    .togo__meta h3 { font-size: 1.4rem; margin: 0 0 .25rem; color: var(--fg); }
    .togo__meta p { margin: 0 0 .7rem; font-size: .9rem; color: color-mix(in srgb, var(--fg) 70%, transparent); }
    .togo__price { font-family: var(--display); color: var(--primary); font-size: 1.2rem; }
    .togo__card--feature { border-color: var(--primary); background: var(--primary); }
    .togo__card--feature .togo__meta h3, .togo__card--feature .togo__price { color: var(--primary-fg); }
    .togo__card--feature .togo__meta p { color: color-mix(in srgb, var(--primary-fg) 80%, transparent); }
    .togo__card--feature .togo__price { color: var(--accent); }
    @media (max-width: 800px) { .togo__grid { grid-template-columns: 1fr; max-width: 460px; } }

    /* Reviews */
    .reviews { background: var(--primary); color: var(--primary-fg); }
    .reviews__grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.2rem; max-width: 1180px; margin-inline: auto; }
    .review { background: color-mix(in srgb, var(--bg) 14%, var(--primary)); border: 1px solid color-mix(in srgb, var(--accent) 50%, transparent); border-radius: 4px; padding: 1.6rem 1.5rem; margin: 0; }
    .review__stars { color: var(--accent); letter-spacing: .15em; margin-bottom: .8rem; }
    .review blockquote { margin: 0 0 1.1rem; font-size: 1.08rem; line-height: 1.5; }
    .review figcaption { display: flex; flex-direction: column; font-size: .85rem; }
    .review figcaption strong { font-family: var(--display); font-weight: 400; font-size: 1rem; }
    .review figcaption span { color: var(--accent); }
    @media (max-width: 860px) { .reviews__grid { grid-template-columns: 1fr; max-width: 540px; } }

    /* Visit */
    .visit { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(1.6rem,4vw,3rem); align-items: stretch; max-width: 1180px; margin-inline: auto; }
    .visit__hours h2 { font-size: clamp(1.9rem,5vw,3rem); margin: 0 0 1.3rem; display: flex; align-items: center; gap: .8rem; flex-wrap: wrap; }
    .open { font-family: var(--body); font-size: .8rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; padding: .3rem .65rem; border-radius: 999px; border: 1px solid var(--border); }
    .open.is-open { background: #2f6b2f; color: #eafce6; border-color: #2f6b2f; }
    .open.is-shut { background: var(--muted); color: var(--ink); }
    .hours { width: 100%; border-collapse: collapse; margin-bottom: 1.6rem; }
    .hours th, .hours td { text-align: left; padding: .75rem .2rem; border-bottom: 1px solid var(--border); font-weight: 600; }
    .hours td { text-align: right; font-family: var(--display); font-weight: 400; color: var(--primary); }
    .hours tr.is-closed td { color: color-mix(in srgb, var(--fg) 45%, transparent); }
    .visit__nap p { font-size: 1rem; }
    .visit__icons { display: flex; flex-wrap: wrap; gap: .6rem; margin: 1rem 0 1.3rem; }
    .vi { font-size: .85rem; font-weight: 600; background: var(--muted); border: 1px solid var(--border); border-radius: 999px; padding: .35rem .75rem; }
    .visit__actions { display: flex; flex-wrap: wrap; gap: .7rem; }
    .visit__map { position: relative; border-radius: 4px; overflow: hidden; border: 2px solid var(--border); min-height: 320px; }
    .visit__map img { width: 100%; height: 100%; object-fit: cover; filter: sepia(.4) contrast(1.05); }
    .visit__pin { position: absolute; bottom: 1rem; left: 1rem; background: var(--primary); color: var(--primary-fg); font-weight: 700; font-size: .85rem; padding: .45rem .8rem; border-radius: 3px; box-shadow: var(--shadow); }
    @media (max-width: 820px) { .visit { grid-template-columns: 1fr; } }

    /* CTA */
    .cta { background: var(--ink); color: var(--primary-fg); text-align: center; position: relative; overflow: hidden; }
    .cta::before { content: ""; position: absolute; inset: 0; background-image: linear-gradient(rgba(46,36,24,.82), rgba(46,36,24,.9)), url("https://picsum.photos/seed/ironwoodtaproom/1500/700"); background-size: cover; background-position: center; }
    .cta__inner { position: relative; max-width: 740px; margin: 0 auto; }
    .cta .crest--md { margin: 0 auto 1.4rem; }
    .cta h2 { font-size: clamp(2rem,6vw,3.6rem); margin: 0 0 1rem; }
    .cta p { color: color-mix(in srgb, var(--primary-fg) 85%, transparent); margin: 0 0 2rem; font-size: 1.1rem; }
    .cta__btns { display: flex; flex-wrap: wrap; gap: .8rem; justify-content: center; }

    /* Footer */
    .footer { background: #1b140d; color: var(--muted); padding: clamp(2.5rem,5vw,3.5rem) clamp(1.1rem,4vw,3rem); display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 2rem; }
    .footer__brand { display: flex; gap: .9rem; align-items: flex-start; }
    .footer__brand strong { font-family: var(--display); font-weight: 400; color: var(--bg); font-size: 1.2rem; }
    .footer__brand p { margin: .3rem 0 0; font-size: .9rem; }
    .footer__col h4 { font-family: var(--body); font-weight: 700; text-transform: uppercase; letter-spacing: .14em; font-size: .78rem; color: var(--accent); margin: 0 0 .8rem; }
    .footer__col p { font-size: .9rem; margin: 0 0 .6rem; }
    .footer__col a { display: block; text-decoration: none; color: var(--muted); padding: .25rem 0; font-size: .92rem; transition: color .15s; }
    .footer__col a:hover { color: var(--accent); }
    .footer__legal { grid-column: 1 / -1; border-top: 1px solid rgba(201,182,140,.25); padding-top: 1.4rem; margin: .5rem 0 0; font-size: .8rem; color: rgba(228,214,184,.6); }
    @media (max-width: 760px) { .footer { grid-template-columns: 1fr 1fr; } .footer__brand { grid-column: 1 / -1; } }
    @media (max-width: 460px) { .footer { grid-template-columns: 1fr; } }

    /* Reveal */
    .reveal { opacity: 0; transform: translateY(26px); transition: opacity .6s ease, transform .6s ease; }
    .reveal.in { opacity: 1; transform: none; }
  </style>
</body>
</html>
