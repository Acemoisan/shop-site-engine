---
import "@studio0rbit/shared/styles/base.css";
import "../theme.css";
import { shop as fallback } from "../content/shop";
import type { ShopContent } from "@studio0rbit/shared";
import SiteNav from "@studio0rbit/shared/components/SiteNav.astro";
import Hero from "@studio0rbit/shared/components/Hero.astro";
import Stats from "@studio0rbit/shared/components/Stats.astro";
import Features from "@studio0rbit/shared/components/Features.astro";
import ContactNAP from "@studio0rbit/shared/components/ContactNAP.astro";
import Hours from "@studio0rbit/shared/components/Hours.astro";
import Services from "@studio0rbit/shared/components/Services.astro";
import Testimonials from "@studio0rbit/shared/components/Testimonials.astro";
import Faq from "@studio0rbit/shared/components/Faq.astro";
import CTA from "@studio0rbit/shared/components/CTA.astro";
import SiteFooter from "@studio0rbit/shared/components/SiteFooter.astro";
import LocalBusinessJsonLd from "@studio0rbit/shared/seo/LocalBusinessJsonLd.astro";

// Local defaults — used as fallback if Storyblok is unavailable or a field is empty.
let shop: ShopContent = fallback;
let stats = [
  { value: "Est. 2012", label: "Beltline barbers" },
  { value: "4.9★", label: "200+ Google reviews" },
  { value: "Walk-ins", label: "Welcome daily" },
];
let features = [
  { icon: "scissors", title: "Master barbers", body: "Skilled hands and sharp eyes — every cut dialled in to you." },
  { icon: "star", title: "Classic & modern", body: "From a clean side-part to a skin fade, we do it all." },
  { icon: "clock", title: "In and out, sharp", body: "Respect for your time — quality work without the wait." },
  { icon: "calendar", title: "Easy online booking", body: "Reserve your chair in seconds, or walk in any day." },
  { icon: "coffee", title: "On the house", body: "Grab a coffee or a whisky while you wait." },
  { icon: "mapPin", title: "Heart of 17th Ave", body: "Right in the Beltline — easy to find, easy to park." },
];
let testimonials = [
  { quote: "Best fade in the city, hands down. Been coming for years.", name: "Mike D." },
  { quote: "Walked in on a Saturday, barely waited, left looking sharp.", name: "Chris L." },
  { quote: "These guys actually listen — exactly the cut I asked for.", name: "Andre P." },
];
let faqs = [
  { q: "Do you take walk-ins?", a: "Yes — walk-ins are welcome every day we're open. Booking ahead guarantees your time." },
  { q: "How do I book?", a: "Tap any 'Book' button to reserve online, or just drop by." },
  { q: "Do you cut kids' hair?", a: "Absolutely — all ages are welcome in the chair." },
  { q: "Is there parking?", a: "Street parking along 17th Ave plus nearby lots." },
];
let h = { featuresLabel: "Why us", featuresHeading: "A proper barber, done right", testimonialsLabel: "Reviews", testimonialsHeading: "Calgary keeps coming back", faqHeading: "Questions, answered", ctaHeading: "Ready when you are." };

// Content comes from Storyblok (client-editable). Everything below is overridable in the CMS.
const token = import.meta.env.STORYBLOK_TOKEN;
const slug = import.meta.env.STORYBLOK_STORY ?? "ironside-barber";
let source = "fallback (local file)";
if (token) {
  try {
    const res = await fetch(`https://api.storyblok.com/v2/cdn/stories/${slug}?token=${token}&version=published`);
    if (res.ok) {
      const { story } = await res.json();
      const c = story.content;
      shop = {
        name: c.name,
        tagline: c.tagline,
        vertical: "salon",
        heroImage: (c.hero_image && typeof c.hero_image === "object" ? c.hero_image.filename : c.hero_image) || fallback.heroImage,
        phone: c.phone,
        address: c.address,
        mapUrl: c.map_url,
        serviceArea: c.service_area,
        bookingUrl: c.booking_url,
        hours: (c.hours ?? []).map((x: any) => ({ day: x.day, open: x.open, close: x.close, closed: x.closed })),
        services: (c.services ?? []).map((x: any) => ({ name: x.name, price: x.price, description: x.description })),
        reviewsBlurb: c.reviews_blurb,
        rating: typeof c.rating === "string" ? parseFloat(c.rating) : c.rating,
        url: fallback.url,
      };
      if (c.stats?.length) stats = c.stats.map((x: any) => ({ value: x.value, label: x.label }));
      if (c.features?.length) features = c.features.map((x: any) => ({ icon: x.icon, title: x.title, body: x.body }));
      if (c.testimonials?.length) testimonials = c.testimonials.map((x: any) => ({ quote: x.quote, name: x.name }));
      if (c.faqs?.length) faqs = c.faqs.map((x: any) => ({ q: x.question, a: x.answer }));
      h = {
        featuresLabel: c.features_label || h.featuresLabel,
        featuresHeading: c.features_heading || h.featuresHeading,
        testimonialsLabel: c.testimonials_label || h.testimonialsLabel,
        testimonialsHeading: c.testimonials_heading || h.testimonialsHeading,
        faqHeading: c.faq_heading || h.faqHeading,
        ctaHeading: c.cta_heading || h.ctaHeading,
      };
      source = "Storyblok";
    }
  } catch {
    // keep fallbacks
  }
}
console.log(`[demo-barber] content source: ${source}`);
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{shop.name} — {shop.tagline}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <LocalBusinessJsonLd shop={shop} />
  </head>
  <body id="top" class="bg-background text-foreground font-sans">
    <SiteNav
      name={shop.name}
      bookingUrl={shop.bookingUrl}
      links={[{ label: "Services", href: "#services" }, { label: "Why us", href: "#features" }, { label: "Hours", href: "#hours" }, { label: "Visit", href: "#visit" }]}
    />
    <Hero name={shop.name} tagline={shop.tagline} bookingUrl={shop.bookingUrl} heroImage={shop.heroImage} />
    <Stats items={stats} />
    <Features label={h.featuresLabel} heading={h.featuresHeading} items={features} />
    <Services services={shop.services} heading="Services" />
    <Hours hours={shop.hours} />
    <Testimonials label={h.testimonialsLabel} heading={h.testimonialsHeading} items={testimonials} />
    <ContactNAP name={shop.name} phone={shop.phone} address={shop.address} mapUrl={shop.mapUrl} serviceArea={shop.serviceArea} />
    <Faq heading={h.faqHeading} items={faqs} />
    <CTA phone={shop.phone} bookingUrl={shop.bookingUrl} heading={h.ctaHeading} />
    <SiteFooter name={shop.name} address={shop.address} phone={shop.phone} />
  </body>
</html>
