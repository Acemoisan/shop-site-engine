---
// Irongrid Studio — boutique strength studio (template)
const nav = [
  { label: "Classes", href: "#programs" },
  { label: "Pricing", href: "#pricing" },
  { label: "Coaches", href: "#coaches" },
  { label: "Schedule", href: "#schedule" },
  { label: "Visit", href: "#visit" },
];

const programs = [
  { tag: "All levels", name: "Coached Strength", blurb: "Small-group barbell work with a coach who programs for your body, not a leaderboard.", seed: "irongrid-strength" },
  { tag: "Cardio + grit", name: "Conditioning", blurb: "Heart-pumping circuits that feel more like a party than a punishment.", seed: "irongrid-cond" },
  { tag: "Brand new?", name: "Foundations", blurb: "An 8-week on-ramp that turns 'I've never lifted' into 'watch this'.", seed: "irongrid-found" },
  { tag: "Your hours", name: "Open Gym", blurb: "Drop in, do your thing, with coaches floating nearby whenever you wave.", seed: "irongrid-open" },
];

const pricing = [
  { name: "Drop-In", price: "$25", unit: "/ class", features: ["One coached class", "No commitment", "Loaner gear included"], featured: false },
  { name: "Unlimited Monthly", price: "$169", unit: "/ month", features: ["All classes, every day", "Open gym access", "Free monthly check-in", "Cancel anytime"], featured: true },
  { name: "Intro Pack", price: "$59", unit: "3 classes", features: ["3 coached classes", "Movement assessment", "Perfect first step"], featured: false },
];

const coaches = [
  { name: "Maya Okonkwo", role: "Head Coach", cred: "CSCS · 9 yrs coaching", seed: "coach-maya" },
  { name: "Theo Bautista", role: "Strength Lead", cred: "USAW L2 · Powerlifting", seed: "coach-theo" },
  { name: "Priya Sandhu", role: "Foundations Coach", cred: "NASM-CPT · Beginner specialist", seed: "coach-priya" },
];

const testimonials = [
  { quote: "Down 22 lbs and deadlifting double my bodyweight. The coaches actually program for YOU.", name: "Megan R." },
  { quote: "I was terrified of a 'real' gym. Six months later it's the best part of my day.", name: "Devon T." },
  { quote: "Small classes, real coaching, zero ego. Worth every dollar.", name: "Priya S." },
];

const schedule = [
  { day: "Mon", slots: ["6:00a Strength", "12:00p Conditioning", "5:30p Strength"] },
  { day: "Tue", slots: ["6:00a Conditioning", "9:30a Open Gym", "6:00p Foundations"] },
  { day: "Wed", slots: ["6:00a Strength", "12:00p Strength", "5:30p Conditioning"] },
  { day: "Thu", slots: ["6:00a Conditioning", "9:30a Open Gym", "6:00p Strength"] },
  { day: "Fri", slots: ["6:00a Strength", "12:00p Conditioning", "4:30p Open Gym"] },
  { day: "Sat", slots: ["8:00a Community WOD", "10:00a Foundations"] },
];

const hours = [
  { d: "Mon – Fri", h: "5:00 AM – 9:00 PM" },
  { d: "Saturday", h: "7:00 AM – 4:00 PM" },
  { d: "Sunday", h: "8:00 AM – 2:00 PM" },
];

const phone = "(403) 555-0184";
const phoneHref = "tel:+14035550184";
const address = "1142 11 Avenue SW, Calgary, AB T2R 0G6";
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ExerciseGym",
  name: "Irongrid Studio",
  image: "https://picsum.photos/seed/irongrid-hero/1200/800",
  telephone: "+14035550184",
  address: { "@type": "PostalAddress", streetAddress: "1142 11 Avenue SW", addressLocality: "Calgary", addressRegion: "AB", postalCode: "T2R 0G6", addressCountry: "CA" },
  openingHours: ["Mo-Fr 05:00-21:00", "Sa 07:00-16:00", "Su 08:00-14:00"],
  priceRange: "$$",
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Irongrid Studio — Friendly Coached Strength in Calgary</title>
    <meta name="description" content="Calgary's bright, welcoming strength studio. Coached small-group classes for every body — no egos, just progress. Book a free intro class today." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Nunito+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>

    <header class="nav" id="top">
      <div class="wrap nav-inner">
        <a class="brand" href="#top" aria-label="Irongrid Studio home">
          <span class="brand-mark" aria-hidden="true">
            <svg viewBox="0 0 32 32" width="28" height="28"><circle cx="16" cy="16" r="15" fill="none" stroke="currentColor" stroke-width="2"/><path d="M9 16h14M9 11h14M9 21h14" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/></svg>
          </span>
          <span>Irongrid<em>Studio</em></span>
        </a>
        <nav class="nav-links" aria-label="Primary">
          {nav.map((n) => <a href={n.href}>{n.label}</a>)}
        </nav>
        <a class="btn btn-sm" href="#cta">Book free class</a>
        <button class="menu-toggle" aria-label="Toggle menu" aria-expanded="false"><span></span><span></span><span></span></button>
      </div>
      <nav class="mobile-menu" aria-label="Mobile">
        {nav.map((n) => <a href={n.href}>{n.label}</a>)}
        <a class="btn" href="#cta">Book free class</a>
      </nav>
    </header>

    <main id="main">
      <!-- HERO -->
      <section class="hero">
        <div class="hero-photo" aria-hidden="true"></div>
        <div class="wrap hero-grid">
          <div class="hero-copy reveal">
            <span class="eyebrow">Calgary · 11th Ave SW</span>
            <h1>Stronger<br/>starts <span class="hl">here.</span></h1>
            <p class="lede">Coached strength training for every body — no egos, just progress. Bright room, friendly faces, real results.</p>
            <div class="hero-actions">
              <a class="btn btn-lg" href="#cta">Book a free intro class</a>
              <a class="btn btn-ghost btn-lg" href={phoneHref}>Call {phone}</a>
            </div>
            <ul class="hero-stats">
              <li><strong data-count="1200">0</strong><span>members coached</span></li>
              <li><strong data-count="38">0</strong><span>classes / week</span></li>
              <li><strong data-count="9">0</strong><span>coaches on staff</span></li>
            </ul>
          </div>
          <div class="hero-art reveal">
            <div class="blob blob-a"></div>
            <div class="blob blob-b"></div>
            <figure class="hero-card"><img src="https://picsum.photos/seed/irongrid-hero/720/900" alt="A coach spotting a member during a barbell lift in a bright studio" loading="eager" /></figure>
          </div>
        </div>
      </section>

      <!-- MARQUEE -->
      <div class="marquee" aria-hidden="true">
        <div class="marquee-track">
          <span>Show up</span><i>✦</i><span>Lift heavy</span><i>✦</i><span>Repeat</span><i>✦</i><span>No egos</span><i>✦</i><span>Just progress</span><i>✦</i>
          <span>Show up</span><i>✦</i><span>Lift heavy</span><i>✦</i><span>Repeat</span><i>✦</i><span>No egos</span><i>✦</i><span>Just progress</span><i>✦</i>
        </div>
      </div>

      <!-- PROGRAMS -->
      <section class="section" id="programs">
        <div class="wrap">
          <div class="head reveal">
            <span class="kicker">What you'll do</span>
            <h2>Pick your kind of strong</h2>
            <p class="sub">Four ways in, all of them coached. Self-select your start — we'll meet you where you are.</p>
          </div>
          <div class="program-grid">
            {programs.map((p) => (
              <article class="program reveal">
                <div class="program-img"><img src={`https://picsum.photos/seed/${p.seed}/600/440`} alt={p.name + " session at Irongrid Studio"} loading="lazy" /></div>
                <div class="program-body">
                  <span class="tag">{p.tag}</span>
                  <h3>{p.name}</h3>
                  <p>{p.blurb}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- PRICING -->
      <section class="section band" id="pricing">
        <div class="wrap">
          <div class="head reveal">
            <span class="kicker">Memberships</span>
            <h2>Simple plans, no fine print</h2>
            <p class="sub">Month-to-month. Cancel anytime. The hardest part is showing up the first time — so the first time is free.</p>
          </div>
          <div class="price-grid">
            {pricing.map((p) => (
              <article class={"price " + (p.featured ? "price-featured" : "")}>
                {p.featured && <span class="ribbon">Most popular</span>}
                <h3>{p.name}</h3>
                <div class="amount"><strong>{p.price}</strong><span>{p.unit}</span></div>
                <ul>
                  {p.features.map((f) => <li>{f}</li>)}
                </ul>
                <a class={"btn " + (p.featured ? "" : "btn-ghost")} href="#cta">Choose {p.name}</a>
              </article>
            ))}
          </div>
          <p class="price-note">Also offering Strength Foundations (8-week) — $299 · 1-on-1 Coaching — $90/session · Open Gym — $89/month</p>
        </div>
      </section>

      <!-- COACHES -->
      <section class="section" id="coaches">
        <div class="wrap">
          <div class="head reveal">
            <span class="kicker">Your people</span>
            <h2>Coaches who learn your name</h2>
            <p class="sub">Credentialed, friendly, and genuinely in your corner.</p>
          </div>
          <div class="coach-grid">
            {coaches.map((c) => (
              <article class="coach reveal">
                <div class="coach-img"><img src={`https://picsum.photos/seed/${c.seed}/480/560`} alt={"Coach " + c.name} loading="lazy" /></div>
                <div class="coach-meta">
                  <span class="role">{c.role}</span>
                  <h3>{c.name}</h3>
                  <p>{c.cred}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- TESTIMONIALS SLIDER -->
      <section class="section band" id="results" aria-label="Member results">
        <div class="wrap">
          <div class="head reveal">
            <span class="kicker">Results</span>
            <h2>Real people, real progress</h2>
          </div>
          <div class="slider" data-slider>
            <div class="slides">
              {testimonials.map((t, i) => (
                <figure class="slide" data-slide={i} aria-hidden={i === 0 ? "false" : "true"}>
                  <blockquote>“{t.quote}”</blockquote>
                  <figcaption>— {t.name}</figcaption>
                </figure>
              ))}
            </div>
            <div class="dots" role="tablist" aria-label="Choose a testimonial">
              {testimonials.map((_, i) => <button class={"dot " + (i === 0 ? "active" : "")} data-dot={i} aria-label={`Testimonial ${i + 1}`}></button>)}
            </div>
          </div>
        </div>
      </section>

      <!-- SCHEDULE -->
      <section class="section" id="schedule">
        <div class="wrap">
          <div class="head reveal">
            <span class="kicker">This week</span>
            <h2>Find a time that fits</h2>
            <p class="sub">Reserve your spot in seconds — classes cap small so coaching stays personal.</p>
          </div>
          <div class="schedule">
            {schedule.map((row) => (
              <div class="sched-row reveal">
                <div class="sched-day">{row.day}</div>
                <div class="sched-slots">
                  {row.slots.map((s) => <a class="slot" href="#cta">{s}<em>Reserve</em></a>)}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="cta" id="cta">
        <div class="wrap cta-inner reveal">
          <span class="kicker light">First class is on us</span>
          <h2>Come try the friendliest barbell in Calgary</h2>
          <p>Book a free intro class, meet a coach, and lift something. No pressure, no contract, no ego.</p>
          <div class="cta-actions">
            <a class="btn btn-lg btn-accent" href="#cta">Book a free intro class</a>
            <a class="btn btn-lg btn-ghost-light" href={phoneHref}>Call {phone}</a>
          </div>
        </div>
      </section>

      <!-- VISIT / NAP -->
      <section class="section" id="visit">
        <div class="wrap visit-grid">
          <div class="reveal">
            <span class="kicker">Visit us</span>
            <h2>Find the studio</h2>
            <address>
              <p class="addr">{address}</p>
              <p><a class="callline" href={phoneHref}>{phone}</a></p>
            </address>
            <table class="hours">
              <tbody>
                {hours.map((h) => (<tr><th scope="row">{h.d}</th><td>{h.h}</td></tr>))}
              </tbody>
            </table>
            <a class="btn btn-ghost" href="https://maps.google.com/?q=1142+11+Avenue+SW+Calgary+AB" target="_blank" rel="noopener">Get directions</a>
          </div>
          <figure class="map reveal">
            <img src="https://picsum.photos/seed/irongrid-map/720/640" alt="Exterior of Irongrid Studio on 11th Avenue SW" loading="lazy" />
            <figcaption>1142 11 Ave SW</figcaption>
          </figure>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="wrap footer-inner">
        <div class="brand brand-foot">
          <span class="brand-mark" aria-hidden="true"><svg viewBox="0 0 32 32" width="24" height="24"><circle cx="16" cy="16" r="15" fill="none" stroke="currentColor" stroke-width="2"/><path d="M9 16h14M9 11h14M9 21h14" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/></svg></span>
          <span>Irongrid<em>Studio</em></span>
        </div>
        <p class="tagline">Coached strength training for every body — no egos, just progress.</p>
        <nav class="foot-links" aria-label="Footer">{nav.map((n) => <a href={n.href}>{n.label}</a>)}</nav>
      </div>
      <div class="wrap copyright"><p>© 2026 Irongrid Studio · {address} · {phone}</p></div>
    </footer>

    <!-- STICKY MOBILE BOOKING BAR -->
    <div class="bookbar" aria-hidden="false">
      <a href={phoneHref} class="bookbar-call" aria-label="Call the studio">Call</a>
      <a href="#cta" class="bookbar-book">Book a free class</a>
    </div>

    <style is:global>
      *, *::before, *::after { box-sizing: border-box; }
      html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
      body { margin: 0; }
      img { display: block; max-width: 100%; }
      @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
        *, *::before, *::after { animation-duration: 0.001ms !important; transition-duration: 0.001ms !important; }
      }
    </style>

    <style>
      :root {
        --bg: #FFF8F2;
        --fg: #2A2320;
        --primary: #FF6B5C;
        --primary-fg: #FFFFFF;
        --accent: #FFC857;
        --muted: #8A7F78;
        --border: #EFE2D8;
        --card: #FFFFFF;
        --dark: #2A2320;
        --radius: 22px;
        --radius-sm: 14px;
        --font-display: "Fraunces", Georgia, serif;
        --font-body: "Nunito Sans", system-ui, sans-serif;
        --shadow: 0 18px 50px -24px rgba(42, 35, 32, 0.35);
        --shadow-sm: 0 8px 24px -14px rgba(42, 35, 32, 0.3);
        --maxw: 1180px;
      }

      body { background: var(--bg); color: var(--fg); font-family: var(--font-body); line-height: 1.6; font-size: 1.02rem; -webkit-font-smoothing: antialiased; }
      .wrap { width: min(var(--maxw), 92vw); margin-inline: auto; }
      h1, h2, h3 { font-family: var(--font-display); line-height: 1.04; margin: 0; letter-spacing: -0.02em; font-weight: 600; }
      p { margin: 0; }
      a { color: inherit; }

      .skip { position: absolute; left: -999px; top: 0; background: var(--fg); color: #fff; padding: 12px 18px; border-radius: 0 0 12px 0; z-index: 200; }
      .skip:focus { left: 0; }
      :focus-visible { outline: 3px solid var(--primary); outline-offset: 3px; border-radius: 6px; }

      /* Buttons */
      .btn { display: inline-flex; align-items: center; justify-content: center; gap: 8px; min-height: 46px; padding: 12px 22px; border-radius: 999px; background: var(--primary); color: var(--primary-fg); font-weight: 700; font-family: var(--font-body); text-decoration: none; border: 2px solid var(--primary); cursor: pointer; transition: transform .18s ease, box-shadow .18s ease, background .18s ease; box-shadow: var(--shadow-sm); }
      .btn:hover { transform: translateY(-2px); box-shadow: 0 14px 30px -12px rgba(255,107,92,.6); }
      .btn-lg { min-height: 54px; padding: 15px 30px; font-size: 1.05rem; }
      .btn-sm { min-height: 42px; padding: 9px 18px; font-size: .92rem; }
      .btn-ghost { background: transparent; color: var(--fg); border-color: var(--border); box-shadow: none; }
      .btn-ghost:hover { background: #fff; border-color: var(--primary); color: var(--primary); }
      .btn-accent { background: var(--accent); border-color: var(--accent); color: var(--dark); }
      .btn-accent:hover { box-shadow: 0 14px 30px -12px rgba(255,200,87,.7); }
      .btn-ghost-light { background: rgba(255,255,255,.08); color: #fff; border-color: rgba(255,255,255,.4); box-shadow: none; }
      .btn-ghost-light:hover { background: rgba(255,255,255,.16); border-color: #fff; }

      .kicker, .eyebrow { display: inline-block; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; font-size: .76rem; color: var(--primary); }
      .kicker.light { color: var(--accent); }

      /* Nav */
      .nav { position: sticky; top: 0; z-index: 100; background: rgba(255,248,242,.86); backdrop-filter: blur(12px); border-bottom: 1px solid var(--border); }
      .nav-inner { display: flex; align-items: center; gap: 18px; padding: 14px 0; }
      .brand { display: inline-flex; align-items: center; gap: 10px; font-family: var(--font-display); font-weight: 700; font-size: 1.3rem; text-decoration: none; letter-spacing: -.02em; }
      .brand em { font-style: italic; color: var(--primary); }
      .brand-mark { color: var(--primary); display: inline-flex; }
      .nav-links { display: none; margin-left: auto; gap: 26px; }
      .nav-links a { text-decoration: none; font-weight: 600; color: var(--fg); position: relative; padding: 4px 0; }
      .nav-links a::after { content: ""; position: absolute; left: 0; bottom: -2px; height: 2px; width: 0; background: var(--primary); transition: width .2s ease; }
      .nav-links a:hover::after { width: 100%; }
      .nav .btn-sm { display: none; }
      .menu-toggle { margin-left: auto; display: inline-flex; flex-direction: column; gap: 5px; background: none; border: 0; padding: 10px; cursor: pointer; }
      .menu-toggle span { width: 24px; height: 2.5px; background: var(--fg); border-radius: 3px; transition: .25s; }
      .menu-toggle[aria-expanded="true"] span:nth-child(1) { transform: translateY(7.5px) rotate(45deg); }
      .menu-toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
      .menu-toggle[aria-expanded="true"] span:nth-child(3) { transform: translateY(-7.5px) rotate(-45deg); }
      .mobile-menu { display: grid; gap: 4px; padding: 0 4vw; max-height: 0; overflow: hidden; transition: max-height .3s ease, padding .3s ease; background: var(--bg); }
      .mobile-menu.open { max-height: 420px; padding: 10px 4vw 22px; border-bottom: 1px solid var(--border); }
      .mobile-menu a { text-decoration: none; font-weight: 600; padding: 12px 6px; border-radius: 10px; }
      .mobile-menu a:not(.btn):hover { background: #fff; }
      .mobile-menu .btn { margin-top: 8px; }

      /* Hero */
      .hero { position: relative; overflow: hidden; padding: clamp(48px, 8vw, 96px) 0 clamp(40px, 6vw, 72px); }
      .hero-photo { position: absolute; inset: 0; background:
        radial-gradient(900px 500px at 88% -10%, rgba(255,200,87,.28), transparent 60%),
        radial-gradient(700px 500px at 0% 110%, rgba(255,107,92,.16), transparent 55%); pointer-events: none; }
      .hero-grid { position: relative; display: grid; gap: clamp(32px, 5vw, 56px); align-items: center; }
      .hero h1 { font-size: clamp(3rem, 11vw, 6.2rem); font-weight: 700; }
      .hero h1 .hl { color: var(--primary); position: relative; }
      .hero h1 .hl::after { content: ""; position: absolute; left: -2%; right: -2%; bottom: 6%; height: .42em; background: var(--accent); opacity: .5; z-index: -1; border-radius: 8px; transform: rotate(-1.5deg); }
      .eyebrow { margin-bottom: 18px; color: var(--muted); }
      .lede { font-size: clamp(1.05rem, 2.4vw, 1.3rem); color: var(--muted); margin: 22px 0 28px; max-width: 30ch; }
      .hero-actions { display: flex; flex-wrap: wrap; gap: 14px; }
      .hero-stats { list-style: none; display: flex; flex-wrap: wrap; gap: clamp(18px, 4vw, 40px); margin: 38px 0 0; padding: 26px 0 0; border-top: 1px solid var(--border); }
      .hero-stats strong { display: block; font-family: var(--font-display); font-size: clamp(1.8rem, 4vw, 2.6rem); color: var(--fg); font-weight: 700; }
      .hero-stats span { font-size: .82rem; color: var(--muted); font-weight: 600; }

      .hero-art { position: relative; min-height: 380px; display: grid; place-items: center; }
      .hero-card { margin: 0; border-radius: 30px; overflow: hidden; box-shadow: var(--shadow); transform: rotate(2deg); border: 8px solid #fff; position: relative; z-index: 2; max-width: 420px; }
      .hero-card img { width: 100%; height: clamp(360px, 50vw, 520px); object-fit: cover; }
      .blob { position: absolute; border-radius: 50%; filter: blur(2px); z-index: 1; }
      .blob-a { width: 220px; height: 220px; background: var(--accent); top: -20px; right: 0; opacity: .55; animation: float 7s ease-in-out infinite; }
      .blob-b { width: 160px; height: 160px; background: var(--primary); bottom: 0; left: 10px; opacity: .35; animation: float 9s ease-in-out infinite reverse; }
      @keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-18px); } }

      /* Marquee */
      .marquee { background: var(--dark); color: var(--bg); overflow: hidden; padding: 14px 0; }
      .marquee-track { display: inline-flex; align-items: center; gap: 28px; white-space: nowrap; font-family: var(--font-display); font-weight: 600; font-size: 1.3rem; font-style: italic; animation: scroll 22s linear infinite; }
      .marquee-track i { color: var(--accent); font-style: normal; }
      @keyframes scroll { to { transform: translateX(-50%); } }

      /* Sections */
      .section { padding: clamp(56px, 9vw, 110px) 0; }
      .band { background: linear-gradient(180deg, #fff 0%, #FFF1E8 100%); border-block: 1px solid var(--border); }
      .head { max-width: 620px; margin-bottom: clamp(32px, 5vw, 52px); }
      .head h2 { font-size: clamp(2.1rem, 5.4vw, 3.4rem); margin: 14px 0 12px; }
      .head .sub { color: var(--muted); font-size: 1.08rem; }

      /* Programs */
      .program-grid { display: grid; gap: 22px; grid-template-columns: 1fr; }
      .program { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-sm); transition: transform .25s ease, box-shadow .25s ease; }
      .program:hover { transform: translateY(-6px); box-shadow: var(--shadow); }
      .program-img { overflow: hidden; }
      .program-img img { width: 100%; height: 210px; object-fit: cover; transition: transform .5s ease; filter: saturate(1.05); }
      .program:hover .program-img img { transform: scale(1.06); }
      .program-body { padding: 22px 24px 26px; }
      .tag { display: inline-block; background: rgba(255,200,87,.28); color: #8a5a00; font-weight: 700; font-size: .74rem; padding: 5px 12px; border-radius: 999px; letter-spacing: .04em; }
      .program-body h3 { font-size: 1.5rem; margin: 12px 0 8px; }
      .program-body p { color: var(--muted); }

      /* Pricing */
      .price-grid { display: grid; gap: 22px; grid-template-columns: 1fr; align-items: stretch; }
      .price { position: relative; background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 32px 28px; display: flex; flex-direction: column; box-shadow: var(--shadow-sm); }
      .price-featured { border: 2px solid var(--primary); box-shadow: 0 24px 60px -28px rgba(255,107,92,.55); }
      .ribbon { position: absolute; top: -13px; left: 28px; background: var(--primary); color: #fff; font-weight: 700; font-size: .72rem; letter-spacing: .08em; text-transform: uppercase; padding: 6px 14px; border-radius: 999px; }
      .price h3 { font-size: 1.4rem; margin-bottom: 10px; }
      .amount { display: flex; align-items: baseline; gap: 8px; margin-bottom: 20px; }
      .amount strong { font-family: var(--font-display); font-size: 2.6rem; font-weight: 700; }
      .amount span { color: var(--muted); font-weight: 600; }
      .price ul { list-style: none; margin: 0 0 26px; padding: 0; display: grid; gap: 11px; flex: 1; }
      .price li { padding-left: 28px; position: relative; color: var(--fg); }
      .price li::before { content: ""; position: absolute; left: 0; top: 4px; width: 18px; height: 18px; border-radius: 50%; background: rgba(255,107,92,.16); }
      .price li::after { content: ""; position: absolute; left: 5px; top: 9px; width: 7px; height: 4px; border-left: 2px solid var(--primary); border-bottom: 2px solid var(--primary); transform: rotate(-45deg); }
      .price-note { text-align: center; color: var(--muted); margin-top: 28px; font-size: .95rem; }

      /* Coaches */
      .coach-grid { display: grid; gap: 22px; grid-template-columns: 1fr; }
      .coach { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow-sm); transition: transform .25s ease; }
      .coach:hover { transform: translateY(-6px); }
      .coach-img { aspect-ratio: 4/4.4; overflow: hidden; }
      .coach-img img { width: 100%; height: 100%; object-fit: cover; }
      .coach-meta { padding: 20px 22px 24px; }
      .coach-meta .role { color: var(--primary); font-weight: 700; font-size: .8rem; letter-spacing: .06em; text-transform: uppercase; }
      .coach-meta h3 { font-size: 1.45rem; margin: 6px 0 4px; }
      .coach-meta p { color: var(--muted); font-size: .94rem; }

      /* Slider */
      .slider { max-width: 760px; }
      .slides { position: relative; min-height: 200px; }
      .slide { margin: 0; position: absolute; inset: 0; opacity: 0; transform: translateY(14px); transition: opacity .5s ease, transform .5s ease; pointer-events: none; }
      .slide[aria-hidden="false"] { opacity: 1; transform: none; pointer-events: auto; position: relative; }
      .slide blockquote { font-family: var(--font-display); font-size: clamp(1.4rem, 3.6vw, 2.15rem); font-weight: 500; line-height: 1.25; margin: 0; }
      .slide figcaption { margin-top: 18px; font-weight: 700; color: var(--primary); }
      .dots { display: flex; gap: 10px; margin-top: 30px; }
      .dot { width: 13px; height: 13px; border-radius: 50%; border: 0; background: var(--border); cursor: pointer; padding: 0; transition: background .2s, transform .2s; }
      .dot.active { background: var(--primary); transform: scale(1.2); }

      /* Schedule */
      .schedule { border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; background: var(--card); box-shadow: var(--shadow-sm); }
      .sched-row { display: grid; grid-template-columns: 72px 1fr; gap: 12px; padding: 16px 18px; align-items: center; }
      .sched-row + .sched-row { border-top: 1px solid var(--border); }
      .sched-day { font-family: var(--font-display); font-weight: 700; font-size: 1.15rem; color: var(--primary); }
      .sched-slots { display: flex; flex-wrap: wrap; gap: 10px; }
      .slot { display: inline-flex; align-items: center; gap: 10px; background: #FFF8F2; border: 1px solid var(--border); border-radius: 999px; padding: 8px 8px 8px 16px; text-decoration: none; font-weight: 600; font-size: .9rem; min-height: 44px; transition: border-color .2s, background .2s; }
      .slot em { font-style: normal; font-size: .74rem; font-weight: 700; background: var(--primary); color: #fff; padding: 5px 11px; border-radius: 999px; }
      .slot:hover { border-color: var(--primary); background: #fff; }

      /* CTA */
      .cta { background: var(--dark); color: var(--bg); padding: clamp(60px, 9vw, 110px) 0; position: relative; overflow: hidden; }
      .cta::before { content: ""; position: absolute; inset: 0; background: radial-gradient(600px 400px at 12% 0%, rgba(255,107,92,.28), transparent 60%), radial-gradient(500px 400px at 100% 100%, rgba(255,200,87,.22), transparent 55%); }
      .cta-inner { position: relative; text-align: center; max-width: 720px; margin-inline: auto; }
      .cta h2 { font-size: clamp(2.1rem, 6vw, 3.6rem); margin: 16px 0 16px; }
      .cta p { color: rgba(255,248,242,.78); font-size: 1.1rem; max-width: 46ch; margin: 0 auto 30px; }
      .cta-actions { display: flex; flex-wrap: wrap; gap: 14px; justify-content: center; }

      /* Visit */
      .visit-grid { display: grid; gap: 34px; grid-template-columns: 1fr; align-items: center; }
      .visit-grid h2 { font-size: clamp(2rem, 5vw, 3rem); margin: 12px 0 18px; }
      .addr { font-size: 1.15rem; font-weight: 600; }
      address { font-style: normal; margin-bottom: 22px; }
      .callline { font-family: var(--font-display); font-size: 1.5rem; font-weight: 600; color: var(--primary); text-decoration: none; }
      .hours { border-collapse: collapse; width: 100%; max-width: 380px; margin: 0 0 24px; }
      .hours th { text-align: left; font-weight: 700; padding: 11px 0; }
      .hours td { text-align: right; color: var(--muted); padding: 11px 0; }
      .hours tr + tr th, .hours tr + tr td { border-top: 1px solid var(--border); }
      .map { margin: 0; border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow); position: relative; border: 8px solid #fff; }
      .map img { width: 100%; height: clamp(280px, 40vw, 420px); object-fit: cover; filter: saturate(.95); }
      .map figcaption { position: absolute; bottom: 14px; left: 14px; background: #fff; padding: 8px 14px; border-radius: 999px; font-weight: 700; font-size: .85rem; box-shadow: var(--shadow-sm); }

      /* Footer */
      .footer { background: #fff; border-top: 1px solid var(--border); padding: 48px 0 100px; }
      .footer-inner { display: grid; gap: 18px; }
      .brand-foot { font-size: 1.3rem; }
      .tagline { color: var(--muted); max-width: 40ch; }
      .foot-links { display: flex; flex-wrap: wrap; gap: 20px; }
      .foot-links a { text-decoration: none; font-weight: 600; color: var(--fg); }
      .foot-links a:hover { color: var(--primary); }
      .copyright { margin-top: 26px; padding-top: 22px; border-top: 1px solid var(--border); color: var(--muted); font-size: .85rem; }

      /* Sticky book bar (mobile) */
      .bookbar { position: fixed; left: 12px; right: 12px; bottom: 12px; z-index: 90; display: flex; gap: 10px; background: rgba(42,35,32,.96); backdrop-filter: blur(8px); border-radius: 999px; padding: 8px; box-shadow: 0 16px 40px -16px rgba(42,35,32,.6); }
      .bookbar a { text-decoration: none; font-weight: 700; border-radius: 999px; display: inline-flex; align-items: center; justify-content: center; min-height: 46px; }
      .bookbar-call { flex: 0 0 92px; color: #fff; border: 2px solid rgba(255,255,255,.35); }
      .bookbar-book { flex: 1; background: var(--primary); color: #fff; }

      /* Reveal */
      .reveal { opacity: 0; transform: translateY(26px); transition: opacity .7s ease, transform .7s ease; }
      .reveal.in { opacity: 1; transform: none; }

      /* Responsive */
      @media (min-width: 640px) {
        .program-grid, .coach-grid { grid-template-columns: repeat(2, 1fr); }
      }
      @media (min-width: 880px) {
        .nav-links { display: flex; }
        .nav .btn-sm { display: inline-flex; }
        .menu-toggle { display: none; }
        .hero-grid { grid-template-columns: 1.05fr .95fr; }
        .program-grid { grid-template-columns: repeat(2, 1fr); }
        .coach-grid { grid-template-columns: repeat(3, 1fr); }
        .price-grid { grid-template-columns: repeat(3, 1fr); }
        .visit-grid { grid-template-columns: 1fr 1fr; }
        .footer-inner { grid-template-columns: 1fr auto; align-items: center; }
        .tagline { grid-column: 1; }
        .bookbar { display: none; }
      }
      @media (min-width: 1080px) {
        .program-grid { grid-template-columns: repeat(4, 1fr); }
      }
    </style>

    <script>
      // Mobile menu
      const toggle = document.querySelector(".menu-toggle");
      const menu = document.querySelector(".mobile-menu");
      toggle?.addEventListener("click", () => {
        const open = menu.classList.toggle("open");
        toggle.setAttribute("aria-expanded", String(open));
      });
      menu?.querySelectorAll("a").forEach((a) =>
        a.addEventListener("click", () => { menu.classList.remove("open"); toggle.setAttribute("aria-expanded", "false"); })
      );

      // Scroll reveal
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const reveals = document.querySelectorAll(".reveal");
      if (reduce) { reveals.forEach((r) => r.classList.add("in")); }
      else {
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add("in"); io.unobserve(e.target); } });
        }, { threshold: 0.12 });
        reveals.forEach((r) => io.observe(r));
      }

      // Animated stat counters
      const counters = document.querySelectorAll("[data-count]");
      const countObs = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (!e.isIntersecting) return;
          const el = e.target;
          const target = parseInt(el.getAttribute("data-count"), 10);
          if (reduce) { el.textContent = target.toLocaleString() + "+"; countObs.unobserve(el); return; }
          const dur = 1400, start = performance.now();
          const step = (now) => {
            const p = Math.min((now - start) / dur, 1);
            const eased = 1 - Math.pow(1 - p, 3);
            el.textContent = Math.round(target * eased).toLocaleString() + (p === 1 ? "+" : "");
            if (p < 1) requestAnimationFrame(step);
          };
          requestAnimationFrame(step);
          countObs.unobserve(el);
        });
      }, { threshold: 0.5 });
      counters.forEach((c) => countObs.observe(c));

      // Testimonial slider
      const slider = document.querySelector("[data-slider]");
      if (slider) {
        const slides = [...slider.querySelectorAll("[data-slide]")];
        const dots = [...slider.querySelectorAll("[data-dot]")];
        let idx = 0, timer;
        const show = (n) => {
          idx = (n + slides.length) % slides.length;
          slides.forEach((s, i) => s.setAttribute("aria-hidden", String(i !== idx)));
          dots.forEach((d, i) => d.classList.toggle("active", i === idx));
        };
        const auto = () => { if (reduce) return; timer = setInterval(() => show(idx + 1), 5000); };
        dots.forEach((d, i) => d.addEventListener("click", () => { clearInterval(timer); show(i); auto(); }));
        auto();
      }
    </script>
  </body>
</html>
