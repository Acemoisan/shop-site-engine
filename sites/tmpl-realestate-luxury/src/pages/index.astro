      .card-body { padding: 1.5rem 1.6rem 1.8rem; }
      .card-price { font-family: var(--serif); font-size: 1.7rem; color: var(--primary); }
      .card-addr { font-size: 1.4rem; margin-top: 0.2rem; }
      .card-area { font-size: 0.72rem; letter-spacing: 0.22em; text-transform: uppercase; color: rgba(239,233,221,0.55); margin-top: 0.5rem; }
      .card-meta { display: flex; gap: 1.2rem; list-style: none; margin-top: 1.1rem; padding-top: 1.1rem; border-top: 1px solid var(--border); }
      .card-meta li { font-size: 0.82rem; letter-spacing: 0.06em; color: rgba(239,233,221,0.8); }

      /* Valuation */
      .valuation { position: relative; padding: clamp(5rem, 10vw, 8rem) 0; overflow: hidden; }
      .val-img {
        position: absolute; inset: 0;
        background: url("https://picsum.photos/seed/valuationbg/1600/900") center/cover no-repeat;
        filter: grayscale(0.5) brightness(0.4); transform: scale(1.05);
      }
      .valuation::after {
        content: ""; position: absolute; inset: 0;
        background: linear-gradient(105deg, rgba(14,13,11,0.94), rgba(14,13,11,0.6));
      }
      .val-inner { position: relative; z-index: 2; display: grid; gap: 2.2rem; align-items: center; }
      @media (min-width: 900px) { .val-inner { grid-template-columns: 1.2fr 1fr; gap: 4rem; } }
      .val-inner h2 { font-size: clamp(2rem, 5vw, 3.4rem); }
      .val-form { display: flex; flex-direction: column; gap: 0.9rem; }
      @media (min-width: 520px) { .val-form { flex-direction: row; } }
      .val-form input {
        flex: 1; min-height: 52px; padding: 0 1.2rem;
        background: rgba(28,26,22,0.7); border: 1px solid var(--border); color: var(--fg);
        font-family: var(--sans); font-size: 0.95rem;
      }
      .val-form input::placeholder { color: rgba(239,233,221,0.45); }

      /* Numbers */
      .numbers { background: var(--muted); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
      .grid-stats { display: grid; grid-template-columns: repeat(2, 1fr); gap: 2rem 1rem; }
      @media (min-width: 820px) { .grid-stats { grid-template-columns: repeat(4, 1fr); } }
      .stat { text-align: center; padding: 1rem 0.5rem; border-top: 1px solid var(--border); }
      .stat-val { font-family: var(--serif); font-size: clamp(2.6rem, 7vw, 4.2rem); color: var(--primary); line-height: 1; }
      .stat-label { font-size: 0.74rem; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(239,233,221,0.65); margin-top: 0.8rem; }
      .press { margin-top: clamp(2.5rem, 5vw, 4rem); padding-top: 2.4rem; border-top: 1px solid var(--border); text-align: center; }
      .press-lead { font-size: 0.68rem; letter-spacing: 0.32em; text-transform: uppercase; color: rgba(239,233,221,0.45); }
      .press-row { display: flex; flex-wrap: wrap; justify-content: center; gap: 1.4rem 2.6rem; margin-top: 1.4rem; }
      .press-logo {
        font-family: var(--serif); font-size: clamp(0.85rem, 2vw, 1.15rem);
        letter-spacing: 0.12em; color: rgba(239,233,221,0.5);
        transition: color 0.3s;
      }
      .press-logo:hover { color: var(--primary); }

      /* Split */
      .split { display: grid; gap: clamp(2.5rem, 5vw, 4.5rem); align-items: center; }
      @media (min-width: 900px) { .split { grid-template-columns: 1fr 1fr; } }
      .split-media { position: relative; }
      .split-media img { width: 100%; aspect-ratio: 4 / 5; object-fit: cover; filter: saturate(0.85) brightness(0.95); }
      .split-badge {
        position: absolute; bottom: -1.4rem; right: -0.4rem; background: var(--bg);
