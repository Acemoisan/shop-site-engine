---
// Meridian & Vale | Private Brokerage — luxury real estate template (self-contained)
const nav = [
  { label: "Listings", href: "#listings" },
  { label: "Track Record", href: "#numbers" },
  { label: "Our Story", href: "#story" },
  { label: "Neighborhoods", href: "#areas" },
  { label: "Contact", href: "#contact" },
];

const listings = [
  { seed: "roxboro88", addr: "88 Roxboro Road SW", price: "$3,495,000", bd: 5, ba: 6, sqft: "6,200", area: "Roxboro", tag: "New" },
  { seed: "eagleridge412", addr: "412 Eagle Ridge Drive SW", price: "$2,150,000", bd: 4, ba: 4, sqft: "4,050", area: "Eagle Ridge", tag: "Featured" },
  { seed: "mountpleasant207", addr: "207 18th Avenue NW", price: "$899,000", bd: 3, ba: 3, sqft: "2,100", area: "Mount Pleasant", tag: "" },
];

const services = [
  { name: "Luxury Listing & Marketing", price: "2.5%", note: "Cinematic video, drone, staging consult included" },
  { name: "Standard Residential Listing", price: "2.0%", note: "Full representation, professional photography" },
  { name: "Buyer Representation", price: "No cost", note: "Commission paid by seller" },
  { name: "Professional Home Valuation (CMA)", price: "Complimentary", note: "Data-driven, no obligation" },
  { name: "Premium Staging Consultation", price: "$350", note: "Credited back on a signed listing" },
  { name: "Architectural Photography & 3D Tour", price: "$1,200", note: "Per property, white-glove production" },
];

const stats = [
  { value: 480, prefix: "$", suffix: "M+", label: "Lifetime sales volume" },
  { value: 640, prefix: "", suffix: "+", label: "Homes sold" },
  { value: 19, prefix: "", suffix: "", label: "Avg. days on market" },
  { value: 99.2, prefix: "", suffix: "%", label: "List-to-sale ratio" },
];

const press = ["THE WALL STREET JOURNAL", "FORBES", "ARCHITECTURAL DIGEST", "AVENUE", "WESTERN LIVING"];

const testimonials = [
  { quote: "Eleanor sold our Mount Royal home in eleven days, over asking. Every detail was handled before we even thought to ask.", who: "Daniel & Priya R.", ctx: "Mount Royal" },
  { quote: "The marketing was on another level — the video alone made buyers fall in love. Truly white-glove from start to close.", who: "Marguerite L.", ctx: "Britannia" },
  { quote: "As first-time buyers we felt completely guided, never pressured. We found exactly the right home in Inglewood.", who: "James & Cora T.", ctx: "Inglewood" },
];

const areas = [
  { name: "Mount Royal", seed: "mtroyal", note: "Heritage estates, mature canopy" },
  { name: "Roxboro", seed: "roxboroarea", note: "Riverside privacy, walk to Mission" },
  { name: "Britannia", seed: "britannia", note: "Mid-century modern, elevated views" },
  { name: "Inglewood", seed: "inglewood", note: "Historic main street, creative pulse" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Meridian &amp; Vale | Private Brokerage — Luxury Real Estate in Calgary</title>
    <meta name="description" content="Meridian & Vale is a private luxury brokerage serving Calgary's finest neighborhoods. Live exceptionally — a different standard of service from listing to close." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <a class="skip" href="#listings">Skip to listings</a>

    <header class="nav" id="top">
      <div class="wrap nav-inner">
        <a class="brand" href="#top" aria-label="Meridian and Vale home">
          <span class="brand-mark" aria-hidden="true">M&amp;V</span>
          <span class="brand-name">Meridian <em>&amp;</em> Vale</span>
        </a>
        <nav class="nav-links" aria-label="Primary">
          {nav.map((n) => <a href={n.href}>{n.label}</a>)}
        </nav>
        <a class="btn btn-sm" href="#contact">Book a Consultation</a>
        <button class="hamburger" aria-label="Toggle menu" aria-expanded="false" id="navToggle">
          <span></span><span></span><span></span>
        </button>
      </div>
      <nav class="mobile-menu" id="mobileMenu" aria-label="Mobile">
        {nav.map((n) => <a href={n.href}>{n.label}</a>)}
        <a class="btn" href="#contact">Book a Consultation</a>
      </nav>
    </header>

    <!-- HERO -->
    <section class="hero" aria-label="Introduction">
      <div class="hero-img" aria-hidden="true"></div>
      <div class="hero-grad" aria-hidden="true"></div>
      <div class="wrap hero-content">
        <p class="eyebrow reveal">Private Brokerage · Calgary, Alberta</p>
        <h1 class="reveal">Live<br /><span class="ital">exceptionally.</span></h1>
        <p class="lede reveal">A different standard of service across Calgary's finest neighborhoods — from quiet first showings to the final signature.</p>
        <div class="hero-cta reveal">
          <a class="btn" href="#listings">View Listings</a>
          <a class="btn btn-ghost" href="#contact">Book a Consultation</a>
        </div>
      </div>
      <div class="hero-scroll" aria-hidden="true"><span>Scroll</span></div>
    </section>

    <!-- LISTINGS -->
    <section class="section" id="listings" aria-labelledby="listings-h">
      <div class="wrap">
        <div class="sec-head reveal">
          <p class="eyebrow">Curated Portfolio</p>
          <h2 id="listings-h">Featured residences</h2>
          <p class="sec-sub">A selection from our private collection. Each home is represented with cinematic video, architectural photography, and discreet, personal handling.</p>
        </div>
        <div class="grid-listings">
          {listings.map((l) => (
            <article class="card reveal">
              <a class="card-media" href="#contact" aria-label={`View ${l.addr}`}>
                <img loading="lazy" src={`https://picsum.photos/seed/${l.seed}/900/600`} alt={`Exterior of ${l.addr} in ${l.area}`} width="900" height="600" />
                {l.tag && <span class="card-tag">{l.tag}</span>}
              </a>
              <div class="card-body">
                <p class="card-price">{l.price}</p>
                <h3 class="card-addr">{l.addr}</h3>
                <p class="card-area">{l.area}</p>
                <ul class="card-meta">
                  <li>{l.bd} bd</li><li>{l.ba} ba</li><li>{l.sqft} sqft</li>
                </ul>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- VALUATION BAND -->
    <section class="valuation" aria-labelledby="val-h">
      <div class="val-img" aria-hidden="true"></div>
      <div class="wrap val-inner reveal">
        <div>
          <p class="eyebrow gold">Sellers</p>
          <h2 id="val-h">What is your home worth?</h2>
          <p class="sec-sub">A complimentary, data-driven valuation from a brokerage that knows Calgary's high-end market intimately. No obligation, complete discretion.</p>
        </div>
        <form class="val-form" onsubmit="return false" aria-label="Request a home valuation">
          <label class="vis-hidden" for="val-addr">Your address</label>
          <input id="val-addr" type="text" placeholder="Enter your address" autocomplete="street-address" />
          <button class="btn" type="submit">Get My Estimate</button>
        </form>
      </div>
    </section>

    <!-- BY THE NUMBERS -->
    <section class="section numbers" id="numbers" aria-labelledby="num-h">
      <div class="wrap">
        <div class="sec-head reveal">
          <p class="eyebrow gold">By the Numbers</p>
          <h2 id="num-h">A measurable difference</h2>
        </div>
        <div class="grid-stats">
          {stats.map((s) => (
            <div class="stat reveal">
              <p class="stat-val" data-target={s.value} data-prefix={s.prefix} data-suffix={s.suffix}>{s.prefix}0{s.suffix}</p>
              <p class="stat-label">{s.label}</p>
            </div>
          ))}
        </div>
        <div class="press reveal" aria-label="As seen in">
          <span class="press-lead">As seen in</span>
          <div class="press-row">
            {press.map((p) => <span class="press-logo">{p}</span>)}
          </div>
        </div>
      </div>
    </section>

    <!-- STORY (split editorial) -->
    <section class="section story" id="story" aria-labelledby="story-h">
      <div class="wrap split">
        <div class="split-media reveal">
          <img loading="lazy" src="https://picsum.photos/seed/eleanorvale/800/1000" alt="Eleanor Vale, founding broker, in a light-filled Calgary residence" width="800" height="1000" />
          <div class="split-badge"><strong>19</strong><span>years guiding<br />Calgary buyers &amp; sellers</span></div>
        </div>
        <div class="split-copy reveal">
          <p class="eyebrow gold">Our Story</p>
          <h2 id="story-h">A boutique brokerage, built on trust.</h2>
          <p>Meridian &amp; Vale was founded on a simple conviction: that the most significant transaction of a person's life deserves more than a sign on a lawn. We work with a deliberately small roster of clients, allowing every listing the attention, marketing, and discretion it warrants.</p>
          <p>Founder Eleanor Vale has spent nearly two decades representing Calgary's most distinctive homes — heritage estates in Mount Royal, riverside properties in Roxboro, and architectural statements across Britannia and Eagle Ridge. The result is a practice defined by restraint, craft, and results.</p>
          <a class="btn btn-ghost dark" href="#contact">Meet with Eleanor</a>
        </div>
      </div>
    </section>

    <!-- SERVICES / PRICING -->
    <section class="section services" aria-labelledby="svc-h">
      <div class="wrap">
        <div class="sec-head reveal">
          <p class="eyebrow gold">Engagements</p>
          <h2 id="svc-h">Services &amp; transparent pricing</h2>
        </div>
        <ul class="svc-list">
          {services.map((s) => (
            <li class="svc-row reveal">
              <div class="svc-text">
                <h3>{s.name}</h3>
                <p>{s.note}</p>
              </div>
              <span class="svc-price">{s.price}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- TESTIMONIAL SLIDER -->
    <section class="section quotes" aria-labelledby="q-h">
      <div class="wrap">
        <div class="sec-head reveal">
          <p class="eyebrow gold">Clients</p>
          <h2 id="q-h">Spoken from the doorstep</h2>
        </div>
        <div class="slider reveal" id="slider">
          <div class="slides" id="slides">
            {testimonials.map((t) => (
              <figure class="quote">
                <blockquote>&ldquo;{t.quote}&rdquo;</blockquote>
                <figcaption><strong>{t.who}</strong><span>{t.ctx}</span></figcaption>
              </figure>
            ))}
          </div>
          <div class="dots" id="dots" role="tablist" aria-label="Testimonials">
            {testimonials.map((_, i) => (
              <button class={i === 0 ? "dot active" : "dot"} data-i={i} aria-label={`Testimonial ${i + 1}`}></button>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- NEIGHBORHOODS -->
    <section class="section" id="areas" aria-labelledby="areas-h">
      <div class="wrap">
        <div class="sec-head reveal">
          <p class="eyebrow gold">Local Authority</p>
          <h2 id="areas-h">Neighborhoods we know by name</h2>
        </div>
        <div class="grid-areas">
          {areas.map((a) => (
            <a class="area reveal" href="#contact">
              <img loading="lazy" src={`https://picsum.photos/seed/${a.seed}/600/700?grayscale`} alt={`Streetscape of ${a.name}, Calgary`} width="600" height="700" />
              <span class="area-overlay"></span>
              <span class="area-text">
                <strong>{a.name}</strong>
                <em>{a.note}</em>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- CONTACT / CTA -->
    <section class="section contact" id="contact" aria-labelledby="contact-h">
      <div class="wrap split">
        <div class="reveal">
          <p class="eyebrow gold">Begin</p>
          <h2 id="contact-h">A conversation, in confidence.</h2>
          <p class="sec-sub">Whether you are buying, selling, or simply curious about value, we welcome a private consultation — evenings available by request.</p>
          <ul class="nap">
            <li><span>Visit</span><a href="https://maps.google.com/?q=1100+1st+Street+SW+Suite+400+Calgary+AB+T2R+0V1" target="_blank" rel="noopener">1100 1st Street SW, Suite 400<br />Calgary, AB T2R 0V1</a></li>
            <li><span>Call</span><a href="tel:+14035550192">(403) 555-0192</a></li>
            <li><span>Email</span><a href="mailto:hello@meridianvale.ca">hello@meridianvale.ca</a></li>
          </ul>
          <table class="hours" aria-label="Office hours">
            <tbody>
              <tr><th scope="row">Mon – Fri</th><td>9:00 AM – 6:00 PM</td></tr>
              <tr><th scope="row">Saturday</th><td>10:00 AM – 4:00 PM</td></tr>
              <tr><th scope="row">Sunday</th><td>By appointment</td></tr>
            </tbody>
          </table>
        </div>
        <form class="contact-form reveal" onsubmit="return false" aria-label="Request a consultation">
          <label for="c-name">Name</label>
          <input id="c-name" type="text" autocomplete="name" required />
          <label for="c-phone">Phone</label>
          <input id="c-phone" type="tel" autocomplete="tel" />
          <label for="c-msg">How can we help?</label>
          <textarea id="c-msg" rows="4"></textarea>
          <button class="btn" type="submit">Request Consultation</button>
          <a class="call-cta" href="tel:+14035550192">or call (403) 555-0192</a>
        </form>
      </div>
    </section>

    <footer class="footer">
      <div class="wrap foot-inner">
        <div class="foot-brand">
          <span class="brand-mark" aria-hidden="true">M&amp;V</span>
          <p>Meridian &amp; Vale Private Brokerage</p>
          <p class="foot-note">Live exceptionally.</p>
        </div>
        <nav class="foot-nav" aria-label="Footer">
          {nav.map((n) => <a href={n.href}>{n.label}</a>)}
        </nav>
        <p class="foot-legal">1100 1st Street SW, Suite 400, Calgary, AB · (403) 555-0192<br />© 2026 Meridian &amp; Vale. All rights reserved.</p>
      </div>
    </footer>

    <script>
      // Mobile nav
      const t = document.getElementById("navToggle");
      const m = document.getElementById("mobileMenu");
      t?.addEventListener("click", () => {
        const open = m.classList.toggle("open");
        t.setAttribute("aria-expanded", String(open));
      });
      m?.querySelectorAll("a").forEach((a) =>
        a.addEventListener("click", () => {
          m.classList.remove("open");
          t?.setAttribute("aria-expanded", "false");
        })
      );

      // Sticky nav shadow
      const header = document.querySelector(".nav");
      const onScroll = () => header?.classList.toggle("scrolled", window.scrollY > 40);
      onScroll();
      window.addEventListener("scroll", onScroll, { passive: true });

      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      // Scroll reveal
      const els = document.querySelectorAll(".reveal");
      if (reduce || !("IntersectionObserver" in window)) {
        els.forEach((e) => e.classList.add("in"));
      } else {
        const io = new IntersectionObserver(
          (entries) => entries.forEach((en) => {
            if (en.isIntersecting) { en.target.classList.add("in"); io.unobserve(en.target); }
          }),
          { threshold: 0.15 }
        );
        els.forEach((e) => io.observe(e));
      }

      // Animated counters
      const counters = document.querySelectorAll(".stat-val");
      const animate = (el) => {
        const target = parseFloat(el.dataset.target);
        const prefix = el.dataset.prefix || "";
        const suffix = el.dataset.suffix || "";
        const decimals = (el.dataset.target.split(".")[1] || "").length;
        if (reduce) { el.textContent = prefix + target.toFixed(decimals) + suffix; return; }
        let start = null;
        const dur = 1400;
        const step = (ts) => {
          if (!start) start = ts;
          const p = Math.min((ts - start) / dur, 1);
          const eased = 1 - Math.pow(1 - p, 3);
          el.textContent = prefix + (target * eased).toFixed(decimals) + suffix;
          if (p < 1) requestAnimationFrame(step);
        };
        requestAnimationFrame(step);
      };
      if ("IntersectionObserver" in window) {
        const cio = new IntersectionObserver(
          (entries) => entries.forEach((en) => {
            if (en.isIntersecting) { animate(en.target); cio.unobserve(en.target); }
          }),
          { threshold: 0.6 }
        );
        counters.forEach((c) => cio.observe(c));
      } else counters.forEach(animate);

      // Testimonial slider
      const slides = document.getElementById("slides");
      const dots = Array.from(document.querySelectorAll(".dot"));
      let idx = 0;
      const go = (i) => {
        idx = (i + dots.length) % dots.length;
        slides.style.transform = `translateX(-${idx * 100}%)`;
        dots.forEach((d, di) => d.classList.toggle("active", di === idx));
      };
      dots.forEach((d) => d.addEventListener("click", () => go(parseInt(d.dataset.i))));
      if (!reduce && dots.length > 1) setInterval(() => go(idx + 1), 6000);
    </script>

    <style>
      :root {
        --bg: #0E0D0B;
        --fg: #EFE9DD;
        --primary: #C2A66A;
        --primary-fg: #0E0D0B;
        --accent: #8C7848;
        --muted: #1C1A16;
        --border: #34302A;
        --serif: "Cormorant Garamond", Georgia, serif;
        --sans: "Jost", system-ui, sans-serif;
        --max: 1240px;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      @media (prefers-reduced-motion: reduce) { html { scroll-behavior: auto; } }
      body {
        background: var(--bg);
        color: var(--fg);
        font-family: var(--sans);
        font-weight: 300;
        line-height: 1.7;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }
      img { display: block; max-width: 100%; }
      a { color: inherit; text-decoration: none; }
      h1, h2, h3 { font-family: var(--serif); font-weight: 500; line-height: 1.05; letter-spacing: 0.01em; }
      .ital { font-style: italic; font-weight: 400; color: var(--primary); }
      .wrap { width: 100%; max-width: var(--max); margin: 0 auto; padding: 0 clamp(1.25rem, 4vw, 3rem); }
      .eyebrow {
        font-size: 0.72rem; letter-spacing: 0.34em; text-transform: uppercase;
        color: var(--primary); font-weight: 400; margin-bottom: 1.1rem;
      }
      .eyebrow.gold { color: var(--primary); }
      .skip {
        position: absolute; left: -999px; top: 0; background: var(--primary);
        color: var(--primary-fg); padding: 0.6rem 1rem; z-index: 200;
      }
      .skip:focus { left: 0; }
      .vis-hidden { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0); }

      /* Buttons */
      .btn {
        display: inline-flex; align-items: center; justify-content: center;
        min-height: 48px; padding: 0 1.7rem;
        background: var(--primary); color: var(--primary-fg);
        font-family: var(--sans); font-size: 0.78rem; letter-spacing: 0.2em;
        text-transform: uppercase; font-weight: 500;
        border: 1px solid var(--primary); cursor: pointer;
        transition: background 0.3s ease, color 0.3s ease, transform 0.3s ease;
      }
      .btn:hover { background: transparent; color: var(--primary); transform: translateY(-2px); }
      .btn-ghost { background: transparent; color: var(--fg); border-color: var(--border); }
      .btn-ghost:hover { border-color: var(--primary); color: var(--primary); background: transparent; }
      .btn-ghost.dark { margin-top: 1.6rem; }
      .btn-sm { min-height: 44px; padding: 0 1.3rem; font-size: 0.7rem; }
      a:focus-visible, button:focus-visible, input:focus-visible, textarea:focus-visible {
        outline: 2px solid var(--primary); outline-offset: 3px;
      }

      /* Nav */
      .nav {
        position: fixed; top: 0; left: 0; right: 0; z-index: 100;
        transition: background 0.4s ease, border-color 0.4s ease, padding 0.4s ease;
        border-bottom: 1px solid transparent; padding: 0.4rem 0;
      }
      .nav.scrolled {
        background: rgba(14, 13, 11, 0.86);
        backdrop-filter: blur(14px);
        border-bottom-color: var(--border);
      }
      .nav-inner { display: flex; align-items: center; justify-content: space-between; min-height: 72px; gap: 1rem; }
      .brand { display: flex; align-items: center; gap: 0.7rem; }
      .brand-mark {
        display: grid; place-items: center; width: 40px; height: 40px;
        border: 1px solid var(--primary); color: var(--primary);
        font-family: var(--serif); font-size: 0.85rem; letter-spacing: 0.02em;
      }
      .brand-name { font-family: var(--serif); font-size: 1.35rem; letter-spacing: 0.02em; }
      .brand-name em { color: var(--primary); font-style: italic; }
      .nav-links { display: none; gap: 2rem; }
      .nav-links a {
        font-size: 0.74rem; letter-spacing: 0.18em; text-transform: uppercase;
        color: var(--fg); opacity: 0.82; transition: opacity 0.25s, color 0.25s; position: relative;
      }
      .nav-links a:hover { opacity: 1; color: var(--primary); }
      .nav .btn-sm { display: none; }
      .hamburger {
        display: flex; flex-direction: column; gap: 5px; background: none; border: none;
        cursor: pointer; padding: 12px; min-width: 44px; min-height: 44px; justify-content: center;
      }
      .hamburger span { width: 24px; height: 1.5px; background: var(--fg); transition: 0.3s; }
      .mobile-menu {
        display: none; flex-direction: column; gap: 0.3rem;
        background: rgba(14,13,11,0.97); border-top: 1px solid var(--border);
        padding: 1rem clamp(1.25rem, 4vw, 3rem) 1.6rem;
      }
      .mobile-menu.open { display: flex; }
      .mobile-menu a { padding: 0.8rem 0; letter-spacing: 0.16em; text-transform: uppercase; font-size: 0.82rem; min-height: 44px; display: flex; align-items: center; }
      .mobile-menu .btn { margin-top: 0.6rem; }
      @media (min-width: 940px) {
        .nav-links { display: flex; }
        .nav .btn-sm { display: inline-flex; }
        .hamburger { display: none; }
      }

      /* Hero */
      .hero { position: relative; min-height: 100svh; display: flex; align-items: flex-end; overflow: hidden; }
      .hero-img {
        position: absolute; inset: 0;
        background: url("https://picsum.photos/seed/meridianhero/1920/1200") center/cover no-repeat;
        filter: saturate(0.78) brightness(0.72) contrast(1.04);
        transform: scale(1.08); animation: ken 24s ease-in-out infinite alternate;
      }
      @keyframes ken { from { transform: scale(1.08) translate(0, 0); } to { transform: scale(1.18) translate(-2%, -2%); } }
      @media (prefers-reduced-motion: reduce) { .hero-img { animation: none; transform: scale(1.05); } }
      .hero-grad {
        position: absolute; inset: 0;
        background:
          linear-gradient(to top, rgba(14,13,11,0.96) 4%, rgba(14,13,11,0.45) 42%, rgba(14,13,11,0.2) 70%),
          radial-gradient(120% 80% at 80% 10%, rgba(194,166,106,0.12), transparent 55%);
      }
      .hero-content { position: relative; z-index: 2; padding-bottom: clamp(4rem, 9vw, 7rem); padding-top: 8rem; }
      .hero h1 { font-size: clamp(3.6rem, 13vw, 9rem); line-height: 0.92; letter-spacing: -0.01em; }
      .hero .lede { max-width: 36ch; margin: 1.8rem 0 2.2rem; font-size: clamp(1rem, 2.2vw, 1.25rem); color: rgba(239,233,221,0.82); }
      .hero-cta { display: flex; flex-wrap: wrap; gap: 0.9rem; }
      .hero-scroll {
        position: absolute; bottom: 1.6rem; left: 50%; transform: translateX(-50%); z-index: 2;
        font-size: 0.62rem; letter-spacing: 0.34em; text-transform: uppercase; color: rgba(239,233,221,0.6);
      }
      .hero-scroll span::after { content: ""; display: block; width: 1px; height: 32px; background: var(--primary); margin: 0.7rem auto 0; opacity: 0.7; }

      /* Sections */
      .section { padding: clamp(4.5rem, 10vw, 8rem) 0; }
      .sec-head { max-width: 640px; margin-bottom: clamp(2.5rem, 5vw, 3.5rem); }
      .sec-head h2 { font-size: clamp(2.2rem, 5.5vw, 3.8rem); }
      .sec-sub { color: rgba(239,233,221,0.7); margin-top: 1.1rem; font-size: 1.02rem; max-width: 56ch; }

      /* Listings */
      .grid-listings { display: grid; grid-template-columns: 1fr; gap: clamp(1.6rem, 3vw, 2.4rem); }
      @media (min-width: 720px) { .grid-listings { grid-template-columns: repeat(2, 1fr); } }
      @media (min-width: 1040px) { .grid-listings { grid-template-columns: repeat(3, 1fr); } }
      .card { background: var(--muted); border: 1px solid var(--border); transition: border-color 0.4s, transform 0.4s; }
      .card:hover { border-color: var(--accent); transform: translateY(-4px); }
      .card-media { position: relative; display: block; overflow: hidden; aspect-ratio: 3 / 2; }
      .card-media img { width: 100%; height: 100%; object-fit: cover; filter: saturate(0.85) brightness(0.92); transition: transform 0.8s ease, filter 0.6s; }
      .card:hover .card-media img { transform: scale(1.07); filter: saturate(1) brightness(1); }
      .card-tag {
        position: absolute; top: 1rem; left: 1rem; z-index: 2;
        background: var(--primary); color: var(--primary-fg);
        font-size: 0.62rem; letter-spacing: 0.2em; text-transform: uppercase;
        padding: 0.4rem 0.8rem;
