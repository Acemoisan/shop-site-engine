      }
      @media (min-width: 900px) { .split-badge { right: -1.6rem; } }
      .split-badge strong { font-family: var(--serif); font-size: 2.6rem; color: var(--primary); line-height: 1; }
      .split-badge span { font-size: 0.68rem; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(239,233,221,0.7); }
      .split-copy h2 { font-size: clamp(2rem, 5vw, 3.2rem); }
      .split-copy p { color: rgba(239,233,221,0.78); margin-top: 1.3rem; }

      /* Services */
      .services { background: var(--muted); }
      .svc-list { list-style: none; }
      .svc-row {
        display: flex; align-items: baseline; justify-content: space-between; gap: 1.5rem;
        padding: 1.7rem 0; border-top: 1px solid var(--border);
        transition: padding-left 0.3s;
      }
      .svc-row:last-child { border-bottom: 1px solid var(--border); }
      .svc-row:hover { padding-left: 0.8rem; }
      .svc-text h3 { font-size: 1.45rem; }
      .svc-text p { font-size: 0.9rem; color: rgba(239,233,221,0.6); margin-top: 0.3rem; }
      .svc-price { font-family: var(--serif); font-size: clamp(1.4rem, 3vw, 2rem); color: var(--primary); white-space: nowrap; }

      /* Quotes slider */
      .slider { overflow: hidden; }
      .slides { display: flex; transition: transform 0.7s cubic-bezier(0.4,0,0.1,1); }
      .quote { flex: 0 0 100%; text-align: center; padding: 0 clamp(0rem, 5vw, 4rem); }
      .quote blockquote { font-family: var(--serif); font-style: italic; font-size: clamp(1.5rem, 4vw, 2.6rem); line-height: 1.3; color: var(--fg); max-width: 24ch; margin: 0 auto; }
      .quote figcaption { margin-top: 1.8rem; }
      .quote figcaption strong { display: block; font-family: var(--sans); font-weight: 500; letter-spacing: 0.04em; }
      .quote figcaption span { font-size: 0.74rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--primary); }
      .dots { display: flex; gap: 0.7rem; justify-content: center; margin-top: 2.6rem; }
      .dot { width: 36px; height: 36px; padding: 0; background: none; border: none; cursor: pointer; position: relative; }
      .dot::after { content: ""; position: absolute; inset: 50% auto auto 50%; transform: translate(-50%,-50%); width: 9px; height: 9px; border: 1px solid var(--accent); border-radius: 50%; transition: 0.3s; }
      .dot.active::after { background: var(--primary); border-color: var(--primary); width: 11px; height: 11px; }

      /* Areas */
      .grid-areas { display: grid; grid-template-columns: repeat(2, 1fr); gap: clamp(0.9rem, 2vw, 1.5rem); }
      @media (min-width: 900px) { .grid-areas { grid-template-columns: repeat(4, 1fr); } }
      .area { position: relative; display: block; overflow: hidden; aspect-ratio: 3 / 4; }
      .area img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.8s ease; }
      .area:hover img { transform: scale(1.08); }
      .area-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(14,13,11,0.92) 8%, rgba(14,13,11,0.15) 60%); transition: background 0.4s; }
      .area:hover .area-overlay { background: linear-gradient(to top, rgba(14,13,11,0.95) 8%, rgba(140,120,72,0.3) 70%); }
      .area-text { position: absolute; left: 1.1rem; bottom: 1.1rem; right: 1.1rem; }
      .area-text strong { display: block; font-family: var(--serif); font-size: 1.5rem; }
      .area-text em { font-style: normal; font-size: 0.72rem; letter-spacing: 0.06em; color: rgba(239,233,221,0.75); }

      /* Contact */
      .contact .split { align-items: start; }
      .contact h2 { font-size: clamp(2.2rem, 5vw, 3.6rem); }
      .nap { list-style: none; margin-top: 2rem; }
      .nap li { padding: 1rem 0; border-top: 1px solid var(--border); }
      .nap li span { display: block; font-size: 0.68rem; letter-spacing: 0.24em; text-transform: uppercase; color: var(--primary); margin-bottom: 0.35rem; }
      .nap li a { font-size: 1.1rem; transition: color 0.25s; }
      .nap li a:hover { color: var(--primary); }
      .hours { margin-top: 1.6rem; width: 100%; border-collapse: collapse; }
      .hours th, .hours td { text-align: left; padding: 0.6rem 0; border-top: 1px solid var(--border); font-weight: 300; font-size: 0.92rem; }
      .hours th { color: rgba(239,233,221,0.65); letter-spacing: 0.08em; }
      .hours td { text-align: right; color: var(--fg); }
      .contact-form { display: flex; flex-direction: column; background: var(--muted); border: 1px solid var(--border); padding: clamp(1.6rem, 4vw, 2.6rem); }
      .contact-form label { font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(239,233,221,0.65); margin: 1rem 0 0.45rem; }
      .contact-form label:first-child { margin-top: 0; }
      .contact-form input, .contact-form textarea {
        background: var(--bg); border: 1px solid var(--border); color: var(--fg);
        padding: 0.8rem 0.9rem; font-family: var(--sans); font-size: 0.95rem; min-height: 48px; resize: vertical;
      }
      .contact-form .btn { margin-top: 1.6rem; }
      .call-cta { text-align: center; margin-top: 1rem; font-size: 0.8rem; letter-spacing: 0.1em; color: rgba(239,233,221,0.6); }
      .call-cta:hover { color: var(--primary); }

      /* Footer */
      .footer { border-top: 1px solid var(--border); padding: clamp(3rem, 6vw, 4.5rem) 0; }
      .foot-inner { display: grid; gap: 2rem; align-items: center; }
      @media (min-width: 820px) { .foot-inner { grid-template-columns: 1fr auto 1fr; } }
      .foot-brand { display: flex; flex-direction: column; gap: 0.5rem; }
      .foot-brand .brand-mark { margin-bottom: 0.3rem; }
      .foot-brand p { font-family: var(--serif); font-size: 1.2rem; }
      .foot-note { color: var(--primary); font-style: italic; font-size: 1rem !important; }
      .foot-nav { display: flex; flex-wrap: wrap; gap: 1rem 1.6rem; justify-content: center; }
      .foot-nav a { font-size: 0.72rem; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(239,233,221,0.7); transition: color 0.25s; }
      .foot-nav a:hover { color: var(--primary); }
      .foot-legal { font-size: 0.74rem; letter-spacing: 0.04em; color: rgba(239,233,221,0.5); text-align: right; line-height: 1.7; }
      @media (max-width: 819px) { .foot-legal { text-align: center; } .foot-nav { order: 3; } }

      /* Reveal */
      .reveal { opacity: 0; transform: translateY(26px); transition: opacity 0.8s ease, transform 0.8s ease; }
      .reveal.in { opacity: 1; transform: none; }
      @media (prefers-reduced-motion: reduce) {
        .reveal { opacity: 1; transform: none; transition: none; }
      }
    </style>
  </body>
