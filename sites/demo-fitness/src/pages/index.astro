---
import "@studio0rbit/shared/styles/base.css";
import "../theme.css";
import type { ShopContent } from "@studio0rbit/shared";
import SiteNav from "@studio0rbit/shared/components/SiteNav.astro";
import Stats from "@studio0rbit/shared/components/Stats.astro";
import Features from "@studio0rbit/shared/components/Features.astro";
import Services from "@studio0rbit/shared/components/Services.astro";
import Testimonials from "@studio0rbit/shared/components/Testimonials.astro";
import Faq from "@studio0rbit/shared/components/Faq.astro";
import CTA from "@studio0rbit/shared/components/CTA.astro";
import SiteFooter from "@studio0rbit/shared/components/SiteFooter.astro";
import LocalBusinessJsonLd from "@studio0rbit/shared/seo/LocalBusinessJsonLd.astro";

const shop: ShopContent = {
  name: "Forge Athletic Club",
  tagline: "Train like it matters.",
  vertical: "retail",
  phone: "+1-403-555-0199",
  address: "1140 11 St SE, Ramsay, Calgary, AB",
  mapUrl: "https://maps.google.com/?q=1140+11+St+SE+Calgary",
  serviceArea: "Ramsay",
  bookingUrl: "#book",
  hours: [],
  services: [
    { name: "Day Pass", price: "$25" },
    { name: "Monthly — Open Gym", price: "$89/mo" },
    { name: "Monthly — Unlimited Classes", price: "$159/mo" },
    { name: "Personal Coaching (4-pack)", price: "$320" },
  ],
  url: "https://forge.example.com",
};
const stats = [
  { value: "2,000+", label: "Members trained" },
  { value: "30+", label: "Classes / week" },
  { value: "5am–11pm", label: "Open daily" },
];
const features = [
  { icon: "dumbbell", title: "Serious equipment", body: "Full rack room, platforms, sleds, and a dedicated conditioning floor." },
  { icon: "target", title: "Real coaching", body: "Certified coaches program every session — no guessing, just progress." },
  { icon: "bolt", title: "Classes that hit", body: "Strength, HIIT, and conditioning on a schedule that fits your day." },
  { icon: "heart", title: "A real community", body: "Train alongside people who'll push you and learn your name." },
];
const testimonials = [
  { quote: "Strongest and fittest I've been in my life. The coaching is next level.", name: "Tyler B." },
  { quote: "Walked in nervous, left hooked. Best community in Calgary.", name: "Renee D." },
  { quote: "The 5am crew is unmatched. Forge changed my mornings.", name: "Omar H." },
];
const faqs = [
  { q: "Is the first class really free?", a: "Yes — your first class or day pass is on us. Just show up 10 minutes early." },
  { q: "I'm a total beginner. Is that okay?", a: "Absolutely. Every session scales to your level and our coaches guide you." },
  { q: "Can I freeze my membership?", a: "Yes, memberships can be frozen anytime — no long-term lock-in." },
];
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{shop.name} — Strength & conditioning gym in Ramsay, Calgary</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@600;700;800;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <LocalBusinessJsonLd shop={shop} />
  </head>
  <body id="top" class="bg-background text-foreground font-sans">
    <SiteNav name={shop.name} bookingUrl={shop.bookingUrl} bookLabel="Free trial" links={[{ label: "Memberships", href: "#services" }, { label: "Why Forge", href: "#features" }, { label: "FAQ", href: "#faq" }]} />

    <section class="relative overflow-hidden px-6 py-32 text-center sm:py-44">
      <div class="absolute inset-0 -z-10 bg-gradient-to-b from-primary/15 via-transparent to-transparent"></div>
      <div class="mx-auto max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.35em] text-primary">Forge Athletic Club · Ramsay</p>
        <h1 class="mt-6 font-display text-6xl font-extrabold uppercase leading-[0.88] tracking-tight text-foreground sm:text-8xl">Train like<br />it matters.</h1>
        <p class="mx-auto mt-7 max-w-lg text-lg text-muted-foreground">Strength, conditioning & coaching in Calgary's Ramsay district. Your first class is free.</p>
        <a href="#book" class="mt-10 inline-block rounded-[var(--radius)] bg-primary px-10 py-4 font-bold uppercase tracking-wider text-primary-foreground transition hover:opacity-90">Start free trial</a>
      </div>
    </section>

    <Stats items={stats} />
    <Features label="Why Forge" heading="Built for people who show up" items={features} />
    <Services services={shop.services} heading="Memberships" />
    <Testimonials label="Members" heading="The proof is in the people" items={testimonials} />
    <Faq items={faqs} />
    <CTA phone={shop.phone} bookingUrl={shop.bookingUrl} heading="Your first class is free" />
    <SiteFooter name={shop.name} address={shop.address} phone={shop.phone} />
  </body>
</html>
