---
import "../styles/base.css";
import "../theme.css";
import { profile } from "../content/profile";
import Head from "../components/Head.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Icon from "../components/Icon.astro";
import AppCard from "../components/AppCard.astro";

const title = `${profile.name} — self-hosted utilities & tools`;
const description =
  "A personal hub for the day-to-day tools Aidan Moisan self-hosts — starting with MacroFactor, a local-first macro & nutrition tracker with a live calendar and progress charts.";
const siteUrl = (Astro.site ?? new URL("https://acemoisan.pages.dev")).origin;
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: profile.name,
  jobTitle: profile.role,
  url: siteUrl,
  sameAs: profile.socials.filter((s) => s.href.startsWith("http")).map((s) => s.href),
  address: { "@type": "PostalAddress", addressRegion: "Alberta", addressCountry: "CA" },
};
---
<!doctype html>
<html lang="en">
  <head>
    <Head title={title} description={description} path="/" jsonLd={jsonLd} />
  </head>
  <body class="app-bg min-h-screen font-sans text-foreground antialiased">
    <a href="#main" class="skip-link">Skip to content</a>
    <Nav current="home" />

    <main id="main">
      <!-- Hero -->
      <section class="relative overflow-hidden">
        <div class="grid-overlay pointer-events-none absolute inset-0"></div>
        <div class="relative mx-auto grid max-w-6xl gap-12 px-4 py-16 sm:px-6 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:py-24">
          <!-- copy -->
          <div>
            <span class="inline-flex items-center gap-2 rounded-full border border-border bg-card/60 px-3 py-1 font-mono text-xs text-muted-foreground">
              <span class="h-1.5 w-1.5 rounded-full bg-accent"></span> Personal utility hub
            </span>
            <h1 class="mt-5 font-display text-4xl font-bold leading-[1.05] tracking-tight text-foreground sm:text-5xl lg:text-6xl">
              Hey, I'm {profile.name.split(" ")[0]}.<br />
              <span class="bg-gradient-to-r from-primary to-accent bg-clip-text text-transparent">Tools I actually use.</span>
            </h1>
            <p class="mt-5 max-w-xl text-base leading-relaxed text-muted-foreground sm:text-lg">
              {profile.bio}
            </p>

            <div class="mt-8 flex flex-wrap items-center gap-3">
              <a href="/apps" class="inline-flex items-center gap-2 rounded-lg bg-primary px-5 py-3 text-sm font-semibold text-primary-foreground shadow-sm transition hover:brightness-110">
                <Icon name="apps" class="h-4 w-4" /> Browse apps
              </a>
              <a href="/apps/macrofactor" class="inline-flex items-center gap-2 rounded-lg border border-border bg-card px-5 py-3 text-sm font-semibold text-foreground transition hover:border-border-strong">
                <Icon name="flame" class="h-4 w-4 text-cal" /> Open MacroFactor
              </a>
            </div>

            <div class="mt-8 flex flex-wrap items-center gap-1.5">
              {profile.socials.map((s) => (
                <a
                  href={s.href}
                  target={s.href.startsWith("http") ? "_blank" : undefined}
                  rel={s.href.startsWith("http") ? "noopener" : undefined}
                  class="group inline-flex items-center gap-2 rounded-lg border border-border bg-card/50 px-3 py-2 text-xs text-muted-foreground transition hover:border-border-strong hover:text-foreground"
                  aria-label={s.label}
                >
                  <Icon name={s.icon} class="h-4 w-4" />
                  <span class="font-mono">{s.handle ?? s.label}</span>
                </a>
              ))}
            </div>
          </div>

          <!-- live dashboard panel -->
          <div class="relative">
            <div class="rounded-2xl border border-border bg-card/80 p-5 shadow-xl shadow-black/30 backdrop-blur-sm">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                  <span class="h-2.5 w-2.5 rounded-full bg-good"></span>
                  <span class="font-mono text-xs text-muted-foreground">live · on-device</span>
                </div>
                <div class="text-right">
                  <p id="hp-date" class="font-mono text-xs text-muted-foreground">—</p>
                  <p id="hp-clock" class="font-mono text-sm font-semibold tabular-nums text-foreground">--:--</p>
                </div>
              </div>

              <div class="mt-4 rounded-xl border border-border bg-background/50 p-4">
                <div class="flex items-center justify-between">
                  <h2 class="font-display text-sm font-semibold text-foreground">Today's macros</h2>
                  <a href="/apps/macrofactor" class="font-mono text-xs text-primary hover:underline">log →</a>
                </div>
                <!-- rendered client-side from localStorage -->
                <div id="hp-macros" class="mt-4">
                  <div class="grid grid-cols-[auto_1fr] items-center gap-4">
                    <div class="relative h-24 w-24">
                      <svg viewBox="0 0 100 100" class="h-24 w-24 -rotate-90">
                        <circle cx="50" cy="50" r="42" fill="none" stroke="var(--border)" stroke-width="9" />
                        <circle id="hp-ring" cx="50" cy="50" r="42" fill="none" stroke="var(--cal)" stroke-width="9" stroke-linecap="round" stroke-dasharray="264" stroke-dashoffset="264" />
                      </svg>
                      <div class="absolute inset-0 grid place-content-center text-center">
                        <span id="hp-kcal" class="font-mono text-base font-semibold tabular-nums text-foreground">0</span>
                        <span class="font-mono text-[10px] text-muted-foreground">kcal</span>
                      </div>
                    </div>
                    <div class="space-y-2.5" id="hp-bars">
                      <!-- macro bars injected here -->
                    </div>
                  </div>
                  <p id="hp-empty" class="mt-3 hidden text-center font-mono text-xs text-muted-foreground">Nothing logged yet today — <a href="/apps/macrofactor" class="text-primary hover:underline">start tracking</a>.</p>
                </div>
              </div>

              <div class="mt-4 grid grid-cols-2 gap-3">
                <a href="/apps" class="flex items-center justify-between rounded-xl border border-border bg-background/40 px-3 py-2.5 text-sm text-foreground transition hover:border-border-strong">
                  <span class="flex items-center gap-2"><Icon name="apps" class="h-4 w-4 text-accent" /> Apps</span>
                  <Icon name="arrowRight" class="h-4 w-4 text-muted-foreground" />
                </a>
                <a href="https://github.com/Acemoisan" target="_blank" rel="noopener" class="flex items-center justify-between rounded-xl border border-border bg-background/40 px-3 py-2.5 text-sm text-foreground transition hover:border-border-strong">
                  <span class="flex items-center gap-2"><Icon name="github" class="h-4 w-4" /> GitHub</span>
                  <Icon name="arrowUpRight" class="h-4 w-4 text-muted-foreground" />
                </a>
              </div>
            </div>
            <span class="pointer-events-none absolute -inset-4 -z-10 rounded-3xl bg-gradient-to-tr from-primary/20 to-accent/10 blur-2xl"></span>
          </div>
        </div>
      </section>

      <!-- Apps -->
      <section id="apps" class="mx-auto max-w-6xl px-4 pb-24 sm:px-6">
        <div class="flex items-end justify-between gap-4">
          <div>
            <span class="font-mono text-xs uppercase tracking-widest text-primary">The apps</span>
            <h2 class="mt-1 font-display text-2xl font-bold tracking-tight text-foreground sm:text-3xl">Self-hosted utilities</h2>
            <p class="mt-2 max-w-xl text-sm text-muted-foreground">Small, fast, single-purpose tools — built for me, hosted here. More on the way.</p>
          </div>
          <a href="/apps" class="hidden shrink-0 items-center gap-1 text-sm font-semibold text-primary hover:underline sm:inline-flex">
            All apps <Icon name="arrowRight" class="h-4 w-4" />
          </a>
        </div>
        <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {profile.apps.map((app) => <AppCard app={app} />)}
        </div>
      </section>
    </main>

    <Footer />

    <script>
      import { loadState, todayKey, totalsFor, round } from "../lib/macro-store";

      const C = 2 * Math.PI * 42; // ring circumference

      function tick() {
        const now = new Date();
        const date = document.getElementById("hp-date");
        const clock = document.getElementById("hp-clock");
        if (date) date.textContent = now.toLocaleDateString(undefined, { weekday: "short", month: "short", day: "numeric" });
        if (clock) clock.textContent = now.toLocaleTimeString(undefined, { hour: "2-digit", minute: "2-digit" });
      }

      function macroBar(label: string, val: number, goal: number, color: string) {
        const pct = goal > 0 ? Math.min(100, (val / goal) * 100) : 0;
        return `<div>
          <div class="flex items-center justify-between font-mono text-[11px]">
            <span class="text-muted-foreground">${label}</span>
            <span class="tabular-nums text-foreground">${round(val)}<span class="text-muted-foreground">/${round(goal)}g</span></span>
          </div>
          <div class="mt-1 h-1.5 overflow-hidden rounded-full bg-border">
            <div class="h-full rounded-full" style="width:${pct}%;background:${color}"></div>
          </div>
        </div>`;
      }

      function renderMacros() {
        const s = loadState();
        const t = totalsFor(s.log[todayKey()]);
        const g = s.goals;
        const kcalEl = document.getElementById("hp-kcal");
        const ring = document.getElementById("hp-ring") as unknown as SVGCircleElement | null;
        const bars = document.getElementById("hp-bars");
        const empty = document.getElementById("hp-empty");
        if (kcalEl) kcalEl.textContent = String(round(t.calories));
        if (ring) {
          const pct = g.calories > 0 ? Math.min(1, t.calories / g.calories) : 0;
          ring.style.strokeDashoffset = String(C * (1 - pct));
          ring.setAttribute("stroke", t.calories > g.calories ? "var(--warn)" : "var(--cal)");
        }
        if (bars) {
          bars.innerHTML =
            macroBar("Protein", t.protein, g.protein, "var(--protein)") +
            macroBar("Carbs", t.carbs, g.carbs, "var(--carbs)") +
            macroBar("Fat", t.fat, g.fat, "var(--fat)");
        }
        if (empty) empty.classList.toggle("hidden", t.calories > 0);
      }

      tick();
      renderMacros();
      setInterval(tick, 1000 * 20);
    </script>
  </body>
</html>
