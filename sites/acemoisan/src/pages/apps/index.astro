---
import "../../styles/base.css";
import "../../theme.css";
import { profile, liveApps } from "../../content/profile";
import Head from "../../components/Head.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import Icon from "../../components/Icon.astro";
import AppCard from "../../components/AppCard.astro";

const title = "Apps — acemoisan";
const description =
  "The self-hosted utilities running on acemoisan.pages.dev. Start with MacroFactor, a local-first macro & nutrition tracker.";
---
<!doctype html>
<html lang="en">
  <head>
    <Head title={title} description={description} path="/apps" />
  </head>
  <body class="app-bg min-h-screen font-sans text-foreground antialiased">
    <a href="#main" class="skip-link">Skip to content</a>
    <Nav current="apps" />

    <main id="main" class="relative overflow-hidden">
      <div class="grid-overlay pointer-events-none absolute inset-0"></div>
      <div class="relative mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:py-20">
        <!-- header -->
        <div class="max-w-2xl">
          <span class="inline-flex items-center gap-2 rounded-full border border-border bg-card/60 px-3 py-1 font-mono text-xs text-muted-foreground">
            <Icon name="apps" class="h-3.5 w-3.5 text-primary" /> {liveApps.length} live · {profile.apps.length - liveApps.length} planned
          </span>
          <h1 class="mt-5 font-display text-4xl font-bold tracking-tight text-foreground sm:text-5xl">Apps</h1>
          <p class="mt-3 text-base leading-relaxed text-muted-foreground">
            Single-purpose tools I built for my own day-to-day, hosted right here. Everything runs client-side and keeps its data on your device — no account, nothing to sign into.
          </p>
        </div>

        <!-- grid -->
        <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {profile.apps.map((app) => <AppCard app={app} />)}
        </div>

        <!-- roadmap note -->
        <div class="mt-12 flex flex-col gap-4 rounded-2xl border border-dashed border-border/70 bg-card/40 p-6 sm:flex-row sm:items-center sm:justify-between">
          <div class="flex items-start gap-3">
            <span class="mt-0.5 grid h-9 w-9 shrink-0 place-items-center rounded-lg bg-accent/15 text-accent ring-1 ring-inset ring-accent/30">
              <Icon name="orbit" class="h-5 w-5" />
            </span>
            <div>
              <h2 class="font-display text-sm font-semibold text-foreground">Where this is going</h2>
              <p class="mt-1 max-w-xl text-sm text-muted-foreground">
                The plan is a small fleet of self-hosted day-to-day tools with live widgets and my own data behind them. On-device first; cloud sync is the next milestone.
              </p>
            </div>
          </div>
          <a href="https://github.com/Acemoisan" target="_blank" rel="noopener" class="inline-flex shrink-0 items-center gap-2 rounded-lg border border-border bg-card px-4 py-2.5 text-sm font-semibold text-foreground transition hover:border-border-strong">
            <Icon name="github" class="h-4 w-4" /> Follow along
          </a>
        </div>
      </div>
    </main>

    <Footer />
  </body>
</html>
