---
import "../../styles/base.css";
import "../../theme.css";
import Head from "../../components/Head.astro";
import Nav from "../../components/Nav.astro";
import Icon from "../../components/Icon.astro";

const title = "Ace-Budget — money in & out, by day · acemoisan";
const description =
  "A local-first budget tracker: log income and expenses on a live calendar, tag by category, track monthly targets and variance, import/export CSV. Data stays on your device.";
---
<!doctype html>
<html lang="en">
  <head>
    <Head title={title} description={description} path="/apps/budget" />
  </head>
  <body class="app-bg min-h-screen font-sans text-foreground antialiased">
    <a href="#main" class="skip-link">Skip to content</a>
    <Nav current="app" appName="Ace-Budget" />

    <main id="main" class="mx-auto max-w-2xl px-3 py-6 sm:px-6 sm:py-8">
      <!-- Title + controls -->
      <div class="flex items-center gap-3">
        <span class="grid h-11 w-11 shrink-0 place-items-center rounded-xl ring-1 ring-inset ring-border" style="background:color-mix(in oklab, var(--good) 16%, transparent); color:var(--good)">
          <Icon name="wallet" class="h-6 w-6" />
        </span>
        <div class="min-w-0">
          <h1 class="font-display text-2xl font-bold tracking-tight text-foreground">Ace-Budget</h1>
          <p class="truncate font-mono text-xs text-muted-foreground">money in &amp; out · <span class="text-good">on-device</span></p>
        </div>
      </div>

      <div class="mt-4 flex flex-col gap-2 sm:flex-row sm:flex-wrap sm:items-center">
        <div class="flex items-stretch justify-between rounded-lg border border-border bg-card sm:justify-start">
          <button data-nav="prev-month" class="grid h-10 w-11 place-items-center rounded-l-lg text-muted-foreground transition hover:bg-muted hover:text-foreground" aria-label="Previous month">
            <Icon name="chevronLeft" class="h-4 w-4" />
          </button>
          <button data-nav="this-month" id="month-label" class="flex-1 px-3 text-center font-mono text-xs font-medium text-foreground transition hover:text-primary sm:min-w-[8.5rem] sm:flex-none">—</button>
          <button data-nav="next-month" class="grid h-10 w-11 place-items-center rounded-r-lg text-muted-foreground transition hover:bg-muted hover:text-foreground" aria-label="Next month">
            <Icon name="chevronRight" class="h-4 w-4" />
          </button>
        </div>
        <div class="grid grid-cols-2 gap-2 sm:flex sm:flex-wrap">
          <label class="inline-flex cursor-pointer items-center justify-center gap-2 rounded-lg border border-border bg-card px-3 py-2.5 text-sm font-medium text-foreground transition hover:border-border-strong" title="Import expenses from a CSV">
            <Icon name="copy" class="h-4 w-4 text-accent" /> Import
            <input id="csv-import" type="file" accept=".csv,text/csv" class="sr-only" />
          </label>
          <button data-action="export" class="inline-flex items-center justify-center gap-2 rounded-lg border border-border bg-card px-3 py-2.5 text-sm font-medium text-foreground transition hover:border-border-strong" title="Export your expenses as CSV">
            <Icon name="download" class="h-4 w-4 text-accent" /> Export
          </button>
          <button data-open="budgets" class="inline-flex items-center justify-center gap-2 rounded-lg border border-border bg-card px-3 py-2.5 text-sm font-medium text-foreground transition hover:border-border-strong">
            <Icon name="target" class="h-4 w-4 text-accent" /> Budgets
          </button>
          <button data-open="entry" class="inline-flex items-center justify-center gap-2 rounded-lg bg-primary px-3 py-2.5 text-sm font-semibold text-primary-foreground shadow-sm transition hover:brightness-110">
            <Icon name="plus" class="h-4 w-4" /> Add
          </button>
        </div>
      </div>

      <!-- Reorderable / collapsible sections -->
      <div id="sections" class="mt-5 space-y-4">
        <!-- This month -->
        <section class="overflow-hidden rounded-2xl border border-border bg-card" data-section="thismonth">
          <div class="flex items-center gap-1 px-2.5 py-2 sm:px-3">
            <button type="button" data-drag class="grid h-8 w-8 shrink-0 cursor-grab touch-none place-items-center rounded-md text-muted-foreground/50 transition hover:text-foreground" aria-label="Drag to reorder"><Icon name="grip" class="h-4 w-4" /></button>
            <button type="button" data-collapse="thismonth" class="flex flex-1 items-center gap-2 py-1 pr-2 text-left">
              <h2 class="font-display text-sm font-semibold text-foreground">This month</h2>
              <span id="summary-count" class="ml-auto font-mono text-[11px] text-muted-foreground">—</span>
              <Icon name="chevronDown" class="section-chevron h-4 w-4 shrink-0 text-muted-foreground transition-transform" />
            </button>
          </div>
          <div class="bbody border-t border-border/60 px-4 pb-4 pt-4 sm:px-5" data-body="thismonth">
            <div class="grid grid-cols-3 gap-2 sm:gap-3">
              <div class="min-w-0 rounded-xl border border-border bg-background/40 px-2 py-2.5 sm:p-3">
                <p class="flex items-center gap-1 font-mono text-[10px] uppercase tracking-wider text-muted-foreground"><Icon name="arrowDown" class="h-3 w-3 shrink-0 text-good" /> In</p>
                <p id="sum-income" class="mt-1 truncate font-mono text-[13px] font-bold tabular-nums text-good sm:text-xl">—</p>
              </div>
              <div class="min-w-0 rounded-xl border border-border bg-background/40 px-2 py-2.5 sm:p-3">
                <p class="flex items-center gap-1 font-mono text-[10px] uppercase tracking-wider text-muted-foreground"><Icon name="arrowUp" class="h-3 w-3 shrink-0" style="color:var(--protein)" /> Out</p>
                <p id="sum-expense" class="mt-1 truncate font-mono text-[13px] font-bold tabular-nums sm:text-xl" style="color:var(--protein)">—</p>
              </div>
              <div class="min-w-0 rounded-xl border border-border bg-background/40 px-2 py-2.5 sm:p-3">
                <p class="font-mono text-[10px] uppercase tracking-wider text-muted-foreground">Net</p>
                <p id="sum-net" class="mt-1 truncate font-mono text-[13px] font-bold tabular-nums text-foreground sm:text-xl">—</p>
              </div>
            </div>
            <div id="budget-bar-wrap" class="mt-4 hidden">
              <div class="flex items-center justify-between font-mono text-[11px]">
                <span class="text-muted-foreground">Spent vs budget</span>
                <span id="budget-bar-text" class="tabular-nums text-foreground">—</span>
              </div>
              <div class="mt-1.5 h-2 overflow-hidden rounded-full bg-border">
                <div id="budget-bar" class="h-full rounded-full transition-[width] duration-500" style="width:0%;background:var(--good)"></div>
              </div>
            </div>
            <button data-open="ledger" class="mt-4 flex w-full items-center justify-center gap-1.5 rounded-lg border border-border bg-background/40 py-2.5 font-mono text-xs text-muted-foreground transition hover:border-border-strong hover:text-foreground">
              <Icon name="list" class="h-4 w-4" /> View all entries this month
            </button>
          </div>
        </section>

        <!-- Daily Entries -->
        <section class="overflow-hidden rounded-2xl border border-border bg-card" data-section="entries">
          <div class="flex items-center gap-1 px-2.5 py-2 sm:px-3">
            <button type="button" data-drag class="grid h-8 w-8 shrink-0 cursor-grab touch-none place-items-center rounded-md text-muted-foreground/50 transition hover:text-foreground" aria-label="Drag to reorder"><Icon name="grip" class="h-4 w-4" /></button>
            <button type="button" data-collapse="entries" class="flex flex-1 items-center gap-2 py-1 pr-2 text-left">
              <h2 class="font-display text-sm font-semibold text-foreground">Daily Entries</h2>
              <span id="day-total" class="ml-auto font-mono text-[11px] tabular-nums text-muted-foreground">—</span>
              <Icon name="chevronDown" class="section-chevron h-4 w-4 shrink-0 text-muted-foreground transition-transform" />
            </button>
          </div>
          <div class="bbody border-t border-border/60 px-4 pb-4 pt-4 sm:px-5" data-body="entries">
            <div class="flex items-center justify-between">
              <p class="font-mono text-xs text-muted-foreground"><span id="day-label">today</span></p>
              <button data-open="entry" class="inline-flex items-center gap-1.5 rounded-lg border border-border px-2.5 py-1.5 font-mono text-xs text-muted-foreground transition hover:border-border-strong hover:text-foreground">
                <Icon name="plus" class="h-3.5 w-3.5" /> Add
              </button>
            </div>
            <div id="day-list" class="mt-3 space-y-2"></div>
          </div>
        </section>

        <!-- Calendar -->
        <section class="overflow-hidden rounded-2xl border border-border bg-card" data-section="calendar">
          <div class="flex items-center gap-1 px-2.5 py-2 sm:px-3">
            <button type="button" data-drag class="grid h-8 w-8 shrink-0 cursor-grab touch-none place-items-center rounded-md text-muted-foreground/50 transition hover:text-foreground" aria-label="Drag to reorder"><Icon name="grip" class="h-4 w-4" /></button>
            <button type="button" data-collapse="calendar" class="flex flex-1 items-center gap-2 py-1 pr-2 text-left">
              <h2 class="font-display text-sm font-semibold text-foreground">Calendar</h2>
              <Icon name="chevronDown" class="section-chevron ml-auto h-4 w-4 shrink-0 text-muted-foreground transition-transform" />
            </button>
          </div>
          <div class="bbody border-t border-border/60 px-4 pb-4 pt-4 sm:px-5" data-body="calendar">
            <div class="grid grid-cols-7 gap-1 text-center font-mono text-[10px] text-muted-foreground">
              <span>Su</span><span>Mo</span><span>Tu</span><span>We</span><span>Th</span><span>Fr</span><span>Sa</span>
            </div>
            <div id="cal-grid" class="mt-1 grid grid-cols-7 gap-1"></div>
            <div class="mt-3 flex items-center justify-between font-mono text-[10px] text-muted-foreground">
              <span class="flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-sm" style="background:color-mix(in oklab, var(--good) 55%, var(--card))"></span> net +</span>
              <span class="flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-sm" style="background:color-mix(in oklab, var(--protein) 55%, var(--card))"></span> net −</span>
              <span class="flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-sm ring-1 ring-inset ring-primary"></span> today</span>
            </div>
          </div>
        </section>

        <!-- Where it went -->
        <section class="overflow-hidden rounded-2xl border border-border bg-card" data-section="whereitwent">
          <div class="flex items-center gap-1 px-2.5 py-2 sm:px-3">
            <button type="button" data-drag class="grid h-8 w-8 shrink-0 cursor-grab touch-none place-items-center rounded-md text-muted-foreground/50 transition hover:text-foreground" aria-label="Drag to reorder"><Icon name="grip" class="h-4 w-4" /></button>
            <button type="button" data-collapse="whereitwent" class="flex flex-1 items-center gap-2 py-1 pr-2 text-left">
              <h2 class="font-display text-sm font-semibold text-foreground">Where it went</h2>
              <span class="ml-auto font-mono text-[11px] text-muted-foreground">this month</span>
              <Icon name="chevronDown" class="section-chevron h-4 w-4 shrink-0 text-muted-foreground transition-transform" />
            </button>
          </div>
          <div class="bbody border-t border-border/60 px-4 pb-4 pt-4 sm:px-5" data-body="whereitwent">
            <div id="cat-breakdown" class="space-y-2.5"></div>
            <button data-open="ledger" class="mt-4 flex w-full items-center justify-center gap-1.5 rounded-lg border border-border bg-background/40 py-2.5 font-mono text-xs text-muted-foreground transition hover:border-border-strong hover:text-foreground">
              <Icon name="list" class="h-4 w-4" /> View all entries this month
            </button>
          </div>
        </section>
      </div>

      <p class="mt-6 px-2 text-center font-mono text-[11px] text-muted-foreground/70">
        On-device only. Drag <Icon name="grip" class="inline h-3 w-3" /> to reorder sections · tap a title to collapse · Export to share a CSV.
      </p>
    </main>

    <!-- ===================== Entry modal ===================== -->
    <div id="modal-entry" class="fixed inset-0 z-[70] hidden" role="dialog" aria-modal="true" aria-labelledby="entry-title">
      <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" data-close></div>
      <div class="absolute inset-x-0 bottom-0 mx-auto max-h-[92vh] w-full max-w-md overflow-y-auto rounded-t-2xl border border-border bg-card sm:inset-x-auto sm:bottom-auto sm:left-1/2 sm:top-1/2 sm:-translate-x-1/2 sm:-translate-y-1/2 sm:rounded-2xl">
        <div class="flex items-center justify-between border-b border-border px-5 py-4">
          <h3 id="entry-title" class="font-display text-base font-semibold text-foreground">Add entry</h3>
          <button data-close class="grid h-8 w-8 place-items-center rounded-lg text-muted-foreground transition hover:bg-muted hover:text-foreground" aria-label="Close">
            <Icon name="x" class="h-4 w-4" />
          </button>
        </div>
        <form id="entry-form" class="px-5 py-5">
          <input type="hidden" id="e-id" />
          <div class="grid grid-cols-2 gap-2 rounded-lg border border-border bg-background/40 p-1">
            <button type="button" data-etype="expense" class="etype-btn rounded-md py-2 text-sm font-semibold transition">Expense</button>
            <button type="button" data-etype="income" class="etype-btn rounded-md py-2 text-sm font-semibold transition">Income</button>
          </div>
          <div class="mt-4 grid grid-cols-2 gap-3">
            <div>
              <label class="font-mono text-xs text-muted-foreground" for="e-amount">Amount</label>
              <div class="mt-1 flex items-center rounded-lg border border-border bg-background focus-within:border-primary">
                <span id="e-currency" class="pl-3 pr-1 font-mono text-sm text-muted-foreground">$</span>
                <input id="e-amount" name="amount" type="number" min="0" step="0.01" inputmode="decimal" required placeholder="0.00"
                  class="w-full rounded-r-lg bg-transparent px-1 py-2.5 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none" />
              </div>
            </div>
            <div>
              <label class="font-mono text-xs text-muted-foreground" for="e-date">Date</label>
              <input id="e-date" name="date" type="date" required
                class="mt-1 w-full rounded-lg border border-border bg-background px-3 py-2.5 text-sm text-foreground focus:border-primary focus:outline-none" />
            </div>
          </div>
          <div class="mt-3">
            <label class="font-mono text-xs text-muted-foreground" for="e-category">Category</label>
            <select id="e-category" name="category"
              class="mt-1 w-full rounded-lg border border-border bg-background px-3 py-2.5 text-sm text-foreground focus:border-primary focus:outline-none"></select>
          </div>
          <div class="mt-3">
            <label class="font-mono text-xs text-muted-foreground" for="e-label"><span id="e-label-name">Vendor</span> <span class="text-muted-foreground/60">(optional)</span></label>
            <input id="e-label" name="label" placeholder="e.g. Costco, Amazon, employer"
              class="mt-1 w-full rounded-lg border border-border bg-background px-3 py-2.5 text-sm text-foreground placeholder:text-muted-foreground focus:border-primary focus:outline-none" />
          </div>
          <div class="mt-3">
            <label class="font-mono text-xs text-muted-foreground" for="e-note">Note <span class="text-muted-foreground/60">(optional)</span></label>
            <input id="e-note" name="note" placeholder="e.g. weekly shop…"
              class="mt-1 w-full rounded-lg border border-border bg-background px-3 py-2.5 text-sm text-foreground placeholder:text-muted-foreground focus:border-primary focus:outline-none" />
          </div>
          <button type="submit" id="e-submit" class="mt-5 inline-flex w-full items-center justify-center gap-2 rounded-lg bg-primary px-4 py-2.5 text-sm font-semibold text-primary-foreground transition hover:brightness-110">
            <Icon name="check" class="h-4 w-4" /> <span id="e-submit-label">Add entry</span>
          </button>
          <button type="button" id="e-delete" class="mt-2 hidden w-full items-center justify-center gap-2 rounded-lg border border-border px-4 py-2.5 text-sm font-medium text-muted-foreground transition hover:border-warn/50 hover:bg-warn/10 hover:text-warn">
            <Icon name="trash" class="h-4 w-4" /> Delete entry
          </button>
        </form>
      </div>
    </div>

    <!-- ===================== Budgets modal ===================== -->
    <div id="modal-budgets" class="fixed inset-0 z-[70] hidden" role="dialog" aria-modal="true" aria-labelledby="budgets-title">
      <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" data-close></div>
      <div class="absolute inset-x-0 bottom-0 mx-auto flex max-h-[92vh] w-full max-w-md flex-col overflow-hidden rounded-t-2xl border border-border bg-card sm:inset-x-auto sm:bottom-auto sm:left-1/2 sm:top-1/2 sm:-translate-x-1/2 sm:-translate-y-1/2 sm:rounded-2xl">
        <div class="flex items-center justify-between border-b border-border px-5 py-4">
          <h3 id="budgets-title" class="font-display text-base font-semibold text-foreground">Monthly budgets</h3>
          <button data-close class="grid h-8 w-8 place-items-center rounded-lg text-muted-foreground transition hover:bg-muted hover:text-foreground" aria-label="Close">
            <Icon name="x" class="h-4 w-4" />
          </button>
        </div>
        <form id="budgets-form" class="flex min-h-0 flex-col">
          <div class="border-b border-border px-5 py-3">
            <label class="font-mono text-xs text-muted-foreground" for="s-currency">Currency symbol</label>
            <input id="s-currency" name="currency" maxlength="3" placeholder="$"
              class="mt-1 w-24 rounded-lg border border-border bg-background px-3 py-2 text-center text-sm text-foreground focus:border-primary focus:outline-none" />
          </div>
          <p class="px-5 pt-3 font-mono text-[11px] text-muted-foreground">Monthly target per expense category.</p>
          <div id="targets-list" class="min-h-0 flex-1 space-y-1.5 overflow-y-auto px-5 py-3"></div>
          <div class="flex items-center gap-2 border-t border-border px-5 py-3">
            <input id="new-cat-name" maxlength="40" placeholder="Add a category…" autocomplete="off"
              class="min-w-0 flex-1 rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground placeholder:text-muted-foreground focus:border-primary focus:outline-none" />
            <button type="button" id="add-cat-btn" class="inline-flex shrink-0 items-center gap-1.5 rounded-lg border border-border px-3 py-2 text-sm font-medium text-foreground transition hover:border-border-strong">
              <Icon name="plus" class="h-4 w-4" /> Add
            </button>
          </div>
          <div class="flex items-center justify-between border-t border-border px-5 py-3">
            <span class="font-mono text-xs text-muted-foreground">Total / month: <span id="targets-total" class="text-foreground">—</span></span>
            <button type="submit" class="inline-flex items-center gap-2 rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground transition hover:brightness-110">
              <Icon name="check" class="h-4 w-4" /> Save
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- ===================== Import preview modal ===================== -->
    <div id="modal-import" class="fixed inset-0 z-[75] hidden" role="dialog" aria-modal="true" aria-labelledby="import-title">
      <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" data-close></div>
      <div class="absolute inset-x-0 bottom-0 mx-auto flex max-h-[90vh] w-full max-w-md flex-col overflow-hidden rounded-t-2xl border border-border bg-card sm:inset-x-auto sm:bottom-auto sm:left-1/2 sm:top-1/2 sm:-translate-x-1/2 sm:-translate-y-1/2 sm:rounded-2xl">
        <div class="flex items-center justify-between border-b border-border px-5 py-4">
          <h3 id="import-title" class="font-display text-base font-semibold text-foreground">Import expenses</h3>
          <button data-close class="grid h-8 w-8 place-items-center rounded-lg text-muted-foreground transition hover:bg-muted hover:text-foreground" aria-label="Close">
            <Icon name="x" class="h-4 w-4" />
          </button>
        </div>
        <div class="flex min-h-0 flex-col px-5 py-5">
          <div id="import-summary" class="rounded-xl border border-border bg-background/40 p-4 text-sm text-foreground">—</div>
          <div id="import-preview" class="mt-3 min-h-0 flex-1 space-y-1 overflow-y-auto pr-1"></div>
          <p id="import-note" class="mt-3 font-mono text-[11px] text-muted-foreground"></p>
          <button id="import-confirm" class="mt-4 inline-flex w-full items-center justify-center gap-2 rounded-lg bg-primary px-4 py-2.5 text-sm font-semibold text-primary-foreground transition hover:brightness-110 disabled:opacity-40">
            <Icon name="check" class="h-4 w-4" /> <span id="import-confirm-label">Import</span>
          </button>
        </div>
      </div>
    </div>

    <!-- ===================== Ledger modal (all month entries) ===================== -->
    <div id="modal-ledger" class="fixed inset-0 z-[75] hidden" role="dialog" aria-modal="true" aria-labelledby="ledger-title">
      <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" data-close></div>
      <div class="absolute inset-x-0 bottom-0 mx-auto flex max-h-[92vh] w-full max-w-lg flex-col overflow-hidden rounded-t-2xl border border-border bg-card sm:inset-x-auto sm:bottom-auto sm:left-1/2 sm:top-1/2 sm:-translate-x-1/2 sm:-translate-y-1/2 sm:rounded-2xl">
        <div class="flex items-center justify-between border-b border-border px-5 py-4">
          <h3 id="ledger-title" class="font-display text-base font-semibold text-foreground">All entries · <span id="ledger-month">—</span></h3>
          <button data-close class="grid h-8 w-8 place-items-center rounded-lg text-muted-foreground transition hover:bg-muted hover:text-foreground" aria-label="Close">
            <Icon name="x" class="h-4 w-4" />
          </button>
        </div>
        <div class="min-h-0 flex-1 overflow-auto">
          <div id="ledger-body" class="min-w-full"></div>
        </div>
        <div class="flex items-center justify-between border-t border-border px-5 py-3 font-mono text-xs">
          <span class="text-muted-foreground"><span id="ledger-count">0</span> entries</span>
          <span id="ledger-total" class="tabular-nums text-foreground">—</span>
        </div>
      </div>
    </div>

    <!-- toast -->
    <div id="toast" class="pointer-events-none fixed bottom-5 left-1/2 z-[80] -translate-x-1/2 rounded-lg border border-border bg-card px-4 py-2.5 text-sm font-medium text-foreground opacity-0 shadow-xl transition-opacity"></div>

    <style>
      .etype-btn { color: var(--muted-foreground); }
      .etype-btn[aria-selected="true"] { background: var(--card); color: var(--foreground); box-shadow: 0 1px 2px rgba(0,0,0,.3); }
      [data-section].collapsed .section-chevron { transform: rotate(-90deg); }
      [data-section].dragging { opacity: .5; }
      [data-section].drag-over { outline: 2px dashed var(--primary); outline-offset: 2px; }
    </style>

    <script>
      import "../../scripts/budget";
    </script>
  </body>
</html>
