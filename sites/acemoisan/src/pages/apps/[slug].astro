---
import "../../styles/base.css";
import "../../theme.css";
import { plannedApps } from "../../content/profile";
import Head from "../../components/Head.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import Icon from "../../components/Icon.astro";

// One detail/plan page per PLANNED app. Live apps have their own static routes
// (ace-macros.astro, budget.astro) which take priority over this dynamic one.
export function getStaticPaths() {
  return plannedApps.map((app) => ({ params: { slug: app.slug }, props: { app } }));
}

const { app } = Astro.props;
const plan = app.plan;
const title = `${app.name} — ${app.tagline} · acemoisan`;
const description = plan?.overview ?? app.description;
---
<!doctype html>
<html lang="en">
  <head>
    <Head title={title} description={description} path={`/apps/${app.slug}`} />
  </head>
  <body class="app-bg min-h-screen font-sans text-foreground antialiased">
    <a href="#main" class="skip-link">Skip to content</a>
    <Nav current="app" appName={app.name} />

    <main id="main" class="relative overflow-hidden">
      <div class="grid-overlay pointer-events-none absolute inset-0"></div>
      <div class="relative mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:py-16">
        <a href="/apps" class="inline-flex items-center gap-1.5 font-mono text-xs text-muted-foreground transition hover:text-foreground">
          <Icon name="chevronLeft" class="h-4 w-4" /> All apps
        </a>

        <!-- header -->
        <div class="mt-6 flex items-start gap-4">
          <span
            class="grid h-14 w-14 shrink-0 place-items-center rounded-2xl ring-1 ring-inset ring-border"
            style={`background:color-mix(in oklab, ${app.accent} 16%, transparent); color:${app.accent}`}
          >
            <Icon name={app.icon} class="h-7 w-7" />
          </span>
          <div>
            <div class="flex flex-wrap items-center gap-2">
              <h1 class="font-display text-3xl font-bold tracking-tight text-foreground">{app.name}</h1>
              <span class="rounded-full bg-muted px-2.5 py-1 font-mono text-[11px] font-medium text-muted-foreground ring-1 ring-inset ring-border">
                Planned{plan?.status ? ` · ${plan.status}` : ""}
              </span>
            </div>
            <p class="mt-1 font-mono text-sm text-muted-foreground">{app.tagline}</p>
          </div>
        </div>

        <!-- overview -->
        <p class="mt-8 text-lg leading-relaxed text-foreground/90">{plan?.overview ?? app.description}</p>

        <!-- planned features -->
        {plan?.features?.length && (
          <section class="mt-10">
            <h2 class="font-display text-sm font-semibold uppercase tracking-widest text-primary">Planned features</h2>
            <ul class="mt-4 space-y-2.5">
              {plan.features.map((f) => (
                <li class="flex items-start gap-3 rounded-xl border border-border bg-card/60 px-4 py-3">
                  <Icon name="check" class="mt-0.5 h-4 w-4 shrink-0 text-good" />
                  <span class="text-sm leading-relaxed text-foreground">{f}</span>
                </li>
              ))}
            </ul>
          </section>
        )}

        <!-- notes / approach -->
        {plan?.notes?.length && (
          <section class="mt-10">
            <h2 class="font-display text-sm font-semibold uppercase tracking-widest text-accent">Approach &amp; notes</h2>
            <ul class="mt-4 space-y-2.5">
              {plan.notes.map((n) => (
                <li class="flex items-start gap-3">
                  <Icon name="info" class="mt-0.5 h-4 w-4 shrink-0 text-muted-foreground" />
                  <span class="text-sm leading-relaxed text-muted-foreground">{n}</span>
                </li>
              ))}
            </ul>
          </section>
        )}

        {app.tags?.length && (
          <div class="mt-10 flex flex-wrap gap-1.5">
            {app.tags.map((t) => (
              <span class="rounded-md bg-muted px-2 py-0.5 font-mono text-[11px] text-muted-foreground ring-1 ring-inset ring-border">{t}</span>
            ))}
          </div>
        )}

        <div class="mt-10 rounded-2xl border border-dashed border-border/70 bg-card/40 px-5 py-4">
          <p class="font-mono text-xs text-muted-foreground">
            This is a plan, not a build yet — catalogued here so the intent is on record. Nothing's shipped for this app.
          </p>
        </div>
      </div>
    </main>

    <Footer />
  </body>
</html>
