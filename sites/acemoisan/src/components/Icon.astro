const inner = stroke[name] ?? solid[name] ?? "";
const isStroke = name in stroke;
---
{isStroke ? (
  <svg class={cls} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={inner} />
) : (
  <svg class={cls} viewBox="0 0 24 24" fill="none" aria-hidden="true" set:html={inner} />
)}
