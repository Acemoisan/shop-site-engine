---
import Icon from "./Icon.astro";
// Sticky, blurred top nav shared across the hub. The "Apps" button is the
// primary affordance — it's the whole point of the site.
interface Props { current?: "home" | "apps" | "app"; appName?: string }
const { current = "home", appName } = Astro.props;
---
<header class="sticky top-0 z-50 border-b border-border/70 bg-background/70 backdrop-blur-xl">
  <nav class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6">
    <a href="/" class="group flex items-center gap-2.5" aria-label="acemoisan — home">
      <span class="grid h-8 w-8 place-items-center rounded-lg bg-primary/15 font-display text-lg font-bold text-primary ring-1 ring-inset ring-primary/30 transition group-hover:bg-primary/25">A</span>
      <span class="font-display text-[15px] font-semibold tracking-tight text-foreground">acemoisan<span class="text-primary">.dev</span></span>
    </a>

    <div class="flex items-center gap-2 sm:gap-3">
      {current === "app" && appName && (
        <span class="hidden items-center gap-1.5 rounded-full border border-border bg-card px-3 py-1 font-mono text-xs text-muted-foreground sm:inline-flex">
          <Icon name="apps" class="h-3.5 w-3.5 text-primary" /> {appName}
        </span>
      )}
      <a
        href="https://github.com/Acemoisan"
        target="_blank"
        rel="noopener"
        class="hidden h-9 w-9 place-items-center rounded-lg border border-border text-muted-foreground transition hover:border-border-strong hover:text-foreground sm:grid"
        aria-label="GitHub"
      >
        <Icon name="github" class="h-[18px] w-[18px]" />
      </a>
      <a
        href="/apps"
        aria-current={current === "apps" ? "page" : undefined}
        class:list={[
          "inline-flex items-center gap-2 rounded-lg px-4 py-2 text-sm font-semibold shadow-sm transition",
          current === "apps"
            ? "bg-primary/15 text-primary ring-1 ring-inset ring-primary/40"
            : "bg-primary text-primary-foreground hover:brightness-110",
        ]}
      >
        <Icon name="apps" class="h-4 w-4" />
        Apps
      </a>
    </div>
  </nav>
</header>
