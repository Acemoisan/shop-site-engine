---
import Icon from "./Icon.astro";
import type { AppEntry } from "../content/profile";
interface Props { app: AppEntry }
const { app } = Astro.props;
const live = app.status === "live";
const Tag = live ? "a" : "div";
---
<Tag
  href={live ? app.href : undefined}
  data-live={live ? "" : undefined}
  class:list={[
    "group relative flex flex-col overflow-hidden rounded-2xl border p-6 transition",
    live
      ? "border-border bg-card hover:-translate-y-0.5 hover:border-border-strong hover:shadow-lg hover:shadow-black/20"
      : "border-dashed border-border/70 bg-card/40",
  ]}
>
  <!-- accent wash -->
  <span
    class="pointer-events-none absolute -right-16 -top-16 h-40 w-40 rounded-full opacity-20 blur-2xl transition group-hover:opacity-30"
    style={`background:${app.accent}`}
  ></span>

  <div class="flex items-start justify-between gap-3">
    <span
      class="grid h-12 w-12 place-items-center rounded-xl ring-1 ring-inset ring-border"
      style={`background:color-mix(in oklab, ${app.accent} 16%, transparent); color:${app.accent}`}
    >
      <Icon name={app.icon} class="h-6 w-6" />
    </span>
    {live ? (
      <span class="inline-flex items-center gap-1.5 rounded-full bg-good/15 px-2.5 py-1 font-mono text-[11px] font-medium text-good ring-1 ring-inset ring-good/30">
        <span class="h-1.5 w-1.5 rounded-full bg-good"></span> Live
      </span>
    ) : (
      <span class="rounded-full bg-muted px-2.5 py-1 font-mono text-[11px] font-medium text-muted-foreground ring-1 ring-inset ring-border">Planned</span>
    )}
  </div>

  <h3 class="mt-4 font-display text-lg font-semibold text-foreground">{app.name}</h3>
  <p class="font-mono text-xs text-muted-foreground">{app.tagline}</p>
  <p class="mt-2 flex-1 text-sm leading-relaxed text-muted-foreground">{app.description}</p>

  <div class="mt-4 flex items-center justify-between gap-3">
    <div class="flex flex-wrap gap-1.5">
      {app.tags?.map((t) => (
        <span class="rounded-md bg-muted px-2 py-0.5 font-mono text-[10px] text-muted-foreground ring-1 ring-inset ring-border">{t}</span>
      ))}
    </div>
    {live && (
      <span class="inline-flex items-center gap-1 text-sm font-semibold text-primary">
        Open <Icon name="arrowRight" class="h-4 w-4 transition group-hover:translate-x-0.5" />
      </span>
    )}
  </div>
</Tag>
