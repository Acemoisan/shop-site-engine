---
// Ironwood Tattoo Co. — "fineline" variant. Self-contained showcase template.
const nav = [
  { label: "Work", href: "#gallery" },
  { label: "Artists", href: "#artists" },
  { label: "Rates", href: "#rates" },
  { label: "Visit", href: "#visit" },
];

const stats = [
  { value: "12", label: "Years on 9th Ave" },
  { value: "3", label: "Resident artists" },
  { value: "90", label: "Day touch-up window" },
  { value: "AA", label: "Hygiene rated" },
];

const services = [
  { name: "Custom Tattoo Design", price: "from $180/hr", note: "Shop minimum $120" },
  { name: "Fine-Line & Micro Tattoo", price: "from $140", note: "Single-needle work" },
  { name: "Flash of the Day", price: "$150 flat", note: "Pre-drawn, claim same-day" },
  { name: "Cover-Up & Rework", price: "from $200/hr", note: "Free consultation" },
  { name: "Touch-Up (our work)", price: "complimentary", note: "Within 90 days" },
  { name: "Ear & Body Piercing", price: "from $45", note: "Plus jewellery" },
];

const artists = [
  { name: "Marlo Vance", focus: "Fine-line · Florals", seed: "marlo-fineline" },
  { name: "Priya Nair", focus: "Micro · Lettering", seed: "priya-micro" },
  { name: "Cole Ashby", focus: "Botanical · Linework", seed: "cole-botanical" },
];

const gallery = [
  { seed: "ink-fern", style: "Fine-line", span: "tall" },
  { seed: "ink-rose", style: "Floral", span: "" },
  { seed: "ink-script", style: "Lettering", span: "" },
  { seed: "ink-snake", style: "Linework", span: "wide" },
  { seed: "ink-moth", style: "Micro", span: "" },
  { seed: "ink-hand", style: "Botanical", span: "tall" },
];

const testimonials = [
  { quote: "Marlo took my rough idea and turned it into the cleanest piece I own. The studio is spotless and the whole thing felt easy.", who: "Devon R." },
  { quote: "Booked for a fine-line floral and left obsessed. Healed perfectly, lines still razor sharp months later.", who: "Priya K." },
  { quote: "Walked in for flash, walked out with a tattoo I'll brag about forever. Real old-school energy.", who: "Cole T." },
];

const faqs = [
  { q: "What do I need to book?", a: "You must be 18+ with valid government photo ID. No exceptions. An $80 non-refundable deposit holds your slot and comes off your final price." },
  { q: "How does the deposit work?", a: "Deposits secure your appointment and are applied to your session total. We require 48-hour notice to reschedule without forfeiting it." },
  { q: "Do you offer touch-ups?", a: "Yes — free touch-ups on our work within 90 days. An aftercare sheet is provided with every piece." },
  { q: "Walk-ins or appointment?", a: "Both. Custom work is by appointment; flash and small pieces are often available as walk-ins Tuesday through Saturday." },
];

const hours = [
  { day: "Tue – Fri", time: "11am – 8pm" },
  { day: "Saturday", time: "11am – 6pm" },
  { day: "Sunday", time: "12pm – 5pm" },
  { day: "Monday", time: "Closed · by request" },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Ironwood Tattoo Co. — Fine-Line Tattooing in Inglewood, Calgary</title>
    <meta
      name="description"
      content="Delicate, considered fine-line and micro tattooing in the heart of Calgary's Inglewood. By appointment and walk-in. Book a consultation with Ironwood Tattoo Co."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Jost:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>

    <!-- Sticky booking bar -->
    <div class="bookbar" aria-label="Booking">
      <span class="bookbar__txt">Now booking · deposit $80 holds your slot</span>
      <a class="bookbar__cta" href="#book">Book a consultation</a>
    </div>

    <header class="nav" id="top">
      <a class="brand" href="#top" aria-label="Ironwood Tattoo Co. home">
        <span class="brand__mark" aria-hidden="true">
          <svg viewBox="0 0 32 32" width="26" height="26">
            <circle cx="16" cy="16" r="14" fill="none" stroke="currentColor" stroke-width="1" />
            <path d="M16 5 C 11 12, 11 20, 16 27 C 21 20, 21 12, 16 5 Z" fill="none" stroke="currentColor" stroke-width="1" />
            <line x1="16" y1="5" x2="16" y2="27" stroke="currentColor" stroke-width="0.6" />
          </svg>
        </span>
        <span class="brand__name">Ironwood</span>
      </a>
      <nav class="nav__links" aria-label="Primary">
        {nav.map((n) => <a href={n.href}>{n.label}</a>)}
      </nav>
      <a class="nav__cta" href="#book">Book</a>
      <button class="nav__toggle" aria-label="Toggle menu" aria-expanded="false" id="navToggle">
        <span></span><span></span>
      </button>
    </header>
    <nav class="drawer" id="drawer" aria-label="Mobile">
      {nav.map((n) => <a href={n.href}>{n.label}</a>)}
      <a class="drawer__cta" href="#book">Book a consultation</a>
    </nav>

    <main id="main">
      <!-- Hero -->
      <section class="hero">
        <div class="hero__copy reveal">
          <p class="eyebrow">Inglewood · Calgary · est. 2014</p>
          <h1>Delicate work.<br /><em>Considered</em> lines.</h1>
          <p class="hero__lede">
            Custom fine-line and micro tattooing in the heart of Calgary's
            Inglewood — by appointment and walk-in.
          </p>
          <div class="hero__actions">
            <a class="btn btn--solid" href="#book">Book a consultation</a>
            <a class="btn btn--ghost" href="#gallery">View healed work</a>
          </div>
        </div>
        <div class="hero__art reveal">
          <div class="hero__frame">
            <img
              src="https://picsum.photos/seed/ironwood-hero/760/940"
              alt="Macro photograph of a delicate single-needle fine-line tattoo on skin"
              loading="eager"
              width="760"
              height="940"
            />
          </div>
          <span class="hero__tag">single-needle · healed</span>
        </div>
      </section>

      <!-- Marquee -->
      <div class="marquee" aria-hidden="true">
        <div class="marquee__track">
          <span>Fine-line</span><span>·</span><span>Micro</span><span>·</span>
          <span>Botanical</span><span>·</span><span>Lettering</span><span>·</span>
          <span>Cover-ups</span><span>·</span><span>Custom only</span><span>·</span>
          <span>Fine-line</span><span>·</span><span>Micro</span><span>·</span>
          <span>Botanical</span><span>·</span><span>Lettering</span><span>·</span>
          <span>Cover-ups</span><span>·</span><span>Custom only</span><span>·</span>
        </div>
      </div>

      <!-- Stats / about -->
      <section class="about">
        <div class="about__intro reveal">
          <h2>Quiet rooms, careful hands, ink that ages well.</h2>
          <p>
            Ironwood is a small studio built around restraint. We take fewer
            clients, draw every piece custom, and obsess over the lines that
            most people never notice — because those are the ones that last.
          </p>
        </div>
        <dl class="stats">
          {stats.map((s) => (
            <div class="stats__item reveal">
              <dt>{s.value}</dt>
              <dd>{s.label}</dd>
            </div>
          ))}
        </dl>
      </section>

      <!-- Gallery (bento masonry) -->
      <section class="gallery" id="gallery">
        <div class="section-head reveal">
          <p class="eyebrow">Portfolio · healed work</p>
          <h2>Selected pieces</h2>
          <p class="section-head__sub">Shown in true colour, photographed weeks after healing.</p>
        </div>
        <div class="bento">
          {gallery.map((g) => (
            <figure class={`bento__cell ${g.span}`}>
              <img
                src={`https://picsum.photos/seed/${g.seed}/680/680`}
                alt={`Healed ${g.style.toLowerCase()} tattoo by an Ironwood artist`}
                loading="lazy"
                width="680"
                height="680"
              />
              <figcaption>{g.style}</figcaption>
            </figure>
          ))}
        </div>
      </section>

      <!-- Artists -->
      <section class="artists" id="artists">
        <div class="section-head reveal">
          <p class="eyebrow">Resident roster</p>
          <h2>Choose your artist</h2>
        </div>
        <div class="artist-grid">
          {artists.map((a) => (
            <article class="artist reveal">
              <div class="artist__photo">
                <img
                  src={`https://picsum.photos/seed/${a.seed}/520/640?grayscale`}
                  alt={`Portrait of tattoo artist ${a.name}`}
                  loading="lazy"
                  width="520"
                  height="640"
                />
              </div>
              <div class="artist__body">
                <h3>{a.name}</h3>
                <p class="artist__focus">{a.focus}</p>
                <a class="artist__link" href="#book">Book with {a.name.split(" ")[0]} →</a>
              </div>
            </article>
          ))}
        </div>
      </section>

      <!-- Rates -->
      <section class="rates" id="rates">
        <div class="section-head reveal">
          <p class="eyebrow">Services & rates</p>
          <h2>Honest pricing</h2>
          <p class="section-head__sub">
            Deposit: $80 non-refundable, applied to your session. 48-hour
            reschedule notice required.
          </p>
        </div>
        <ul class="rate-list">
          {services.map((s) => (
            <li class="rate reveal">
              <div class="rate__main">
                <span class="rate__name">{s.name}</span>
                <span class="rate__note">{s.note}</span>
              </div>
              <span class="rate__price">{s.price}</span>
            </li>
          ))}
        </ul>
      </section>

      <!-- Testimonials slider -->
      <section class="quotes" aria-label="Client reviews">
        <div class="quotes__inner">
          <div class="quotes__head reveal">
            <span class="stars" aria-label="5 out of 5 stars">★★★★★</span>
            <p class="eyebrow">What clients say</p>
          </div>
          <div class="slider" id="slider">
            <div class="slider__track" id="slidetrack">
              {testimonials.map((t) => (
                <blockquote class="slide">
                  <p>“{t.quote}”</p>
                  <cite>— {t.who}</cite>
                </blockquote>
              ))}
            </div>
            <div class="slider__dots" id="dots" role="tablist" aria-label="Reviews">
              {testimonials.map((_, i) => (
                <button class={`dot ${i === 0 ? "is-active" : ""}`} data-i={i} aria-label={`Review ${i + 1}`}></button>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- FAQ accordion -->
      <section class="faq">
        <div class="section-head reveal">
          <p class="eyebrow">Before you book</p>
          <h2>Good to know</h2>
        </div>
        <div class="faq__list">
          {faqs.map((f, i) => (
            <details class="faq__item reveal" open={i === 0}>
              <summary>{f.q}<span class="faq__plus" aria-hidden="true"></span></summary>
              <p>{f.a}</p>
            </details>
          ))}
        </div>
      </section>

      <!-- Visit / NAP + booking CTA -->
      <section class="visit" id="visit">
        <div class="visit__card reveal" id="book">
          <p class="eyebrow">Book & visit</p>
          <h2>Request a consultation</h2>
          <p class="visit__lede">
            Tell us roughly what you're thinking. We'll reply within two business
            days to confirm an artist, a date, and your $80 deposit.
          </p>
          <div class="nap">
            <p>
              <strong>Ironwood Tattoo Co.</strong><br />
              1242 9th Avenue SE<br />
              Inglewood, Calgary, AB T2G 0T2
            </p>
            <p>
              <a href="tel:+14035550148">(403) 555-0148</a><br />
              <a href="mailto:ink@ironwoodtattoo.ca">ink@ironwoodtattoo.ca</a><br />
              <a href="https://instagram.com/ironwoodtattooyyc">@ironwoodtattooyyc</a>
            </p>
          </div>
          <div class="visit__actions">
            <a class="btn btn--solid" href="tel:+14035550148">Call the studio</a>
            <a class="btn btn--ghost" href="https://maps.google.com/?q=1242+9th+Avenue+SE+Calgary">Open map</a>
          </div>
        </div>
        <div class="visit__hours reveal">
          <h3>Studio hours</h3>
          <dl class="hourlist">
            {hours.map((h) => (
              <div class="hourlist__row">
                <dt>{h.day}</dt>
                <dd>{h.time}</dd>
              </div>
            ))}
          </dl>
          <div class="visit__map">
            <img
              src="https://picsum.photos/seed/ironwood-map/640/360?grayscale"
              alt="Map area showing Ironwood Tattoo Co. in Inglewood, Calgary"
              loading="lazy"
              width="640"
              height="360"
            />
            <span class="visit__pin" aria-hidden="true"></span>
          </div>
        </div>
      </section>
    </main>

    <footer class="foot">
      <div class="foot__top">
        <span class="brand__name">Ironwood</span>
        <p>Permanent art, made to last — Inglewood, Calgary.</p>
      </div>
      <div class="foot__meta">
        <span>© 2026 Ironwood Tattoo Co.</span>
        <span>18+ · valid photo ID required</span>
      </div>
    </footer>

    <script>
      // Mobile nav
      const toggle = document.getElementById("navToggle");
      const drawer = document.getElementById("drawer");
      toggle?.addEventListener("click", () => {
        const open = drawer.classList.toggle("is-open");
        toggle.setAttribute("aria-expanded", String(open));
      });
      drawer?.querySelectorAll("a").forEach((a) =>
        a.addEventListener("click", () => {
          drawer.classList.remove("is-open");
          toggle?.setAttribute("aria-expanded", "false");
        })
      );

      // Scroll reveal
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const items = document.querySelectorAll(".reveal");
      if (reduce || !("IntersectionObserver" in window)) {
        items.forEach((el) => el.classList.add("in"));
      } else {
        const io = new IntersectionObserver(
          (entries) => entries.forEach((e) => e.isIntersecting && (e.target.classList.add("in"), io.unobserve(e.target))),
          { threshold: 0.14 }
        );
        items.forEach((el) => io.observe(el));
      }

      // Testimonial slider
      const track = document.getElementById("slidetrack");
      const dots = Array.from(document.querySelectorAll("#dots .dot"));
      let idx = 0;
      const go = (i) => {
        idx = (i + dots.length) % dots.length;
        if (track) track.style.transform = `translateX(-${idx * 100}%)`;
        dots.forEach((d, di) => d.classList.toggle("is-active", di === idx));
      };
      dots.forEach((d) => d.addEventListener("click", () => go(Number(d.dataset.i))));
      if (dots.length && !reduce) setInterval(() => go(idx + 1), 5500);
    </script>

    <style is:global>
      *, *::before, *::after { box-sizing: border-box; }
      html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
      @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
        *, *::before, *::after { animation-duration: 0.001ms !important; transition-duration: 0.001ms !important; }
      }
      body { margin: 0; }
      img { display: block; max-width: 100%; }
    </style>

    <style>
      :root {
        --bg: #faf8f5;
        --fg: #1f1d1b;
        --primary: #a8907a;
        --primary-fg: #faf8f5;
        --accent: #8d9b88;
        --muted: #efe9e2;
        --border: #ddd5cb;
        --display: "Cormorant Garamond", Georgia, serif;
        --body: "Jost", system-ui, sans-serif;
        --wrap: 1180px;
        --shadow: 0 24px 60px -32px rgba(31, 29, 27, 0.4);
      }

      body {
        background: var(--bg);
        color: var(--fg);
        font-family: var(--body);
        font-weight: 300;
        line-height: 1.65;
        letter-spacing: 0.01em;
        -webkit-font-smoothing: antialiased;
      }

      h1, h2, h3 { font-family: var(--display); font-weight: 500; line-height: 1.04; margin: 0; letter-spacing: 0.01em; }
      h2 { font-size: clamp(2rem, 4.4vw, 3.2rem); }
      em { font-style: italic; color: var(--primary); }
      a { color: inherit; }

      .skip {
        position: absolute; left: -999px; top: 0; z-index: 200;
        background: var(--fg); color: var(--bg); padding: 0.7rem 1.1rem;
      }
      .skip:focus { left: 0.75rem; top: 0.75rem; }

      .eyebrow {
        font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.32em;
        color: var(--primary); margin: 0 0 1rem; font-weight: 400;
      }

      :where(a, button, summary):focus-visible {
        outline: 2px solid var(--accent); outline-offset: 3px; border-radius: 2px;
      }

      /* ---- Booking bar ---- */
      .bookbar {
        position: sticky; top: 0; z-index: 90;
        display: flex; align-items: center; justify-content: center; gap: 1.2rem;
        background: var(--fg); color: var(--bg);
        font-size: 0.74rem; letter-spacing: 0.14em; text-transform: uppercase;
        padding: 0.55rem 1rem; text-align: center;
      }
      .bookbar__txt { opacity: 0.82; }
      .bookbar__cta {
        text-decoration: none; border: 1px solid rgba(250,248,245,0.5);
        padding: 0.35rem 0.9rem; border-radius: 999px; white-space: nowrap;
        transition: background 0.3s, color 0.3s;
      }
      .bookbar__cta:hover { background: var(--bg); color: var(--fg); }
      @media (max-width: 620px) { .bookbar__txt { display: none; } }

      /* ---- Nav ---- */
      .nav {
        position: sticky; top: 38px; z-index: 80;
        display: flex; align-items: center; gap: 1.5rem;
        max-width: var(--wrap); margin: 0 auto; padding: 1.1rem 1.5rem;
        backdrop-filter: blur(8px);
      }
      .brand { display: inline-flex; align-items: center; gap: 0.6rem; text-decoration: none; color: var(--fg); }
      .brand__mark { color: var(--primary); display: inline-flex; }
      .brand__name { font-family: var(--display); font-size: 1.5rem; letter-spacing: 0.04em; }
      .nav__links { margin-left: auto; display: flex; gap: 1.9rem; }
      .nav__links a {
        text-decoration: none; font-size: 0.82rem; letter-spacing: 0.16em;
        text-transform: uppercase; color: var(--fg); opacity: 0.7;
        position: relative; padding: 0.4rem 0; transition: opacity 0.25s;
      }
      .nav__links a::after {
        content: ""; position: absolute; left: 0; bottom: 0; height: 1px; width: 0;
        background: var(--primary); transition: width 0.3s;
      }
      .nav__links a:hover { opacity: 1; }
      .nav__links a:hover::after { width: 100%; }
      .nav__cta {
        text-decoration: none; font-size: 0.78rem; letter-spacing: 0.16em;
        text-transform: uppercase; padding: 0.6rem 1.3rem; border-radius: 999px;
        background: var(--primary); color: var(--primary-fg);
        transition: transform 0.25s, background 0.25s;
      }
      .nav__cta:hover { background: var(--fg); transform: translateY(-1px); }
      .nav__toggle { display: none; }

      .drawer {
        position: fixed; inset: 0 0 auto 0; top: 0; z-index: 95;
        background: var(--bg); border-bottom: 1px solid var(--border);
        flex-direction: column; padding: 5rem 1.5rem 2rem; gap: 0.4rem;
        transform: translateY(-110%); transition: transform 0.4s ease; display: flex;
      }
      .drawer.is-open { transform: translateY(0); }
      .drawer a {
        text-decoration: none; font-family: var(--display); font-size: 1.8rem;
        padding: 0.5rem 0; border-bottom: 1px solid var(--border); color: var(--fg);
      }
      .drawer__cta {
        margin-top: 1rem; border: none !important; color: var(--primary) !important;
      }

      /* ---- Layout primitives ---- */
      main { display: block; }
      section { max-width: var(--wrap); margin: 0 auto; padding: clamp(4rem, 9vw, 7.5rem) 1.5rem; }
      .section-head { max-width: 38rem; margin-bottom: clamp(2rem, 5vw, 3.5rem); }
      .section-head__sub { color: color-mix(in oklab, var(--fg) 60%, transparent); margin: 0.8rem 0 0; max-width: 34rem; }

      .btn {
        display: inline-flex; align-items: center; justify-content: center;
        min-height: 48px; padding: 0 1.7rem; border-radius: 999px;
        font-size: 0.8rem; letter-spacing: 0.16em; text-transform: uppercase;
        text-decoration: none; transition: transform 0.25s, background 0.25s, color 0.25s, border-color 0.25s;
      }
      .btn--solid { background: var(--primary); color: var(--primary-fg); }
      .btn--solid:hover { background: var(--fg); transform: translateY(-2px); }
      .btn--ghost { border: 1px solid var(--border); color: var(--fg); }
      .btn--ghost:hover { border-color: var(--primary); color: var(--primary); transform: translateY(-2px); }

      /* ---- Reveal ---- */
      .reveal { opacity: 0; transform: translateY(22px); transition: opacity 0.7s ease, transform 0.7s ease; }
      .reveal.in { opacity: 1; transform: none; }

      /* ---- Hero ---- */
      .hero {
        display: grid; grid-template-columns: 1.05fr 0.95fr; gap: clamp(2rem, 5vw, 4.5rem);
        align-items: center; padding-top: clamp(2.5rem, 6vw, 4.5rem);
      }
      .hero h1 { font-size: clamp(2.9rem, 8vw, 5.6rem); margin: 0.4rem 0 1.3rem; }
      .hero__lede { font-size: 1.1rem; max-width: 30rem; color: color-mix(in oklab, var(--fg) 72%, transparent); }
      .hero__actions { display: flex; flex-wrap: wrap; gap: 0.8rem; margin-top: 2rem; }
      .hero__art { position: relative; }
      .hero__frame {
        border: 1px solid var(--border); padding: 0.7rem; border-radius: 4px;
        background: var(--bg); box-shadow: var(--shadow);
      }
      .hero__frame img {
        width: 100%; aspect-ratio: 4 / 5; object-fit: cover; border-radius: 2px;
        filter: saturate(0.9) contrast(1.02);
      }
      .hero__tag {
        position: absolute; bottom: 1.2rem; left: -0.6rem;
        background: var(--bg); border: 1px solid var(--border);
        font-size: 0.66rem; letter-spacing: 0.22em; text-transform: uppercase;
        padding: 0.5rem 0.9rem; color: var(--primary);
      }

      /* ---- Marquee ---- */
      .marquee { overflow: hidden; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); background: var(--muted); }
      .marquee__track {
        display: flex; gap: 1.6rem; white-space: nowrap; width: max-content;
        padding: 0.9rem 0; animation: scroll 26s linear infinite;
      }
      .marquee__track span {
        font-family: var(--display); font-style: italic; font-size: 1.45rem; color: var(--fg); opacity: 0.65;
      }
      @keyframes scroll { to { transform: translateX(-50%); } }
      @media (prefers-reduced-motion: reduce) { .marquee__track { animation: none; } }

      /* ---- About / stats ---- */
      .about { display: grid; grid-template-columns: 1.2fr 1fr; gap: clamp(2rem, 5vw, 4rem); align-items: center; }
      .about__intro p { color: color-mix(in oklab, var(--fg) 68%, transparent); margin: 1.2rem 0 0; }
      .stats { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; margin: 0; background: var(--border); border: 1px solid var(--border); }
      .stats__item { background: var(--bg); padding: 1.6rem 1.4rem; }
      .stats__item dt { font-family: var(--display); font-size: clamp(2.4rem, 5vw, 3.4rem); color: var(--primary); line-height: 1; }
      .stats__item dd { margin: 0.5rem 0 0; font-size: 0.78rem; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.7; }

      /* ---- Gallery bento ---- */
      .bento {
        display: grid; grid-template-columns: repeat(4, 1fr); grid-auto-rows: 230px; gap: 1rem;
      }
      .bento__cell { margin: 0; position: relative; overflow: hidden; border-radius: 3px; border: 1px solid var(--border); }
      .bento__cell img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.7s ease; }
      .bento__cell:hover img { transform: scale(1.05); }
      .bento__cell.tall { grid-row: span 2; }
      .bento__cell.wide { grid-column: span 2; }
      .bento__cell figcaption {
        position: absolute; left: 0.8rem; bottom: 0.8rem;
        background: var(--bg); color: var(--fg);
        font-size: 0.64rem; letter-spacing: 0.18em; text-transform: uppercase;
        padding: 0.35rem 0.7rem; opacity: 0; transform: translateY(6px); transition: opacity 0.3s, transform 0.3s;
      }
      .bento__cell:hover figcaption { opacity: 1; transform: none; }

      /* ---- Artists ---- */
      .artist-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
      .artist { border: 1px solid var(--border); border-radius: 3px; overflow: hidden; background: var(--bg); transition: box-shadow 0.4s, transform 0.4s; }
      .artist:hover { box-shadow: var(--shadow); transform: translateY(-4px); }
      .artist__photo { overflow: hidden; }
      .artist__photo img { width: 100%; aspect-ratio: 13 / 16; object-fit: cover; filter: grayscale(1) contrast(1.03); transition: transform 0.7s, filter 0.5s; }
      .artist:hover .artist__photo img { transform: scale(1.04); filter: grayscale(0.3); }
      .artist__body { padding: 1.4rem 1.4rem 1.6rem; }
      .artist__body h3 { font-size: 1.7rem; }
      .artist__focus { font-size: 0.74rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent); margin: 0.4rem 0 1rem; }
      .artist__link { text-decoration: none; font-size: 0.78rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--primary); transition: letter-spacing 0.3s; }
      .artist__link:hover { letter-spacing: 0.16em; }

      /* ---- Rates ---- */
      .rate-list { list-style: none; margin: 0; padding: 0; border-top: 1px solid var(--border); }
      .rate {
        display: flex; align-items: baseline; justify-content: space-between; gap: 1rem;
        padding: 1.3rem 0.3rem; border-bottom: 1px solid var(--border); transition: padding-left 0.3s, background 0.3s;
      }
      .rate:hover { padding-left: 1rem; background: var(--muted); }
      .rate__name { font-family: var(--display); font-size: 1.45rem; }
      .rate__note { display: block; font-size: 0.74rem; letter-spacing: 0.06em; opacity: 0.6; margin-top: 0.15rem; }
      .rate__price { font-size: 0.82rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--primary); white-space: nowrap; }

      /* ---- Quotes slider ---- */
      .quotes { max-width: none; background: var(--muted); padding: 0; }
      .quotes__inner { max-width: var(--wrap); margin: 0 auto; padding: clamp(4rem, 8vw, 6.5rem) 1.5rem; }
      .quotes__head { text-align: center; margin-bottom: 2.5rem; }
      .stars { color: var(--primary); font-size: 1.3rem; letter-spacing: 0.3rem; display: block; margin-bottom: 1rem; }
      .slider { overflow: hidden; }
      .slider__track { display: flex; transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1); }
      .slide { flex: 0 0 100%; margin: 0; padding: 0 clamp(0.5rem, 6vw, 4rem); text-align: center; }
      .slide p { font-family: var(--display); font-style: italic; font-size: clamp(1.5rem, 3.6vw, 2.4rem); line-height: 1.3; margin: 0; }
      .slide cite { display: block; margin-top: 1.5rem; font-style: normal; font-size: 0.78rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent); }
      .slider__dots { display: flex; gap: 0.6rem; justify-content: center; margin-top: 2.5rem; }
      .dot { width: 9px; height: 9px; border-radius: 50%; border: 1px solid var(--primary); background: transparent; cursor: pointer; padding: 0; transition: background 0.3s, transform 0.3s; }
      .dot.is-active { background: var(--primary); transform: scale(1.2); }

      /* ---- FAQ ---- */
      .faq__list { border-top: 1px solid var(--border); }
      .faq__item { border-bottom: 1px solid var(--border); }
      .faq__item summary {
        list-style: none; cursor: pointer; display: flex; align-items: center; justify-content: space-between;
        gap: 1rem; padding: 1.4rem 0.2rem; font-family: var(--display); font-size: clamp(1.3rem, 2.6vw, 1.7rem);
      }
      .faq__item summary::-webkit-details-marker { display: none; }
      .faq__plus { position: relative; width: 16px; height: 16px; flex: none; }
      .faq__plus::before, .faq__plus::after {
        content: ""; position: absolute; background: var(--primary); transition: transform 0.3s;
        top: 50%; left: 0; width: 16px; height: 1.5px; transform: translateY(-50%);
      }
      .faq__plus::after { transform: translateY(-50%) rotate(90deg); }
      .faq__item[open] .faq__plus::after { transform: translateY(-50%) rotate(0); }
      .faq__item p { margin: 0 0 1.4rem; max-width: 46rem; color: color-mix(in oklab, var(--fg) 70%, transparent); }

      /* ---- Visit ---- */
      .visit { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: clamp(1.5rem, 4vw, 3rem); align-items: start; }
      .visit__card { background: var(--fg); color: var(--bg); padding: clamp(2rem, 5vw, 3.5rem); border-radius: 4px; }
      .visit__card .eyebrow { color: var(--primary); }
      .visit__card h2 { color: var(--bg); }
      .visit__lede { color: rgba(250, 248, 245, 0.78); margin: 1.2rem 0 2rem; }
      .nap { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; border-top: 1px solid rgba(250,248,245,0.18); padding-top: 1.6rem; }
      .nap p { margin: 0; font-size: 0.95rem; line-height: 1.8; }
      .nap a { color: var(--primary); text-decoration: none; transition: color 0.25s; }
      .nap a:hover { color: var(--bg); }
      .visit__actions { display: flex; flex-wrap: wrap; gap: 0.8rem; margin-top: 2rem; }
      .visit__card .btn--ghost { border-color: rgba(250,248,245,0.4); color: var(--bg); }
      .visit__card .btn--ghost:hover { border-color: var(--primary); color: var(--primary); }

      .visit__hours h3 { font-size: 1.6rem; margin-bottom: 1.2rem; }
      .hourlist { margin: 0 0 1.8rem; }
      .hourlist__row { display: flex; justify-content: space-between; padding: 0.7rem 0; border-bottom: 1px solid var(--border); font-size: 0.95rem; }
      .hourlist__row dt { opacity: 0.7; }
      .hourlist__row dd { margin: 0; color: var(--primary); }
      .visit__map { position: relative; border: 1px solid var(--border); border-radius: 3px; overflow: hidden; }
      .visit__map img { width: 100%; aspect-ratio: 16 / 9; object-fit: cover; filter: sepia(0.18) contrast(0.95); }
      .visit__pin {
        position: absolute; top: 50%; left: 50%; width: 14px; height: 14px; border-radius: 50% 50% 50% 0;
        background: var(--primary); transform: translate(-50%, -100%) rotate(-45deg);
        box-shadow: 0 0 0 6px color-mix(in oklab, var(--primary) 30%, transparent);
      }

      /* ---- Footer ---- */
      .foot { max-width: var(--wrap); margin: 0 auto; padding: 3rem 1.5rem 3.5rem; border-top: 1px solid var(--border); }
      .foot__top { display: flex; align-items: baseline; gap: 1.2rem; flex-wrap: wrap; }
      .foot__top .brand__name { font-size: 1.8rem; }
      .foot__top p { margin: 0; opacity: 0.7; font-style: italic; font-family: var(--display); font-size: 1.1rem; }
      .foot__meta { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem; margin-top: 2rem; font-size: 0.76rem; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.6; }

      /* ---- Responsive ---- */
      @media (max-width: 900px) {
        .nav__links, .nav__cta { display: none; }
        .nav__toggle {
          display: inline-flex; flex-direction: column; gap: 5px; margin-left: auto;
          background: none; border: none; cursor: pointer; padding: 0.5rem; min-height: 44px; min-width: 44px; align-items: center; justify-content: center;
        }
        .nav__toggle span { width: 24px; height: 1.5px; background: var(--fg); transition: transform 0.3s; }
        .nav__toggle[aria-expanded="true"] span:first-child { transform: translateY(3.5px) rotate(45deg); }
        .nav__toggle[aria-expanded="true"] span:last-child { transform: translateY(-3px) rotate(-45deg); }
        .hero { grid-template-columns: 1fr; }
        .about { grid-template-columns: 1fr; }
        .bento { grid-template-columns: repeat(2, 1fr); grid-auto-rows: 200px; }
        .bento__cell.wide { grid-column: span 2; }
        .artist-grid { grid-template-columns: 1fr 1fr; }
        .visit { grid-template-columns: 1fr; }
      }
      @media (max-width: 560px) {
        .nav { top: 0; }
        .bookbar { position: static; }
        .artist-grid { grid-template-columns: 1fr; }
        .bento { grid-template-columns: 1fr 1fr; grid-auto-rows: 160px; }
        .stats { grid-template-columns: 1fr 1fr; }
        .nap { grid-template-columns: 1fr; }
        .rate { flex-direction: column; gap: 0.3rem; }
      }
    </style>
  </body>
</html>
