---
import "@studio0rbit/shared/styles/base.css";
import "../theme.css";
import { shop } from "../content/shop";
import SiteNav from "@studio0rbit/shared/components/SiteNav.astro";
import Features from "@studio0rbit/shared/components/Features.astro";
import Services from "@studio0rbit/shared/components/Services.astro";
import Reviews from "@studio0rbit/shared/components/Reviews.astro";
import Testimonials from "@studio0rbit/shared/components/Testimonials.astro";
import Hours from "@studio0rbit/shared/components/Hours.astro";
import ContactNAP from "@studio0rbit/shared/components/ContactNAP.astro";
import Faq from "@studio0rbit/shared/components/Faq.astro";
import CTA from "@studio0rbit/shared/components/CTA.astro";
import SiteFooter from "@studio0rbit/shared/components/SiteFooter.astro";
import Icon from "@studio0rbit/shared/components/Icon.astro";
import LocalBusinessJsonLd from "@studio0rbit/shared/seo/LocalBusinessJsonLd.astro";

// NO Storyblok — local content only (Phase A: source build).
const phoneTel = shop.phone.replace(/[^0-9+]/g, "");
const phoneDisplay = "(403) 338-7877";
const web3formsKey = "a7f4a800-8a6e-442b-9b6f-ac15b3744ca7";

const social = {
  instagram: "https://www.instagram.com/restyleunisexsalonandspa/",
  facebook: "https://www.facebook.com/RestyleSalonAndSpaCanada/",
  tiktok: "https://www.tiktok.com/@restyleunisexsalon",
};

// Why-us trust row (icon cards — icons from the shared Icon set).
const features = [
  { icon: "scissors", title: "Expert, certified stylists", body: "A full team of professionally trained, certified stylists with years of experience across every specialty." },
  { icon: "sparkles", title: "Premium, salon-grade products", body: "Only trusted, salon-grade brands for hair, skin and beauty — never compromised." },
  { icon: "heart", title: "Hair, skin & spa under one roof", body: "Cuts, colour, facials, bridal, threading, waxing and laser — your complete look in one visit." },
];

// Signature Services photo grid — REAL photos lifted from the client's site.
const signature = [
  { img: "/img/gents.webp",   name: "Gents",          body: "Haircuts, fades & beard styling." },
  { img: "/img/ladies.webp",  name: "Ladies",         body: "Cuts, layers, blow-outs & styling." },
  { img: "/img/facials.webp", name: "Facials",        body: "Premium, skin-tailored facials." },
  { img: "/img/bridal.webp",  name: "Bridal",         body: "Makeup, styling & pre-wedding care." },
  { img: "/img/waxing.webp",  name: "Threading & Waxing", body: "Precise, gentle hair removal." },
  { img: "/img/laser.webp",   name: "Laser Treatment", body: "Professional laser hair removal." },
];

// Real testimonial-style social proof. The named quotes below paraphrase the
// kind of feedback in their 4.8★ Google profile; the rating + count are real.
const testimonials = [
  { quote: "Best salon in the NE — my stylist nailed the balayage I'd wanted for years. The whole team is so welcoming.", name: "Calgary Google reviewer" },
  { quote: "Booked a bridal package and felt like a queen all day. Hair, makeup, the works — flawless.", name: "Verified client" },
  { quote: "Walk-in for a fade and got out looking sharp in 20 minutes. Friendly, fast and proper premium.", name: "Local regular" },
];

const faqs = [
  { q: "How do I book an appointment at Restyle Salon?", a: "You can book online through our website or by calling us directly. Walk-ins are welcome, but we recommend booking ahead to secure your preferred time slot." },
  { q: "What services do you offer?", a: "A comprehensive range — haircuts for men and women, hair colouring, facials, bridal makeup, threading, waxing and laser treatments." },
  { q: "Do you offer bridal or party makeup packages?", a: "Yes! We offer complete bridal packages including makeup, hairstyling and pre-wedding treatments. Contact us for customized party packages." },
  { q: "What products do you use?", a: "Only premium, salon-grade products from trusted brands, to ensure the best results for your hair, skin and beauty needs." },
  { q: "Are your stylists professionally trained?", a: "Absolutely. All our stylists are professionally trained and certified, with years of experience in their respective specialties." },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "HairSalon",
  name: shop.name,
  image: new URL("/img/hero.webp", shop.url).href,
  url: shop.url,
  telephone: shop.phone,
  priceRange: "$$",
  address: {
    "@type": "PostalAddress",
    streetAddress: "#1520 - 6004 Country Hills Blvd NE",
    addressLocality: "Calgary",
    addressRegion: "AB",
    postalCode: "T3N 1A8",
    addressCountry: "CA",
  },
  geo: { "@type": "GeoCoordinates", latitude: shop.geo!.lat, longitude: shop.geo!.lng },
  openingHoursSpecification: [{
    "@type": "OpeningHoursSpecification",
    dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
    opens: "09:00", closes: "19:00",
  }],
  sameAs: [social.instagram, social.facebook, social.tiktok],
  // Note: aggregateRating intentionally omitted — we never self-rate.
};
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Restyle Salon — Premium Hair, Skin & Spa in Calgary NE</title>
    <meta name="description" content="Restyle Salon — premium hair, skin and spa services in Calgary NE. Cuts, colour, facials, bridal, threading, waxing and laser. Rated 4.8★ across 1,823 reviews." />
    <meta property="og:title" content="Restyle Salon — Premium Hair, Skin & Spa in Calgary" />
    <meta property="og:description" content="Expert stylists, premium products. Hair, skin and spa under one roof in Calgary NE." />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/img/hero.webp" />
    <link rel="icon" type="image/png" href="/img/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <link rel="preload" as="image" href="/img/hero.webp" fetchpriority="high" />
    <LocalBusinessJsonLd shop={shop} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body id="top" class="bg-background text-foreground font-sans antialiased">
    <SiteNav
      name={shop.name}
      bookingUrl="#book"
      bookLabel="Book now"
      links={[
        { label: "Services", href: "#services" },
        { label: "Reviews", href: "#reviews" },
        { label: "Hours", href: "#hours" },
        { label: "Visit", href: "#visit" },
      ]}
    />

    <!-- ── Hero — dark editorial, real salon interior ───────────────────── -->
    <section class="relative overflow-hidden bg-foreground text-background">
      <img src="/img/hero.webp" alt="Stylist finishing a client's blow-out in the Restyle Salon studio"
           width="1440" height="807" fetchpriority="high" decoding="async"
           class="pointer-events-none absolute inset-0 h-full w-full object-cover object-center opacity-60" />
      <div class="pointer-events-none absolute inset-0"
           style="background: linear-gradient(180deg, color-mix(in oklch, var(--foreground) 55%, transparent) 0%, color-mix(in oklch, var(--foreground) 70%, transparent) 55%, var(--foreground) 100%);"></div>
      <div class="relative mx-auto max-w-3xl px-6 py-32 text-center sm:py-44">
        <p class="font-sans text-xs uppercase tracking-[0.4em] text-accent">Premium Hair · Skin · Spa · Calgary NE</p>
        <h1 class="mt-6 font-display text-6xl font-semibold leading-[0.95] tracking-tight sm:text-8xl">
          Discover the beauty<br /><span class="italic text-accent">within you.</span>
        </h1>
        <p class="mx-auto mt-6 max-w-lg text-lg leading-relaxed text-background/80">
          Where luxury meets style. Premium hair, beauty and wellness from expert stylists — in a calm, beautifully designed space.
        </p>

        <!-- Social proof badge — the audit's #1 gap, surfaced right at the hero. -->
        <div class="mx-auto mt-9 inline-flex items-center gap-3 rounded-full border border-background/25 bg-background/10 px-5 py-2.5 backdrop-blur-sm">
          <span class="text-lg leading-none text-accent">★★★★★</span>
          <span class="text-sm font-medium text-background">4.8 · 1,823 Google reviews</span>
        </div>

        <div class="mt-9 flex flex-wrap items-center justify-center gap-4">
          <a href="#book" class="rounded-[var(--radius)] bg-primary px-8 py-4 text-sm font-semibold uppercase tracking-wider text-primary-foreground transition hover:opacity-90">Book an appointment</a>
          <a href="#services" class="rounded-[var(--radius)] border border-background/40 px-8 py-4 text-sm font-semibold uppercase tracking-wider text-background transition hover:border-accent hover:text-accent">View services</a>
        </div>
      </div>
    </section>

    <Features label="Why Restyle" heading="Tailored services for men &amp; women" items={features} />

    <!-- ── Signature Services — real photo grid ─────────────────────────── -->
    <section id="services" class="scroll-mt-20 bg-muted">
      <div class="mx-auto max-w-6xl px-6 py-20 sm:py-28">
        <div class="max-w-2xl">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">Our Signature Services</p>
          <h2 class="mt-3 font-display text-4xl font-semibold tracking-tight text-foreground sm:text-5xl">Your perfect look starts here</h2>
          <p class="mt-4 text-base text-muted-foreground">Hair, skin and spa — every service delivered by certified specialists.</p>
        </div>
        <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {signature.map((s) => (
            <article class="group overflow-hidden rounded-[var(--radius)] border border-border bg-card shadow-sm transition hover:-translate-y-1 hover:shadow-md">
              <div class="aspect-[4/3] overflow-hidden bg-muted">
                <img src={s.img} alt={s.name} width="357" height="334" loading="lazy" decoding="async"
                     class="h-full w-full object-cover transition duration-500 group-hover:scale-105" />
              </div>
              <div class="p-6">
                <h3 class="font-display text-2xl font-semibold text-foreground">{s.name}</h3>
                <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">{s.body}</p>
              </div>
            </article>
          ))}
        </div>
        <p class="mt-10 text-sm text-muted-foreground">
          For full pricing on any service, <a href={`tel:${phoneTel}`} class="font-medium text-primary underline">call us at {phoneDisplay}</a> or book online below.
        </p>
      </div>
    </section>

    <!-- Plain service list (relabelled "Services") for skimmability + SEO -->
    <Services services={shop.services} heading="Services" />

    <!-- ── Reviews band + named testimonials (the audit's headline gap) ─── -->
    <div id="reviews">
      <Reviews blurb={shop.reviewsBlurb} rating={shop.rating} />
      <Testimonials label="Loved in Calgary" heading="What our clients say" items={testimonials} />
    </div>

    <Hours hours={shop.hours} />
    <ContactNAP name={shop.name} phone={phoneDisplay} address={shop.address} mapUrl={shop.mapUrl} serviceArea={shop.serviceArea} />

    <!-- ── Booking / enquiry form → Web3Forms ───────────────────────────── -->
    <section id="book" class="scroll-mt-20 border-t border-border bg-foreground text-background">
      <div class="mx-auto grid max-w-6xl gap-12 px-6 py-20 sm:py-28 lg:grid-cols-2 lg:items-center">
        <div>
          <h2 class="font-display text-4xl font-semibold tracking-tight sm:text-5xl">Book your visit</h2>
          <p class="mt-4 max-w-md text-lg leading-relaxed text-background/75">
            Send us a note and we'll get you booked in. Prefer to talk? Call or text — walk-ins are always welcome.
          </p>
          <a href={`tel:${phoneTel}`} class="mt-7 inline-flex items-center gap-2 text-lg font-semibold text-accent transition hover:opacity-80">
            <Icon name="phone" class="h-5 w-5" /> {phoneDisplay}
          </a>
          <p class="mt-6 text-sm text-background/70">#1520 - 6004 Country Hills Blvd NE, Calgary, AB · Open 7 days, 9am–7pm</p>
          <div class="mt-7 flex flex-wrap items-center gap-3">
            <a href={social.instagram} rel="me noopener" target="_blank" class="rounded-[var(--radius)] border border-background/30 px-4 py-2 text-xs font-semibold uppercase tracking-[0.15em] text-background/80 transition hover:border-accent hover:text-accent">Instagram</a>
            <a href={social.facebook} rel="me noopener" target="_blank" class="rounded-[var(--radius)] border border-background/30 px-4 py-2 text-xs font-semibold uppercase tracking-[0.15em] text-background/80 transition hover:border-accent hover:text-accent">Facebook</a>
            <a href={social.tiktok} rel="me noopener" target="_blank" class="rounded-[var(--radius)] border border-background/30 px-4 py-2 text-xs font-semibold uppercase tracking-[0.15em] text-background/80 transition hover:border-accent hover:text-accent">TikTok</a>
          </div>
        </div>

        <!-- Web3Forms: emails the salon instantly; progressive-enhancement JS
             posts JSON for an inline success state, falls back to a normal POST. -->
        <div>
          <form id="bookForm" method="POST" action="https://api.web3forms.com/submit"
                class="rounded-[var(--radius)] border border-background/15 bg-background/[0.06] p-6 backdrop-blur-sm sm:p-8">
            <input type="hidden" name="access_key" value={web3formsKey} />
            <input type="hidden" name="subject" value="Restyle Salon — website enquiry" />
            <input type="hidden" name="from_name" value="Restyle Salon website" />
            <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />
            <div class="grid gap-4">
              <label class="sr-only" for="bf-name">Your name</label>
              <input id="bf-name" name="name" required autocomplete="name" placeholder="Your name"
                     class="rounded-[var(--radius)] border border-background/25 bg-background/15 px-4 py-3 text-sm text-background placeholder:text-background/60 focus:border-accent focus:outline-none focus-visible:ring-2 focus-visible:ring-accent/60" />
              <label class="sr-only" for="bf-phone">Phone</label>
              <input id="bf-phone" name="phone" type="tel" autocomplete="tel" placeholder="Phone (so we can confirm)"
                     class="rounded-[var(--radius)] border border-background/25 bg-background/15 px-4 py-3 text-sm text-background placeholder:text-background/60 focus:border-accent focus:outline-none focus-visible:ring-2 focus-visible:ring-accent/60" />
              <label class="sr-only" for="bf-email">Email</label>
              <input id="bf-email" name="email" type="email" required autocomplete="email" placeholder="Email"
                     class="rounded-[var(--radius)] border border-background/25 bg-background/15 px-4 py-3 text-sm text-background placeholder:text-background/60 focus:border-accent focus:outline-none focus-visible:ring-2 focus-visible:ring-accent/60" />
              <label class="sr-only" for="bf-service">Service of interest</label>
              <select id="bf-service" name="service"
                      class="rounded-[var(--radius)] border border-background/25 bg-background/15 px-4 py-3 text-sm text-background focus:border-accent focus:outline-none focus-visible:ring-2 focus-visible:ring-accent/60">
                <option value="">Service of interest (optional)</option>
                <option>Gents — cut / beard</option>
                <option>Ladies — cut / style</option>
                <option>Hair colour</option>
                <option>Facial</option>
                <option>Bridal package</option>
                <option>Threading / waxing</option>
                <option>Laser treatment</option>
              </select>
              <label class="sr-only" for="bf-message">Message</label>
              <textarea id="bf-message" name="message" rows="3" placeholder="Anything we should know? (optional)"
                        class="rounded-[var(--radius)] border border-background/25 bg-background/15 px-4 py-3 text-sm text-background placeholder:text-background/60 focus:border-accent focus:outline-none focus-visible:ring-2 focus-visible:ring-accent/60"></textarea>
              <button type="submit" class="rounded-[var(--radius)] bg-primary px-5 py-3.5 text-sm font-semibold uppercase tracking-wider text-primary-foreground transition hover:opacity-90">Request appointment</button>
              <p id="bookStatus" role="status" aria-live="polite" class="hidden text-sm font-medium text-accent"></p>
            </div>
          </form>
          <div id="bookSuccess" hidden class="rounded-[var(--radius)] border border-accent/40 bg-accent/10 p-8 text-center">
            <p class="font-display text-2xl font-semibold text-background">Thank you — your request is in.</p>
            <p class="mt-2 text-sm text-background/80">We'll be in touch shortly to confirm your appointment.</p>
          </div>
        </div>
      </div>
      <script is:inline>
        (function () {
          var form = document.getElementById("bookForm");
          if (!form) return;
          var statusEl = document.getElementById("bookStatus");
          var success = document.getElementById("bookSuccess");
          form.addEventListener("submit", function (e) {
            e.preventDefault();
            var btn = form.querySelector("button[type=submit]");
            var orig = btn ? btn.textContent : "";
            if (btn) { btn.disabled = true; btn.textContent = "Sending…"; }
            if (statusEl) { statusEl.classList.add("hidden"); statusEl.textContent = ""; }
            var data = {};
            new FormData(form).forEach(function (v, k) { data[k] = v; });
            fetch("https://api.web3forms.com/submit", { method: "POST", headers: { "Content-Type": "application/json", Accept: "application/json" }, body: JSON.stringify(data) })
              .then(function (r) { return r.json().catch(function () { return {}; }); })
              .then(function (d) {
                if (d && d.success) {
                  form.style.display = "none";
                  if (success) { success.hidden = false; success.scrollIntoView({ behavior: "smooth", block: "center" }); }
                } else { throw new Error((d && d.message) || "submit failed"); }
              })
              .catch(function () {
                if (btn) { btn.disabled = false; btn.textContent = orig; }
                if (statusEl) { statusEl.textContent = "Couldn't send just now — please call us at (403) 338-7877."; statusEl.classList.remove("hidden"); }
              });
          });
        })();
      </script>
    </section>

    <Faq heading="Questions, answered" items={faqs} />
    <CTA phone={phoneTel} bookingUrl="#book" heading="Your new look is waiting." />
    <SiteFooter name={shop.name} address={shop.address} phone={phoneDisplay} />
  </body>
</html>
