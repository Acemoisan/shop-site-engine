---
const nav = ["Collections", "The Edit", "Atelier", "Stockists"];
const products = [
  { name: "The Atelier Wool Overcoat", price: "$480", seed: "luxecoat", alt: "Model in tailored wool overcoat" },
  { name: "Heavyweight Boxy Tee", price: "$68", seed: "luxetee", alt: "Heavyweight cotton tee on figure" },
  { name: "Pleated Wide-Leg Trouser", price: "$165", seed: "luxetrouser", alt: "Pleated wide-leg trousers in motion" },
  { name: "Cashmere-Blend Crewneck", price: "$210", seed: "luxecrew", alt: "Cashmere crewneck knit detail" },
];
const swatches = ["#111111", "#8a7355", "#e7e2db", "#6b6b6b"];
const sizes = ["XS", "S", "M", "L", "XL"];
const editorials = [
  {
    seed: "luxeeditA", kicker: "The Fall Edit",
    head: "Cut from a Different Cloth",
    body: "A study in restraint. Tailoring drawn close to the body, fabrics chosen for the way they fall and the way they age. Nothing shouts; everything lasts.",
  },
  {
    seed: "luxeeditB", kicker: "Atelier Notes",
    head: "Made to Last",
    body: "Each garment leaves our Calgary atelier finished by hand — bound seams, horn buttons, a quiet label sewn inside. The modern wardrobe, considered.",
  },
];
const testimonials = [
  { q: "The overcoat is the best-made thing in my closet. Worth every dollar.", who: "Dana R.", city: "Calgary" },
  { q: "Finally a brand that nails fit and fabric without the logo noise.", who: "Priya S.", city: "Vancouver" },
  { q: "Copped the drop in two minutes flat. Quality is insane for the price.", who: "Marcus T.", city: "Toronto" },
];
const insta = ["ig1", "ig2", "ig3", "ig4", "ig5", "ig6"];
const stats = [
  { n: "1108", l: "17th Ave SW, Flagship" },
  { n: "30", l: "Day easy returns" },
  { n: "100%", l: "Hand-finished in Calgary" },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Meridian Atelier — Modern Wardrobe, Made to Last</title>
    <meta name="description" content="Meridian Atelier — editorial menswear and womenswear hand-finished in Calgary. Wool overcoats, cashmere knits, pleated trousers. The Fall Edit has landed." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..700&family=Inter:wght@300..600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>

    <div class="ticker" aria-hidden="true">
      <div class="ticker__track">
        <span>Free shipping over $150</span><span>·</span><span>The Fall Edit has landed</span><span>·</span><span>Easy 30-day returns</span><span>·</span><span>Hand-finished in Calgary</span><span>·</span>
        <span>Free shipping over $150</span><span>·</span><span>The Fall Edit has landed</span><span>·</span><span>Easy 30-day returns</span><span>·</span><span>Hand-finished in Calgary</span><span>·</span>
      </div>
    </div>

    <header class="nav" id="nav">
      <a class="brand" href="#main">Meridian<span>Atelier</span></a>
      <nav class="nav__links" aria-label="Primary">
        {nav.map((n) => <a href={"#" + n.toLowerCase().replace(/\s/g, "")}>{n}</a>)}
      </nav>
      <div class="nav__right">
        <a class="bag" href="#newsletter" aria-label="Open bag">Bag <span>(0)</span></a>
        <button class="burger" id="burger" aria-label="Toggle menu" aria-expanded="false"><span></span><span></span></button>
      </div>
    </header>
    <nav class="mobilemenu" id="mobilemenu" aria-label="Mobile">
      {nav.map((n) => <a href={"#" + n.toLowerCase().replace(/\s/g, "")}>{n}</a>)}
    </nav>

    <main id="main">
      <section class="hero">
        <div class="hero__img"><img src="https://picsum.photos/seed/luxehero/1600/1900?grayscale" alt="Editorial campaign — model in seasonal tailoring" /></div>
        <div class="hero__copy reveal">
          <p class="eyebrow">Fall / Winter — Edit 04</p>
          <h1>Cut from a<br /><em>Different</em> Cloth</h1>
          <p class="lede">Modern wardrobe, made to last. Tailoring and knitwear, hand-finished in Calgary.</p>
          <div class="hero__cta">
            <a class="btn btn--solid" href="#collection">Shop the Collection</a>
            <a class="btn btn--ghost" href="#edit">View the Edit</a>
          </div>
        </div>
        <div class="hero__index" aria-hidden="true"><span>01</span> / <span>The Masthead</span></div>
      </section>

      <section class="shopby" id="collections" aria-label="Shop by category">
        {["Outerwear", "Knitwear", "Trousers", "Accessories"].map((c, i) => (
          <a class="shopby__tile reveal" href="#collection" style={`--d:${i * 70}ms`}>
            <span class="shopby__no">{"0" + (i + 1)}</span>
            <span class="shopby__name">{c}</span>
            <span class="shopby__arrow">→</span>
          </a>
        ))}
      </section>

      <section class="grid" id="collection">
        <div class="grid__head reveal">
          <h2>The Fall Collection</h2>
          <p>Twelve pieces. Each made to outlast the season.</p>
        </div>
        <div class="grid__items">
          {products.map((p) => (
            <article class="card reveal">
              <a class="card__media" href="#" aria-label={p.name}>
                <img class="card__front" src={`https://picsum.photos/seed/${p.seed}/700/900?grayscale`} alt={p.alt} loading="lazy" />
                <img class="card__back" src={`https://picsum.photos/seed/${p.seed}b/700/900?grayscale`} alt="" aria-hidden="true" loading="lazy" />
                <span class="card__quick">Quick add</span>
              </a>
              <div class="card__meta">
                <h3>{p.name}</h3>
                <p class="card__price">{p.price}</p>
              </div>
              <div class="card__swatches" aria-label="Colours">
                {swatches.map((s) => <button class="dot" style={`--c:${s}`} aria-label={"Colour " + s}></button>)}
              </div>
              <div class="card__sizes" aria-label="Sizes">
                {sizes.map((s) => <button class="size">{s}</button>)}
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="edit" id="edit">
        {editorials.map((e, i) => (
          <div class={"split " + (i % 2 ? "split--rev" : "")}>
            <div class="split__img reveal"><img src={`https://picsum.photos/seed/${e.seed}/1100/1300?grayscale`} alt={e.head + " editorial image"} loading="lazy" /></div>
            <div class="split__copy reveal">
              <p class="eyebrow">{e.kicker}</p>
              <h2>{e.head}</h2>
              <p>{e.body}</p>
              <a class="link" href="#collection">Read the story →</a>
            </div>
          </div>
        ))}
      </section>

      <section class="stats" id="atelier">
        {stats.map((s) => (
          <div class="stat reveal"><span class="stat__n">{s.n}</span><span class="stat__l">{s.l}</span></div>
        ))}
      </section>

      <section class="quotes" aria-label="Customer reviews">
        <div class="quotes__rail" id="quoteRail">
          {testimonials.map((t) => (
            <figure class="quote">
              <div class="quote__stars" aria-label="5 out of 5">★★★★★</div>
              <blockquote>“{t.q}”</blockquote>
              <figcaption>{t.who} — <span>{t.city}</span></figcaption>
            </figure>
          ))}
        </div>
        <div class="quotes__dots" id="quoteDots" aria-hidden="true"></div>
      </section>

      <section class="ugc" id="stockists" aria-label="As worn by the community">
        <div class="ugc__head reveal"><h2>@meridian.atelier</h2><a class="link" href="#newsletter">Tag us to be featured →</a></div>
        <div class="ugc__mosaic">
          {insta.map((s, i) => (
            <a class={"ugc__cell ugc__cell--" + i} href="#" aria-label="Community photo">
              <img src={`https://picsum.photos/seed/${s}/600/600?grayscale`} alt="Community member wearing Meridian Atelier" loading="lazy" />
            </a>
          ))}
        </div>
      </section>

      <section class="signup" id="newsletter">
        <div class="signup__inner reveal">
          <p class="eyebrow eyebrow--light">The List</p>
          <h2>Early access to every drop, <em>and</em> 10% off your first order.</h2>
          <form class="signup__form" onsubmit="event.preventDefault(); this.querySelector('.signup__ok').hidden=false; this.querySelector('input').value='';">
            <label class="vh" for="email">Email address</label>
            <input id="email" type="email" required placeholder="you@email.com" />
            <button class="btn btn--solid" type="submit">Join</button>
            <p class="signup__ok" hidden>Welcome to the list. Check your inbox for 10% off.</p>
          </form>
          <p class="signup__fine">Mon–Fri 10–7 · Sat 11–6 · Sun 12–5 · Flagship, 1108 17th Ave SW, Calgary</p>
        </div>
      </section>
    </main>

    <footer class="foot">
      <div class="foot__grid">
        <div class="foot__brandcol">
          <a class="brand brand--lg" href="#main">Meridian<span>Atelier</span></a>
          <p>Modern wardrobe, made to last. Hand-finished in Calgary, AB.</p>
          <a class="foot__call" href="tel:+14035552174">(403) 555-2174</a>
        </div>
        <div><h4>Shop</h4><a href="#collection">Outerwear</a><a href="#collection">Knitwear</a><a href="#collection">Trousers</a><a href="#collection">Accessories</a></div>
        <div><h4>Service</h4><a href="#newsletter">Free shipping over $150</a><a href="#newsletter">30-day returns</a><a href="#newsletter">Size guide</a></div>
        <div>
          <h4>Visit</h4>
          <address>1108 17th Avenue SW<br />Calgary, AB T2T 0B6<br /><a href="tel:+14035552174">(403) 555-2174</a></address>
        </div>
      </div>
      <div class="foot__base">
        <span>© 2026 Meridian Atelier</span>
        <span class="foot__pay" aria-hidden="true">VISA · MC · AMEX · APPLE PAY</span>
      </div>
    </footer>

    <script>
      const burger = document.getElementById("burger");
      const mm = document.getElementById("mobilemenu");
      burger?.addEventListener("click", () => {
        const open = mm.classList.toggle("is-open");
        burger.setAttribute("aria-expanded", String(open));
        burger.classList.toggle("is-x", open);
      });
      mm?.querySelectorAll("a").forEach((a) =>
        a.addEventListener("click", () => {
          mm.classList.remove("is-open");
          burger.classList.remove("is-x");
          burger.setAttribute("aria-expanded", "false");
        })
      );
      const nav = document.getElementById("nav");
      addEventListener("scroll", () => nav?.classList.toggle("is-stuck", scrollY > 40), { passive: true });

      const mq = matchMedia("(prefers-reduced-motion: reduce)");
      if (!mq.matches) {
        const io = new IntersectionObserver((es) => es.forEach((e) => { if (e.isIntersecting) { e.target.classList.add("in"); io.unobserve(e.target); } }), { threshold: 0.14 });
        document.querySelectorAll(".reveal").forEach((el) => io.observe(el));
      } else {
        document.querySelectorAll(".reveal").forEach((el) => el.classList.add("in"));
      }

      // quote slider dots
      const rail = document.getElementById("quoteRail");
      const dots = document.getElementById("quoteDots");
      if (rail && dots) {
        const cards = [...rail.children];
        cards.forEach((_, i) => {
          const b = document.createElement("button");
          b.setAttribute("aria-label", "Go to review " + (i + 1));
          b.addEventListener("click", () => cards[i].scrollIntoView({ behavior: "smooth", inline: "center", block: "nearest" }));
          dots.appendChild(b);
        });
        const sync = () => {
          const mid = rail.scrollLeft + rail.clientWidth / 2;
          let best = 0, bd = Infinity;
          cards.forEach((c, i) => { const d = Math.abs(c.offsetLeft + c.clientWidth / 2 - mid); if (d < bd) { bd = d; best = i; } });
          [...dots.children].forEach((d, i) => d.classList.toggle("on", i === best));
        };
        rail.addEventListener("scroll", sync, { passive: true });
        sync();
      }
    </script>

    <style is:global>
      *, *::before, *::after { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body { margin: 0; }
      img { display: block; max-width: 100%; }
      @media (prefers-reduced-motion: reduce) { html { scroll-behavior: auto; } }
    </style>

    <style>
      :root {
        --bg: #f6f4f1; --fg: #111111; --primary: #111111; --primary-fg: #f6f4f1;
        --accent: #8a7355; --muted: #e7e2db; --border: #d8d2c9;
        --sans: "Inter", system-ui, sans-serif; --disp: "Playfair Display", Georgia, serif;
        --pad: clamp(1.25rem, 5vw, 5rem); --max: 1380px;
      }
      body { background: var(--bg); color: var(--fg); font-family: var(--sans); font-weight: 300; line-height: 1.6; -webkit-font-smoothing: antialiased; }
      h1, h2, h3, h4 { font-family: var(--disp); font-weight: 500; line-height: 1.04; margin: 0; letter-spacing: -.01em; }
      em { font-style: italic; }
      a { color: inherit; text-decoration: none; }
      :focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }
      .vh { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0); }
      .skip { position: absolute; left: -999px; top: 0; background: var(--fg); color: var(--bg); padding: .8rem 1.2rem; z-index: 200; }
      .skip:focus { left: 8px; top: 8px; }
      .eyebrow { font-size: .72rem; letter-spacing: .32em; text-transform: uppercase; color: var(--accent); margin: 0 0 1rem; }
      .eyebrow--light { color: var(--accent); }

      .reveal { opacity: 0; transform: translateY(26px); transition: opacity .8s ease, transform .8s cubic-bezier(.2,.7,.2,1); transition-delay: var(--d, 0ms); }
      .reveal.in { opacity: 1; transform: none; }

      .ticker { background: var(--fg); color: var(--bg); overflow: hidden; font-size: .7rem; letter-spacing: .26em; text-transform: uppercase; }
      .ticker__track { display: inline-flex; gap: 2rem; white-space: nowrap; padding: .7rem 0; animation: slide 32s linear infinite; }
      .ticker__track span { opacity: .85; }
      @keyframes slide { to { transform: translateX(-50%); } }
      @media (prefers-reduced-motion: reduce) { .ticker__track { animation: none; } }

      .nav { position: sticky; top: 0; z-index: 100; display: flex; align-items: center; justify-content: space-between;
        gap: 1rem; padding: 1.1rem var(--pad); background: color-mix(in srgb, var(--bg) 88%, transparent); backdrop-filter: blur(10px);
        border-bottom: 1px solid transparent; transition: border-color .3s, padding .3s; }
      .nav.is-stuck { border-color: var(--border); padding-block: .75rem; }
      .brand { font-family: var(--disp); font-size: 1.35rem; letter-spacing: .02em; display: flex; gap: .4ch; }
      .brand span { font-style: italic; color: var(--accent); }
      .brand--lg { font-size: 1.7rem; }
      .nav__links { display: none; gap: 2.2rem; font-size: .82rem; letter-spacing: .12em; text-transform: uppercase; }
      .nav__links a { position: relative; padding: .3rem 0; }
      .nav__links a::after { content: ""; position: absolute; left: 0; bottom: 0; height: 1px; width: 0; background: var(--fg); transition: width .3s; }
      .nav__links a:hover::after { width: 100%; }
      .nav__right { display: flex; align-items: center; gap: 1rem; }
      .bag { font-size: .8rem; letter-spacing: .12em; text-transform: uppercase; }
      .bag span { color: var(--accent); }
      .burger { display: grid; gap: 5px; background: none; border: 0; padding: 11px 4px; cursor: pointer; }
      .burger span { width: 24px; height: 1.5px; background: var(--fg); transition: transform .3s, opacity .3s; }
      .burger.is-x span:first-child { transform: translateY(3.3px) rotate(45deg); }
      .burger.is-x span:last-child { transform: translateY(-3.3px) rotate(-45deg); }
      .mobilemenu { display: grid; gap: 1px; background: var(--border); max-height: 0; overflow: hidden; transition: max-height .4s ease; position: sticky; top: 0; z-index: 99; }
      .mobilemenu.is-open { max-height: 60vh; }
      .mobilemenu a { background: var(--bg); padding: 1.1rem var(--pad); font-size: 1.4rem; font-family: var(--disp); }

      /* HERO */
      .hero { position: relative; min-height: 92vh; display: grid; align-items: end; overflow: hidden; }
      .hero__img { position: absolute; inset: 0; }
      .hero__img img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(1) contrast(1.04); }
      .hero__img::after { content: ""; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(17,17,17,.18), rgba(17,17,17,.62)); }
      .hero__copy { position: relative; padding: var(--pad); padding-bottom: clamp(3rem, 8vw, 6rem); color: var(--bg); max-width: 880px; }
      .hero h1 { font-size: clamp(3rem, 12vw, 8.5rem); font-weight: 500; }
      .hero h1 em { color: var(--bg); }
      .eyebrow { color: var(--accent); }
      .hero .eyebrow { color: color-mix(in srgb, var(--accent) 70%, white); }
      .lede { font-size: clamp(1rem, 2.4vw, 1.25rem); max-width: 40ch; margin: 1.4rem 0 2rem; opacity: .9; }
      .hero__cta { display: flex; flex-wrap: wrap; gap: .9rem; }
      .hero__index { position: absolute; top: clamp(1rem,4vw,2.4rem); right: var(--pad); color: var(--bg); font-size: .72rem; letter-spacing: .28em; text-transform: uppercase; opacity: .8; }
      .hero__index span:first-child { font-family: var(--disp); font-size: 1rem; }

      .btn { display: inline-flex; align-items: center; min-height: 48px; padding: 0 1.7rem; font-size: .8rem; letter-spacing: .18em; text-transform: uppercase; border: 1px solid var(--fg); transition: background .3s, color .3s, transform .2s; }
      .btn:hover { transform: translateY(-2px); }
      .btn--solid { background: var(--fg); color: var(--bg); border-color: var(--fg); }
      .btn--solid:hover { background: var(--accent); border-color: var(--accent); }
      .hero .btn--solid { background: var(--bg); color: var(--fg); border-color: var(--bg); }
      .hero .btn--solid:hover { background: var(--accent); color: var(--bg); border-color: var(--accent); }
      .btn--ghost { color: var(--bg); border-color: color-mix(in srgb, var(--bg) 60%, transparent); }
      .btn--ghost:hover { background: var(--bg); color: var(--fg); }

      /* SHOP BY */
      .shopby { display: grid; grid-template-columns: 1fr; border-top: 1px solid var(--border); }
      @media (min-width: 760px) { .shopby { grid-template-columns: repeat(4, 1fr); } }
      .shopby__tile { display: flex; align-items: center; gap: 1rem; padding: clamp(1.4rem,4vw,2.4rem) var(--pad); border-bottom: 1px solid var(--border); transition: background .3s, color .3s; }
      @media (min-width: 760px) { .shopby__tile { flex-direction: column; align-items: flex-start; gap: 2.5rem; border-bottom: 0; border-right: 1px solid var(--border); padding: 2.6rem 1.6rem; } .shopby__tile:last-child { border-right: 0; } }
      .shopby__tile:hover { background: var(--fg); color: var(--bg); }
      .shopby__no { font-size: .72rem; letter-spacing: .26em; color: var(--accent); }
      .shopby__name { font-family: var(--disp); font-size: clamp(1.3rem, 2.6vw, 1.8rem); margin-right: auto; }
      .shopby__arrow { transition: transform .3s; }
      .shopby__tile:hover .shopby__arrow { transform: translateX(6px); }

      /* GRID */
      .grid { padding: clamp(3.5rem,9vw,7rem) var(--pad); }
      .grid__head { max-width: 600px; margin-bottom: clamp(2rem,5vw,3.5rem); }
      .grid__head h2 { font-size: clamp(2rem, 5.5vw, 3.4rem); }
      .grid__head p { color: color-mix(in srgb, var(--fg) 62%, var(--bg)); margin: .8rem 0 0; }
      .grid__items { display: grid; gap: clamp(1.4rem, 3vw, 2.4rem); grid-template-columns: repeat(2, 1fr); }
      @media (min-width: 980px) { .grid__items { grid-template-columns: repeat(4, 1fr); } }
      .card__media { position: relative; display: block; aspect-ratio: 7/9; overflow: hidden; background: var(--muted); }
      .card__media img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; filter: grayscale(1); transition: opacity .6s, transform 1.2s ease; }
      .card__back { opacity: 0; }
      .card__media:hover .card__front { opacity: 0; transform: scale(1.04); }
      .card__media:hover .card__back { opacity: 1; transform: scale(1.04); }
      .card__quick { position: absolute; left: 0; right: 0; bottom: 0; text-align: center; padding: .9rem; background: var(--fg); color: var(--bg); font-size: .72rem; letter-spacing: .2em; text-transform: uppercase; transform: translateY(100%); transition: transform .35s; }
      .card__media:hover .card__quick, .card__media:focus-visible .card__quick { transform: none; }
      .card__meta { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; margin-top: 1rem; }
      .card__meta h3 { font-size: 1rem; font-family: var(--sans); font-weight: 400; letter-spacing: .01em; }
      .card__price { font-family: var(--disp); font-style: italic; color: var(--accent); margin: 0; }
      .card__swatches { display: flex; gap: .5rem; margin-top: .7rem; }
      .dot { width: 18px; height: 18px; border-radius: 50%; border: 1px solid var(--border); background: var(--c); cursor: pointer; padding: 0; transition: transform .2s; }
      .dot:hover { transform: scale(1.18); }
      .card__sizes { display: flex; flex-wrap: wrap; gap: .35rem; margin-top: .7rem; }
      .size { min-width: 38px; min-height: 38px; border: 1px solid var(--border); background: none; font: inherit; font-size: .72rem; letter-spacing: .05em; cursor: pointer; transition: background .2s, color .2s, border-color .2s; }
      .size:hover { background: var(--fg); color: var(--bg); border-color: var(--fg); }

      /* EDITORIAL SPLITS */
      .edit { display: grid; }
      .split { display: grid; grid-template-columns: 1fr; }
      @media (min-width: 880px) { .split { grid-template-columns: 1fr 1fr; } .split--rev .split__img { order: 2; } }
      .split__img { overflow: hidden; aspect-ratio: 4/5; }
      @media (min-width: 880px) { .split__img { aspect-ratio: auto; min-height: 78vh; } }
      .split__img img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(1) contrast(1.03); transition: transform 1.4s ease; }
      .split:hover .split__img img { transform: scale(1.05); }
      .split__copy { display: flex; flex-direction: column; align-items: flex-start; justify-content: center; gap: 1.1rem; padding: clamp(2.5rem,7vw,6rem) var(--pad); }
      .split--rev .split__copy { background: var(--fg); color: var(--bg); }
      .split--rev .eyebrow { color: color-mix(in srgb, var(--accent) 75%, white); }
      .split__copy h2 { font-size: clamp(2rem, 5vw, 3.6rem); }
      .split__copy p { max-width: 42ch; margin: 0; opacity: .82; }
      .link { font-size: .8rem; letter-spacing: .16em; text-transform: uppercase; border-bottom: 1px solid currentColor; padding-bottom: 3px; transition: gap .2s, opacity .2s; }
      .link:hover { opacity: .65; }

      /* STATS */
      .stats { display: grid; grid-template-columns: 1fr; gap: 1px; background: var(--border); border-block: 1px solid var(--border); }
      @media (min-width: 720px) { .stats { grid-template-columns: repeat(3, 1fr); } }
      .stat { background: var(--bg); padding: clamp(2.4rem,6vw,4rem) var(--pad); display: grid; gap: .6rem; text-align: center; }
      .stat__n { font-family: var(--disp); font-size: clamp(2.6rem, 7vw, 4.6rem); line-height: 1; }
      .stat__l { font-size: .76rem; letter-spacing: .2em; text-transform: uppercase; color: var(--accent); }

      /* QUOTES SLIDER */
      .quotes { padding: clamp(3rem,8vw,6rem) 0; }
      .quotes__rail { display: flex; gap: clamp(1rem,3vw,2rem); overflow-x: auto; scroll-snap-type: x mandatory; padding: 0 var(--pad); scrollbar-width: none; }
      .quotes__rail::-webkit-scrollbar { display: none; }
      .quote { scroll-snap-align: center; flex: 0 0 min(86vw, 520px); margin: 0; padding: clamp(1.8rem,4vw,3rem); border: 1px solid var(--border); display: grid; gap: 1.2rem; background: var(--bg); }
      .quote__stars { color: var(--accent); letter-spacing: .25em; font-size: .9rem; }
      .quote blockquote { margin: 0; font-family: var(--disp); font-size: clamp(1.3rem, 3vw, 1.95rem); line-height: 1.25; }
      .quote figcaption { font-size: .78rem; letter-spacing: .12em; text-transform: uppercase; }
      .quote figcaption span { color: var(--accent); }
      .quotes__dots { display: flex; justify-content: center; gap: .5rem; margin-top: 2rem; }
      .quotes__dots button { width: 8px; height: 8px; border-radius: 50%; border: 1px solid var(--accent); background: none; padding: 0; cursor: pointer; transition: background .3s, transform .3s; }
      .quotes__dots button.on { background: var(--accent); transform: scale(1.3); }

      /* UGC MOSAIC */
      .ugc { padding: clamp(2.5rem,6vw,5rem) var(--pad) clamp(3.5rem,8vw,7rem); }
      .ugc__head { display: flex; flex-wrap: wrap; gap: 1rem; align-items: baseline; justify-content: space-between; margin-bottom: 2rem; }
      .ugc__head h2 { font-size: clamp(1.6rem,4vw,2.6rem); }
      .ugc__mosaic { display: grid; grid-template-columns: repeat(2, 1fr); gap: clamp(.4rem,1.5vw,1rem); }
      @media (min-width: 720px) { .ugc__mosaic { grid-template-columns: repeat(4, 1fr); grid-auto-rows: 1fr; } .ugc__cell--0 { grid-column: span 2; grid-row: span 2; } .ugc__cell--3 { grid-row: span 2; } }
      .ugc__cell { overflow: hidden; aspect-ratio: 1; position: relative; }
      .ugc__cell img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(1); transition: transform .8s, filter .5s; }
      .ugc__cell:hover img { transform: scale(1.07); filter: grayscale(.2); }
      .ugc__cell::after { content: "↗"; position: absolute; inset: auto 0 0 auto; padding: .6rem .8rem; color: var(--bg); opacity: 0; transition: opacity .3s; }
      .ugc__cell:hover::after { opacity: 1; }

      /* SIGNUP */
      .signup { background: var(--fg); color: var(--bg); padding: clamp(3.5rem,9vw,7rem) var(--pad); }
      .signup__inner { max-width: 760px; margin: 0 auto; text-align: center; }
      .signup h2 { font-size: clamp(1.8rem, 5vw, 3.2rem); margin: .4rem 0 2rem; }
      .signup h2 em { color: color-mix(in srgb, var(--accent) 80%, white); }
      .signup__inner .eyebrow { color: color-mix(in srgb, var(--accent) 75%, white); }
      .signup__form { display: flex; flex-wrap: wrap; gap: .6rem; justify-content: center; }
      .signup__form input { flex: 1 1 280px; min-height: 48px; padding: 0 1.2rem; background: transparent; border: 1px solid color-mix(in srgb, var(--bg) 40%, transparent); color: var(--bg); font: inherit; }
      .signup__form input::placeholder { color: color-mix(in srgb, var(--bg) 55%, transparent); }
      .signup .btn--solid { background: var(--bg); color: var(--fg); border-color: var(--bg); }
      .signup .btn--solid:hover { background: var(--accent); color: var(--bg); border-color: var(--accent); }
      .signup__ok { flex-basis: 100%; margin: .4rem 0 0; color: color-mix(in srgb, var(--accent) 80%, white); font-size: .85rem; letter-spacing: .04em; }
      .signup__fine { margin-top: 2rem; font-size: .74rem; letter-spacing: .16em; text-transform: uppercase; opacity: .6; }

      /* FOOTER */
      .foot { padding: clamp(3rem,7vw,5rem) var(--pad) 2rem; border-top: 1px solid var(--border); }
      .foot__grid { display: grid; gap: 2.5rem; grid-template-columns: 1fr; }
      @media (min-width: 760px) { .foot__grid { grid-template-columns: 1.6fr 1fr 1fr 1fr; gap: 2rem; } }
      .foot__brandcol p { max-width: 30ch; color: color-mix(in srgb, var(--fg) 60%, var(--bg)); margin: 1rem 0; }
      .foot__call { font-family: var(--disp); font-style: italic; font-size: 1.4rem; }
      .foot h4 { font-family: var(--sans); font-size: .74rem; letter-spacing: .22em; text-transform: uppercase; color: var(--accent); margin-bottom: 1rem; font-weight: 500; }
      .foot__grid a { display: block; padding: .3rem 0; font-size: .92rem; color: color-mix(in srgb, var(--fg) 75%, var(--bg)); transition: color .2s; }
      .foot__grid a:hover { color: var(--fg); }
      .foot address { font-style: normal; font-size: .92rem; line-height: 1.9; color: color-mix(in srgb, var(--fg) 75%, var(--bg)); }
      .foot__base { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: space-between; margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--border); font-size: .72rem; letter-spacing: .18em; text-transform: uppercase; color: color-mix(in srgb, var(--fg) 55%, var(--bg)); }

      @media (min-width: 880px) { .nav__links { display: flex; } .burger { display: none; } }
    </style>
  </body>
</html>
