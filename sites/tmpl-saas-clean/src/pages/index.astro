---
const nav = [
  { label: "Features", href: "#features" },
  { label: "Product tour", href: "#tour" },
  { label: "Customers", href: "#proof" },
  { label: "Pricing", href: "#pricing" },
];

const logos = ["Northbeam", "Lumen Labs", "Cadence", "Foundry", "Brightwave", "Helio"];

const features = [
  {
    title: "Connect every tool",
    body: "50+ native integrations. Wire Slack, Jira, GitHub and your warehouse into one tidy flow — no glue code.",
    span: "wide",
    accent: false,
  },
  {
    title: "No-code builder",
    body: "Drag, drop, ship. Build automations a teammate can read.",
    span: "tall",
    accent: true,
  },
  { title: "Single source of truth", body: "Every handoff logged. Nothing falls between teams.", span: "", accent: false },
  { title: "API-deep", body: "Go as far as your platform team wants. Fully typed SDK.", span: "", accent: false },
  {
    title: "Smart suggestions",
    body: "Driftwork learns your patterns and proposes the next automation before you ask.",
    span: "wide",
    accent: false,
  },
];

const tour = [
  {
    tab: "Triggers",
    heading: "Start from anything",
    body: "A new ticket, a pushed commit, a customer reply — pick a trigger and Driftwork watches it for you, 24/7.",
    seed: "drifttrigger",
  },
  {
    tab: "Logic",
    heading: "Branch without code",
    body: "Visual if/then steps with live previews. Map the messy real-world path your team already follows.",
    seed: "driftlogic",
  },
  {
    tab: "Handoff",
    heading: "Land it in the right place",
    body: "Route the result to the team, channel, or system that needs it — with a full audit trail attached.",
    seed: "drifthandoff",
  },
];

const metrics = [
  { n: "12,000+", l: "teams onboarded" },
  { n: "4.2M", l: "workflows run daily" },
  { n: "99.99%", l: "uptime SLA" },
  { n: "11 hrs", l: "saved / person / week" },
];

const testimonials = [
  {
    quote: "We cut our release cycle from two weeks to two days. Driftwork is the first tool the whole team adopted without being asked.",
    name: "Priya Nadkarni",
    role: "VP Engineering, Northbeam",
    seed: "priya",
  },
  {
    quote: "Setup took an afternoon. The API-deep design meant our platform team could go as far as they wanted.",
    name: "Marcus Webb",
    role: "Staff Engineer, Lumen Labs",
    seed: "marcus",
  },
  {
    quote: "Our ops finally have a single source of truth. Demo requests went up 30% after we standardized handoffs.",
    name: "Sofia Tran",
    role: "Head of Operations, Cadence",
    seed: "sofia",
  },
];

const plans = [
  {
    name: "Starter",
    price: "$0",
    unit: "/mo",
    blurb: "For small teams testing the waters.",
    features: ["Up to 3 users", "100 automation runs/mo", "2 integrations", "Community support"],
    cta: "Start free",
    popular: false,
  },
  {
    name: "Team",
    price: "$24",
    unit: "/user/mo",
    blurb: "For teams ready to standardize.",
    features: ["Unlimited automations", "50+ integrations", "Shared workspaces", "Priority email support"],
    cta: "Start free trial",
    popular: true,
  },
  {
    name: "Business",
    price: "$48",
    unit: "/user/mo",
    blurb: "For scaling orgs with compliance needs.",
    features: ["Advanced permissions", "Audit logs", "SSO / SAML", "99.99% SLA + dedicated CSM"],
    cta: "Book a demo",
    popular: false,
  },
];

const footer = {
  Product: ["Features", "Integrations", "Pricing", "Changelog"],
  Resources: ["Docs", "API reference", "Status", "Community"],
  Company: ["About", "Careers", "Blog", "Contact"],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Driftwork — The workflow automation platform for product teams</title>
    <meta
      name="description"
      content="Driftwork connects your tools, automates handoffs, and gives every team a single source of truth. No-code to set up, API-deep when you need it."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;600;700;800&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>

    <header class="nav" id="top">
      <div class="wrap nav-inner">
        <a class="brand" href="#top" aria-label="Driftwork home">
          <span class="brand-mark" aria-hidden="true"></span>
          Driftwork
        </a>
        <nav class="nav-links" aria-label="Primary">
          {nav.map((n) => <a href={n.href}>{n.label}</a>)}
        </nav>
        <div class="nav-cta">
          <a class="btn btn-ghost" href="#pricing">Sign in</a>
          <a class="btn btn-primary" href="#pricing">Start free</a>
        </div>
        <button class="menu-btn" aria-label="Toggle menu" aria-expanded="false" id="menuBtn">
          <span></span><span></span><span></span>
        </button>
      </div>
      <div class="mobile-menu" id="mobileMenu" hidden>
        {nav.map((n) => <a href={n.href}>{n.label}</a>)}
        <a class="btn btn-primary" href="#pricing">Start free</a>
      </div>
    </header>

    <main id="main">
      <!-- HERO -->
      <section class="hero">
        <div class="wrap hero-grid">
          <div class="hero-copy reveal">
            <span class="pill"><span class="dot"></span> New → v2 just launched <span class="arrow">↗</span></span>
            <h1>Ship faster.<br /><span class="grad">Drift less.</span></h1>
            <p class="lede">
              Driftwork connects your tools, automates handoffs, and gives every team a single source of
              truth. No-code to set up, API-deep when you need it.
            </p>
            <div class="hero-actions">
              <a class="btn btn-primary btn-lg" href="#pricing">Start free</a>
              <a class="btn btn-ghost btn-lg" href="#tour">Book a demo</a>
            </div>
            <p class="hero-fine">No credit card · Free for up to 3 users</p>
          </div>

          <div class="hero-art reveal">
            <div class="blob blob-a" aria-hidden="true"></div>
            <div class="blob blob-b" aria-hidden="true"></div>
            <figure class="screenshot">
              <div class="chrome"><span></span><span></span><span></span><em>app.driftwork.io</em></div>
              <img
                src="https://picsum.photos/seed/driftworkapp/720/520"
                alt="Driftwork app dashboard showing an automation flow between connected tools"
                loading="eager"
                width="720"
                height="520"
              />
              <div class="float-card">
                <span class="fc-dot"></span> Workflow ran · 0.4s
              </div>
            </figure>
          </div>
        </div>
      </section>

      <!-- TRUST BAR -->
      <section class="trust" aria-label="Trusted by">
        <div class="wrap">
          <p class="trust-label">Trusted by 12,000+ product teams</p>
          <ul class="logo-row">
            {logos.map((l) => <li>{l}</li>)}
          </ul>
        </div>
      </section>

      <!-- FEATURES BENTO -->
      <section class="section grid-bg" id="features">
        <div class="wrap">
          <div class="head">
            <span class="eyebrow">// Capabilities</span>
            <h2>Automate the work between the work</h2>
            <p>So your team ships, not shuffles. Here's what's under the hood.</p>
          </div>
          <div class="bento">
            {
              features.map((f) => (
                <article class={`card reveal ${f.span} ${f.accent ? "card-accent" : ""}`}>
                  <div class="card-ill" aria-hidden="true">
                    <svg viewBox="0 0 48 48" width="40" height="40">
                      <rect x="6" y="6" width="36" height="36" rx="10" fill="currentColor" opacity="0.14" />
                      <path d="M16 24h16M24 16v16" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
                    </svg>
                  </div>
                  <h3>{f.title}</h3>
                  <p>{f.body}</p>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <!-- PRODUCT TOUR (tabbed) -->
      <section class="section tour-sec" id="tour">
        <div class="wrap">
          <div class="head">
            <span class="eyebrow">// Product tour</span>
            <h2>Three steps from chaos to calm</h2>
          </div>
          <div class="tour">
            <div class="tabs" role="tablist" aria-label="Product tour steps">
              {
                tour.map((t, i) => (
                  <button
                    class={`tab ${i === 0 ? "active" : ""}`}
                    role="tab"
                    aria-selected={i === 0 ? "true" : "false"}
                    data-tab={i}
                  >
                    <span class="tab-n">{`0${i + 1}`}</span>
                    {t.tab}
                  </button>
                ))
              }
            </div>
            <div class="panels">
              {
                tour.map((t, i) => (
                  <div class={`panel ${i === 0 ? "active" : ""}`} data-panel={i} role="tabpanel">
                    <div class="panel-copy">
                      <h3>{t.heading}</h3>
                      <p>{t.body}</p>
                      <a class="link-arrow" href="#pricing">Try it free <span>→</span></a>
                    </div>
                    <figure class="panel-shot">
                      <img
                        src={`https://picsum.photos/seed/${t.seed}/560/380`}
                        alt={`Driftwork — ${t.heading}`}
                        loading="lazy"
                        width="560"
                        height="380"
                      />
                    </figure>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </section>

      <!-- METRICS + MARQUEE -->
      <section class="section metrics-sec" id="proof">
        <div class="wrap">
          <ul class="metrics">
            {
              metrics.map((m) => (
                <li class="reveal">
                  <span class="m-n">{m.n}</span>
                  <span class="m-l">{m.l}</span>
                </li>
              ))
            }
          </ul>
        </div>
        <div class="marquee" aria-hidden="true">
          <div class="marquee-track">
            {
              [...logos, ...logos, ...logos].map((l) => (
                <span class="m-item">{l}</span>
              ))
            }
          </div>
        </div>
      </section>

      <!-- TESTIMONIALS -->
      <section class="section grid-bg">
        <div class="wrap">
          <div class="head">
            <span class="eyebrow">// In their words</span>
            <h2>Teams that stopped shuffling</h2>
          </div>
          <div class="quotes">
            {
              testimonials.map((t) => (
                <figure class="quote reveal">
                  <blockquote>“{t.quote}”</blockquote>
                  <figcaption>
                    <img
                      src={`https://picsum.photos/seed/${t.seed}/96/96`}
                      alt={t.name}
                      width="48"
                      height="48"
                      loading="lazy"
                    />
                    <span>
                      <strong>{t.name}</strong>
                      {t.role}
                    </span>
                  </figcaption>
                </figure>
              ))
            }
          </div>
        </div>
      </section>

      <!-- PRICING -->
      <section class="section pricing-sec" id="pricing">
        <div class="wrap">
          <div class="head">
            <span class="eyebrow">// Pricing</span>
            <h2>Simple, transparent plans</h2>
            <p>Start free. Upgrade when your team is ready. Cancel anytime.</p>
          </div>
          <div class="plans">
            {
              plans.map((p) => (
                <article class={`plan reveal ${p.popular ? "plan-pop" : ""}`}>
                  {p.popular && <span class="plan-badge">Most popular</span>}
                  <h3>{p.name}</h3>
                  <p class="plan-blurb">{p.blurb}</p>
                  <div class="plan-price">
                    <span class="pp-n">{p.price}</span>
                    <span class="pp-u">{p.unit}</span>
                  </div>
                  <a class={`btn btn-lg ${p.popular ? "btn-primary" : "btn-outline"}`} href="#top">
                    {p.cta}
                  </a>
                  <ul class="plan-feat">
                    {p.features.map((f) => (
                      <li>
                        <svg viewBox="0 0 20 20" width="18" height="18" aria-hidden="true">
                          <path d="M5 10.5l3 3 7-7" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        {f}
                      </li>
                    ))}
                  </ul>
                </article>
              ))
            }
          </div>
          <p class="addon">
            Add-ons: <strong>AI Copilot</strong> $12/user/mo · <strong>Advanced Analytics</strong> $99/mo flat · <strong>Enterprise</strong> custom (self-host, SSO, 24/7).
          </p>
        </div>
      </section>

      <!-- FINAL CTA -->
      <section class="cta-band">
        <div class="wrap cta-inner">
          <div class="blob blob-c" aria-hidden="true"></div>
          <h2>Ready to ship faster?</h2>
          <p>Put your busywork on autopilot. Free for up to 3 users — set up in an afternoon.</p>
          <div class="hero-actions center">
            <a class="btn btn-light btn-lg" href="#top">Start free</a>
            <a class="btn btn-ghost-light btn-lg" href="tel:+15875550142">Talk to sales</a>
          </div>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="wrap foot-grid">
        <div class="foot-brand">
          <a class="brand" href="#top"><span class="brand-mark" aria-hidden="true"></span> Driftwork</a>
          <p>The workflow automation platform for product teams.</p>
          <address>
            Driftwork Technologies Inc.<br />
            Suite 720, 318 11th Avenue SE, Calgary, AB T2G 0Y8<br />
            <a href="mailto:hello@driftwork.io">hello@driftwork.io</a> ·
            <a href="tel:+15875550142">+1 (587) 555-0142</a>
          </address>
          <p class="hours">Support: Mon–Fri 6:00 AM – 8:00 PM MT · Enterprise 24/7</p>
        </div>
        {
          Object.entries(footer).map(([group, links]) => (
            <div class="foot-col">
              <h4>{group}</h4>
              <ul>
                {links.map((l) => (
                  <li>
                    <a href="#top">{l}</a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
      <div class="wrap foot-bottom">
        <span>© 2026 Driftwork Technologies Inc.</span>
        <span class="status"><span class="status-dot"></span> All systems operational</span>
      </div>
    </footer>

    <style is:global>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        margin: 0;
      }
      img {
        max-width: 100%;
        display: block;
      }
      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }
        * {
          animation: none !important;
          transition: none !important;
        }
      }
    </style>

    <style>
      :root {
        --bg: #ffffff;
        --fg: #0f172a;
        --primary: #2563eb;
        --primary-fg: #ffffff;
        --accent: #f59e0b;
        --muted: #f1f5f9;
        --border: #e2e8f0;
        --soft: #64748b;
        --display: "Plus Jakarta Sans", system-ui, sans-serif;
        --body: "Inter", system-ui, sans-serif;
        --radius: 18px;
        --shadow: 0 10px 30px -12px rgba(15, 23, 42, 0.18);
        --shadow-lg: 0 30px 70px -28px rgba(37, 99, 235, 0.4);
      }

      body {
        font-family: var(--body);
        color: var(--fg);
        background: var(--bg);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      .wrap {
        width: min(1160px, 92vw);
        margin-inline: auto;
      }

      h1,
      h2,
      h3,
      h4 {
        font-family: var(--display);
        line-height: 1.08;
        letter-spacing: -0.02em;
        margin: 0;
      }

      a {
        color: inherit;
      }

      .skip {
        position: absolute;
        left: -999px;
        top: 0;
        background: var(--primary);
        color: #fff;
        padding: 0.6rem 1rem;
        border-radius: 0 0 10px 0;
        z-index: 100;
      }
      .skip:focus {
        left: 0;
      }

      :focus-visible {
        outline: 3px solid var(--accent);
        outline-offset: 2px;
        border-radius: 6px;
      }

      /* BUTTONS */
      .btn {
        --tap: 44px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: var(--tap);
        padding: 0 1.2rem;
        gap: 0.5rem;
        font-family: var(--display);
        font-weight: 700;
        font-size: 0.95rem;
        text-decoration: none;
        border-radius: 999px;
        border: 1.5px solid transparent;
        cursor: pointer;
        transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
      }
      .btn-lg {
        min-height: 52px;
        padding: 0 1.6rem;
        font-size: 1.02rem;
      }
      .btn-primary {
        background: var(--primary);
        color: var(--primary-fg);
        box-shadow: 0 8px 20px -8px rgba(37, 99, 235, 0.6);
      }
      .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 14px 28px -8px rgba(37, 99, 235, 0.7);
      }
      .btn-ghost {
        color: var(--fg);
        border-color: var(--border);
        background: #fff;
      }
      .btn-ghost:hover {
        border-color: var(--primary);
        color: var(--primary);
        transform: translateY(-2px);
      }
      .btn-outline {
        color: var(--primary);
        border-color: var(--primary);
        background: #fff;
      }
      .btn-outline:hover {
        background: var(--primary);
        color: #fff;
      }
      .btn-light {
        background: #fff;
        color: var(--primary);
      }
      .btn-light:hover {
        transform: translateY(-2px);
      }
      .btn-ghost-light {
        color: #fff;
        border-color: rgba(255, 255, 255, 0.55);
      }
      .btn-ghost-light:hover {
        background: rgba(255, 255, 255, 0.14);
      }

      /* NAV */
      .nav {
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgba(255, 255, 255, 0.82);
        backdrop-filter: blur(14px);
        border-bottom: 1px solid var(--border);
      }
      .nav-inner {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        height: 70px;
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        font-family: var(--display);
        font-weight: 800;
        font-size: 1.25rem;
        text-decoration: none;
        letter-spacing: -0.02em;
      }
      .brand-mark {
        width: 26px;
        height: 26px;
        border-radius: 9px;
        background: linear-gradient(135deg, var(--primary), #60a5fa);
        position: relative;
        box-shadow: inset 0 0 0 3px rgba(255, 255, 255, 0.55);
      }
      .brand-mark::after {
        content: "";
        position: absolute;
        inset: 7px;
        border-radius: 4px;
        background: var(--accent);
      }
      .nav-links {
        display: flex;
        gap: 1.6rem;
        margin-left: auto;
      }
      .nav-links a {
        text-decoration: none;
        font-weight: 500;
        font-size: 0.95rem;
        color: var(--soft);
        transition: color 0.15s;
      }
      .nav-links a:hover {
        color: var(--fg);
      }
      .nav-cta {
        display: flex;
        gap: 0.6rem;
      }
      .menu-btn {
        display: none;
        margin-left: auto;
        width: 44px;
        height: 44px;
        background: none;
        border: 1px solid var(--border);
        border-radius: 12px;
        flex-direction: column;
        gap: 4px;
        align-items: center;
        justify-content: center;
        cursor: pointer;
      }
      .menu-btn span {
        width: 18px;
        height: 2px;
        background: var(--fg);
        border-radius: 2px;
      }
      .mobile-menu {
        display: none;
        flex-direction: column;
        gap: 0.4rem;
        padding: 1rem 4vw 1.4rem;
        border-bottom: 1px solid var(--border);
      }
      .mobile-menu a {
        text-decoration: none;
        padding: 0.7rem 0;
        font-weight: 600;
        font-family: var(--display);
      }
      .mobile-menu .btn {
        margin-top: 0.4rem;
      }

      /* HERO */
      .hero {
        position: relative;
        padding: clamp(3rem, 8vw, 6rem) 0 clamp(3rem, 6vw, 5rem);
        overflow: hidden;
        background:
          radial-gradient(60% 50% at 80% 0%, rgba(37, 99, 235, 0.08), transparent 70%),
          radial-gradient(40% 40% at 5% 30%, rgba(245, 158, 11, 0.08), transparent 70%);
      }
      .hero-grid {
        display: grid;
        grid-template-columns: 1.05fr 1fr;
        gap: clamp(2rem, 5vw, 4rem);
        align-items: center;
      }
      .pill {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: var(--muted);
        border: 1px solid var(--border);
        color: var(--fg);
        font-size: 0.82rem;
        font-weight: 600;
        padding: 0.42rem 0.8rem;
        border-radius: 999px;
      }
      .pill .dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--accent);
        box-shadow: 0 0 0 4px rgba(245, 158, 11, 0.2);
      }
      .pill .arrow {
        color: var(--primary);
      }
      .hero h1 {
        font-size: clamp(2.6rem, 7vw, 4.4rem);
        font-weight: 800;
        margin: 1.2rem 0 0;
      }
      .grad {
        background: linear-gradient(100deg, var(--primary), #7c3aed 60%, var(--accent));
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }
      .lede {
        font-size: clamp(1.05rem, 2vw, 1.2rem);
        color: var(--soft);
        max-width: 34ch;
        margin: 1.3rem 0 1.8rem;
      }
      .hero-actions {
        display: flex;
        gap: 0.8rem;
        flex-wrap: wrap;
      }
      .hero-actions.center {
        justify-content: center;
      }
      .hero-fine {
        margin-top: 1rem;
        font-size: 0.85rem;
        color: var(--soft);
      }

      /* HERO ART */
      .hero-art {
        position: relative;
      }
      .blob {
        position: absolute;
        border-radius: 50%;
        filter: blur(36px);
        z-index: 0;
      }
      .blob-a {
        width: 260px;
        height: 260px;
        background: rgba(37, 99, 235, 0.35);
        top: -30px;
        right: -20px;
        animation: float 7s ease-in-out infinite;
      }
      .blob-b {
        width: 200px;
        height: 200px;
        background: rgba(245, 158, 11, 0.32);
        bottom: -40px;
        left: -30px;
        animation: float 9s ease-in-out infinite reverse;
      }
      .screenshot {
        position: relative;
        z-index: 1;
        margin: 0;
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid var(--border);
        background: #fff;
        box-shadow: var(--shadow-lg);
        transition: transform 0.4s ease;
      }
      .screenshot:hover {
        transform: translateY(-6px) rotate(-0.4deg);
      }
      .chrome {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 0.65rem 0.9rem;
        background: var(--muted);
        border-bottom: 1px solid var(--border);
      }
      .chrome span {
        width: 11px;
        height: 11px;
        border-radius: 50%;
        background: #cbd5e1;
      }
      .chrome span:nth-child(1) {
        background: #f87171;
      }
      .chrome span:nth-child(2) {
        background: #fbbf24;
      }
      .chrome span:nth-child(3) {
        background: #34d399;
      }
      .chrome em {
        margin-left: auto;
        font-style: normal;
        font-size: 0.74rem;
        color: var(--soft);
        font-family: var(--body);
      }
      .screenshot img {
        width: 100%;
        height: auto;
        aspect-ratio: 720 / 520;
        object-fit: cover;
        filter: saturate(1.05) contrast(1.02);
      }
      .float-card {
        position: absolute;
        bottom: 18px;
        left: 18px;
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 0.5rem 0.8rem;
        font-size: 0.8rem;
        font-weight: 600;
        box-shadow: var(--shadow);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        animation: float 5s ease-in-out infinite;
      }
      .fc-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #34d399;
        box-shadow: 0 0 0 4px rgba(52, 211, 153, 0.2);
      }

      /* TRUST */
      .trust {
        padding: 2.5rem 0;
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
      }
      .trust-label {
        text-align: center;
        color: var(--soft);
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin: 0 0 1.2rem;
      }
      .logo-row {
        list-style: none;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: clamp(1.5rem, 5vw, 3.4rem);
        margin: 0;
        padding: 0;
      }
      .logo-row li {
        font-family: var(--display);
        font-weight: 800;
        font-size: 1.15rem;
        color: #94a3b8;
        letter-spacing: -0.02em;
        transition: color 0.2s;
      }
      .logo-row li:hover {
        color: var(--fg);
      }

      /* SECTIONS */
      .section {
        padding: clamp(3.5rem, 8vw, 6rem) 0;
      }
      .grid-bg {
        background-image:
          linear-gradient(var(--border) 1px, transparent 1px),
          linear-gradient(90deg, var(--border) 1px, transparent 1px);
        background-size: 32px 32px;
        background-position: center;
        position: relative;
      }
      .grid-bg::before {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse 70% 60% at 50% 50%, transparent 30%, var(--bg) 90%);
        pointer-events: none;
      }
      .grid-bg .wrap {
        position: relative;
      }
      .head {
        text-align: center;
        max-width: 620px;
        margin: 0 auto clamp(2rem, 5vw, 3rem);
      }
      .eyebrow {
        font-family: "Inter", monospace;
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--primary);
        letter-spacing: 0.04em;
      }
      .head h2 {
        font-size: clamp(1.9rem, 4.5vw, 2.9rem);
        font-weight: 800;
        margin: 0.6rem 0 0.7rem;
      }
      .head p {
        color: var(--soft);
        font-size: 1.08rem;
        margin: 0;
      }

      /* BENTO */
      .bento {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.1rem;
      }
      .card {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1.6rem;
        box-shadow: 0 2px 10px -6px rgba(15, 23, 42, 0.1);
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
        color: var(--primary);
      }
      .card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow);
        border-color: #c7d2fe;
      }
      .card.wide {
        grid-column: span 2;
      }
      .card.tall {
        grid-row: span 2;
      }
      .card-accent {
        background: linear-gradient(160deg, var(--primary), #1d4ed8);
        color: #fff;
        border-color: transparent;
      }
      .card-accent h3,
      .card-accent p {
        color: #fff;
      }
      .card-ill {
        margin-bottom: 0.9rem;
      }
      .card h3 {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--fg);
        margin-bottom: 0.4rem;
      }
      .card p {
        color: var(--soft);
        font-size: 0.96rem;
        margin: 0;
      }

      /* TOUR */
      .tour-sec {
        background: var(--muted);
      }
      .tabs {
        display: flex;
        gap: 0.6rem;
        justify-content: center;
        flex-wrap: wrap;
        margin-bottom: 2rem;
      }
      .tab {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        min-height: 48px;
        padding: 0 1.2rem;
        background: #fff;
        border: 1.5px solid var(--border);
        border-radius: 999px;
        font-family: var(--display);
        font-weight: 700;
        font-size: 0.95rem;
        color: var(--soft);
        cursor: pointer;
        transition: all 0.18s ease;
      }
      .tab .tab-n {
        font-family: "Inter", monospace;
        font-size: 0.78rem;
        color: var(--accent);
      }
      .tab.active {
        background: var(--primary);
        color: #fff;
        border-color: var(--primary);
        box-shadow: 0 8px 20px -10px rgba(37, 99, 235, 0.7);
      }
      .tab.active .tab-n {
        color: rgba(255, 255, 255, 0.8);
      }
      .panels {
        position: relative;
      }
      .panel {
        display: none;
        grid-template-columns: 1fr 1.1fr;
        gap: clamp(1.5rem, 4vw, 3rem);
        align-items: center;
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 24px;
        padding: clamp(1.5rem, 4vw, 2.6rem);
        box-shadow: var(--shadow);
      }
      .panel.active {
        display: grid;
        animation: fade 0.4s ease;
      }
      .panel-copy h3 {
        font-size: clamp(1.5rem, 3vw, 2.1rem);
        font-weight: 800;
        margin-bottom: 0.8rem;
      }
      .panel-copy p {
        color: var(--soft);
        font-size: 1.05rem;
        margin: 0 0 1.4rem;
      }
      .link-arrow {
        font-family: var(--display);
        font-weight: 700;
        color: var(--primary);
        text-decoration: none;
        display: inline-flex;
        gap: 0.4rem;
      }
      .link-arrow span {
        transition: transform 0.2s;
      }
      .link-arrow:hover span {
        transform: translateX(4px);
      }
      .panel-shot {
        margin: 0;
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid var(--border);
      }
      .panel-shot img {
        width: 100%;
        aspect-ratio: 560 / 380;
        object-fit: cover;
        filter: saturate(1.05);
      }

      /* METRICS */
      .metrics-sec {
        padding-bottom: 0;
      }
      .metrics {
        list-style: none;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
        margin: 0 0 clamp(2.5rem, 6vw, 4rem);
        padding: 0;
        text-align: center;
      }
      .metrics li {
        padding: 1.4rem 0.5rem;
        border-radius: var(--radius);
        background: var(--muted);
        border: 1px solid var(--border);
      }
      .m-n {
        display: block;
        font-family: var(--display);
        font-weight: 800;
        font-size: clamp(1.8rem, 4vw, 2.6rem);
        color: var(--primary);
        letter-spacing: -0.03em;
      }
      .m-l {
        display: block;
        margin-top: 0.3rem;
        font-size: 0.88rem;
        color: var(--soft);
        font-weight: 500;
      }
      .marquee {
        overflow: hidden;
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
        padding: 1.4rem 0;
        -webkit-mask-image: linear-gradient(90deg, transparent, #000 12%, #000 88%, transparent);
        mask-image: linear-gradient(90deg, transparent, #000 12%, #000 88%, transparent);
      }
      .marquee-track {
        display: flex;
        gap: 3rem;
        width: max-content;
        animation: scroll 26s linear infinite;
      }
      .m-item {
        font-family: var(--display);
        font-weight: 800;
        font-size: 1.3rem;
        color: #cbd5e1;
        white-space: nowrap;
      }

      /* QUOTES */
      .quotes {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.2rem;
      }
      .quote {
        background: #fff;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1.8rem;
        margin: 0;
        box-shadow: 0 2px 10px -6px rgba(15, 23, 42, 0.1);
        display: flex;
        flex-direction: column;
        gap: 1.3rem;
      }
      .quote blockquote {
        margin: 0;
        font-size: 1.02rem;
        color: var(--fg);
        line-height: 1.55;
      }
      .quote figcaption {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        margin-top: auto;
      }
      .quote figcaption img {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid var(--border);
      }
      .quote figcaption span {
        display: flex;
        flex-direction: column;
        font-size: 0.86rem;
        color: var(--soft);
      }
      .quote figcaption strong {
        color: var(--fg);
        font-family: var(--display);
        font-size: 0.96rem;
      }

      /* PRICING */
      .pricing-sec {
        background: var(--muted);
      }
      .plans {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.2rem;
        align-items: start;
      }
      .plan {
        position: relative;
        background: #fff;
        border: 1.5px solid var(--border);
        border-radius: 22px;
        padding: 2rem 1.7rem;
        box-shadow: 0 2px 12px -6px rgba(15, 23, 42, 0.12);
        transition: transform 0.2s ease;
      }
      .plan:hover {
        transform: translateY(-4px);
      }
      .plan-pop {
        border-color: var(--primary);
        box-shadow: var(--shadow-lg);
        z-index: 1;
      }
      .plan-badge {
        position: absolute;
        top: -13px;
        left: 50%;
        transform: translateX(-50%);
        background: var(--accent);
        color: #422006;
        font-family: var(--display);
        font-weight: 700;
        font-size: 0.75rem;
        padding: 0.32rem 0.85rem;
        border-radius: 999px;
        white-space: nowrap;
      }
      .plan h3 {
        font-size: 1.3rem;
        font-weight: 800;
      }
      .plan-blurb {
        color: var(--soft);
        font-size: 0.92rem;
        margin: 0.4rem 0 1.1rem;
        min-height: 2.6em;
      }
      .plan-price {
        display: flex;
        align-items: baseline;
        gap: 0.2rem;
        margin-bottom: 1.3rem;
      }
      .pp-n {
        font-family: var(--display);
        font-weight: 800;
        font-size: 2.6rem;
        letter-spacing: -0.03em;
      }
      .pp-u {
        color: var(--soft);
        font-size: 0.9rem;
        font-weight: 600;
      }
      .plan .btn {
        width: 100%;
      }
      .plan-feat {
        list-style: none;
        margin: 1.5rem 0 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.7rem;
      }
      .plan-feat li {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        font-size: 0.92rem;
        color: var(--fg);
      }
      .plan-feat svg {
        color: var(--primary);
        flex-shrink: 0;
      }
      .addon {
        text-align: center;
        color: var(--soft);
        font-size: 0.92rem;
        margin: 2rem auto 0;
        max-width: 60ch;
      }
      .addon strong {
        color: var(--fg);
      }

      /* CTA */
      .cta-band {
        background: linear-gradient(135deg, var(--primary), #1d4ed8 60%, #4f46e5);
        color: #fff;
        padding: clamp(3.5rem, 8vw, 6rem) 0;
        position: relative;
        overflow: hidden;
      }
      .cta-inner {
        text-align: center;
        position: relative;
        z-index: 1;
      }
      .blob-c {
        width: 420px;
        height: 420px;
        background: rgba(245, 158, 11, 0.35);
        top: -160px;
        right: -100px;
        z-index: 0;
      }
      .cta-band h2 {
        font-size: clamp(2rem, 5vw, 3.2rem);
        font-weight: 800;
      }
      .cta-band p {
        font-size: 1.1rem;
        opacity: 0.92;
        max-width: 46ch;
        margin: 1rem auto 1.8rem;
      }

      /* FOOTER */
      .footer {
        background: #0f172a;
        color: #cbd5e1;
        padding: clamp(3rem, 6vw, 4.5rem) 0 2rem;
      }
      .foot-grid {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr;
        gap: 2rem;
      }
      .footer .brand {
        color: #fff;
      }
      .foot-brand p {
        font-size: 0.95rem;
        margin: 0.9rem 0;
        max-width: 32ch;
      }
      .foot-brand address {
        font-style: normal;
        font-size: 0.88rem;
        line-height: 1.7;
        color: #94a3b8;
      }
      .foot-brand address a {
        color: #93c5fd;
        text-decoration: none;
      }
      .foot-brand .hours {
        font-size: 0.82rem;
        color: #64748b;
      }
      .foot-col h4 {
        color: #fff;
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 1rem;
      }
      .foot-col ul {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
      }
      .foot-col a {
        color: #94a3b8;
        text-decoration: none;
        font-size: 0.92rem;
        transition: color 0.15s;
      }
      .foot-col a:hover {
        color: #fff;
      }
      .foot-bottom {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
        margin-top: 2.5rem;
        padding-top: 1.6rem;
        border-top: 1px solid #1e293b;
        font-size: 0.84rem;
        color: #64748b;
      }
      .status {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
      }
      .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #34d399;
        box-shadow: 0 0 0 4px rgba(52, 211, 153, 0.2);
      }

      /* ANIMATIONS */
      @keyframes float {
        0%,
        100% {
          transform: translateY(0);
        }
        50% {
          transform: translateY(-14px);
        }
      }
      @keyframes scroll {
        to {
          transform: translateX(-33.33%);
        }
      }
      @keyframes fade {
        from {
          opacity: 0;
          transform: translateY(8px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .reveal {
        opacity: 0;
        transform: translateY(22px);
        transition: opacity 0.6s ease, transform 0.6s ease;
      }
      .reveal.in {
        opacity: 1;
        transform: none;
      }

      /* RESPONSIVE */
      @media (max-width: 920px) {
        .nav-links,
        .nav-cta {
          display: none;
        }
        .menu-btn {
          display: flex;
        }
        .hero-grid {
          grid-template-columns: 1fr;
        }
        .hero-art {
          order: -1;
        }
        .bento {
          grid-template-columns: repeat(2, 1fr);
        }
        .card.wide,
        .card.tall {
          grid-column: auto;
          grid-row: auto;
        }
        .panel {
          grid-template-columns: 1fr;
        }
        .panel-shot {
          order: -1;
        }
        .metrics {
          grid-template-columns: repeat(2, 1fr);
        }
        .quotes,
        .plans {
          grid-template-columns: 1fr;
        }
        .plan-pop {
          order: -1;
        }
        .foot-grid {
          grid-template-columns: 1fr 1fr;
        }
        .foot-brand {
          grid-column: 1 / -1;
        }
      }
      @media (max-width: 540px) {
        .bento,
        .metrics {
          grid-template-columns: 1fr;
        }
        .lede {
          max-width: none;
        }
        .foot-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>

    <script>
      // mobile menu
      const mb = document.getElementById("menuBtn");
      const mm = document.getElementById("mobileMenu");
      if (mb && mm) {
        mb.addEventListener("click", () => {
          const open = mm.hasAttribute("hidden");
          if (open) {
            mm.removeAttribute("hidden");
            mm.style.display = "flex";
          } else {
            mm.setAttribute("hidden", "");
            mm.style.display = "none";
          }
          mb.setAttribute("aria-expanded", String(open));
        });
        mm.querySelectorAll("a").forEach((a) =>
          a.addEventListener("click", () => {
            mm.setAttribute("hidden", "");
            mm.style.display = "none";
            mb.setAttribute("aria-expanded", "false");
          })
        );
      }

      // product tour tabs
      const tabs = document.querySelectorAll(".tab");
      const panels = document.querySelectorAll(".panel");
      tabs.forEach((t) =>
        t.addEventListener("click", () => {
          const i = t.getAttribute("data-tab");
          tabs.forEach((x) => {
            x.classList.remove("active");
            x.setAttribute("aria-selected", "false");
          });
          t.classList.add("active");
          t.setAttribute("aria-selected", "true");
          panels.forEach((p) =>
            p.classList.toggle("active", p.getAttribute("data-panel") === i)
          );
        })
      );

      // scroll reveal
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add("in");
              io.unobserve(e.target);
            }
          });
        },
        { threshold: 0.12 }
      );
      document.querySelectorAll(".reveal").forEach((el) => io.observe(el));
    </script>
  </body>
</html>
