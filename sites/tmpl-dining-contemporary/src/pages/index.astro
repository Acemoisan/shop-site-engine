---
// Maison Lumiere — Contemporary fine-dining template (self-contained Astro page)
const nav = [
  { label: "Experience", href: "#experience" },
  { label: "Menu", href: "#menu" },
  { label: "Gallery", href: "#gallery" },
  { label: "Press", href: "#press" },
  { label: "Visit", href: "#visit" },
];

const tasting = [
  { name: "The Lumiere Tasting Menu", note: "eight courses, one unhurried evening", price: "165" },
  { name: "Wine Pairing", note: "sommelier-selected, five pours", price: "95" },
];

const alacarte = [
  { name: "Hand-Dived Scallop", note: "brown butter, sea herbs, finger lime", price: "34" },
  { name: "Alberta Wagyu", note: "charred leek, bone-marrow jus, black garlic", price: "62" },
  { name: "Heritage Beet", note: "whipped goat cheese, walnut, aged balsamic", price: "26" },
  { name: "Tarte Tatin", note: "crème fraîche, salted caramel, vanilla bean", price: "19" },
  { name: "Cheese Trolley", note: "three selections, house preserves, walnut bread", price: "28" },
];

const testimonials = [
  { quote: "The closest thing to a Michelin evening this city has. Every course told a story.", who: "Daniel R.", role: "Avenue Magazine" },
  { quote: "Faultless service and a tasting menu I'm still thinking about a week later.", who: "Priya N.", role: "Guest" },
  { quote: "We came for an anniversary and left planning the next visit. Quietly extraordinary.", who: "Marc & Eloise T.", role: "Guests" },
];

const press = ["Michelin Guide — Recommended", "enRoute Top 10", "Avenue Best Restaurants 2026"];

const hours = [
  { d: "Tuesday – Thursday", t: "5:30pm – 10:00pm" },
  { d: "Friday – Saturday", t: "5:00pm – 11:00pm" },
  { d: "Sunday & Monday", t: "Closed" },
];

const gallery = [
  { seed: "lum-plate-01", w: 600, h: 800, alt: "Plated seasonal course with sea herbs", span: "tall" },
  { seed: "lum-room-02", w: 800, h: 560, alt: "Candlelit dining room at dusk", span: "wide" },
  { seed: "lum-hands-03", w: 600, h: 600, alt: "Chef finishing a dish with tweezers", span: "" },
  { seed: "lum-pour-04", w: 600, h: 600, alt: "Sommelier pouring a wine pairing", span: "" },
  { seed: "lum-plate-05", w: 800, h: 560, alt: "Dessert with salted caramel detail", span: "wide" },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Maison Lumiere — Contemporary French Tasting House | Calgary</title>
    <meta
      name="description"
      content="Maison Lumiere — modern French dining in the heart of Calgary. Eight courses, one unhurried evening. Reserve a table on Stephen Avenue SW."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,400;0,500;0,600;1,400&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a class="skip" href="#menu">Skip to menu</a>

    <!-- Sticky reservation bar -->
    <header class="bar" id="top">
      <nav class="bar__in" aria-label="Primary">
        <a class="brand" href="#top" aria-label="Maison Lumiere home">
          <span class="brand__mark" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.1">
              <path d="M12 2v20M5 7c0 4 3 6 7 6M19 7c0 4-3 6-7 6" />
            </svg>
          </span>
          <span class="brand__name">Maison Lumiere</span>
        </a>
        <ul class="bar__nav">
          {nav.map((n) => <li><a href={n.href}>{n.label}</a></li>)}
        </ul>
        <a class="resv" href="#reserve">
          <span class="resv__dot" aria-hidden="true"></span>Reserve
        </a>
      </nav>
    </header>

    <main>
      <!-- Hero -->
      <section class="hero" aria-labelledby="hero-h">
        <div class="hero__img" aria-hidden="true">
          <img src="https://picsum.photos/seed/lum-hero-contempo/1600/1100" alt="" loading="eager" />
        </div>
        <div class="hero__grid">
          <p class="eyebrow">Contemporary French · Calgary</p>
          <h1 id="hero-h">
            A quiet room,<br /><em>a long table,</em><br />an evening you'll remember.
          </h1>
          <p class="hero__sub">
            Seasonal French cuisine, plated with intention. Eight courses,
            one unhurried evening on Stephen Avenue.
          </p>
          <div class="hero__cta">
            <a class="btn btn--solid" href="#reserve">Reserve a Table</a>
            <a class="btn btn--ghost" href="#menu">View the Menu</a>
          </div>
          <dl class="hero__meta">
            <div><dt>Format</dt><dd>8-course tasting</dd></div>
            <div><dt>From</dt><dd>$165 / guest</dd></div>
            <div><dt>Seatings</dt><dd>Tue – Sat, 5pm</dd></div>
          </dl>
        </div>
      </section>

      <!-- Marquee -->
      <div class="marquee" aria-hidden="true">
        <div class="marquee__track">
          {Array(2).fill(0).map(() => (
            <span>
              Seasonal&nbsp;·&nbsp; Sommelier-led&nbsp;·&nbsp; Provenance&nbsp;·&nbsp;
              Eight Courses&nbsp;·&nbsp; Calgary&nbsp;·&nbsp; Maison Lumiere&nbsp;·&nbsp;
            </span>
          ))}
        </div>
      </div>

      <!-- Experience / Story -->
      <section class="exp" id="experience" aria-labelledby="exp-h">
        <div class="exp__media reveal">
          <img src="https://picsum.photos/seed/lum-chef-portrait/900/1100" alt="Chef plating a course in the open kitchen" loading="lazy" />
          <span class="exp__tag">The kitchen, after service begins</span>
        </div>
        <div class="exp__copy reveal">
          <p class="eyebrow">The Experience</p>
          <h2 id="exp-h">Where provenance meets the plate.</h2>
          <p>
            Each evening unfolds as a single, considered sequence — eight courses
            paced to the room, not the clock. We cook with what Alberta's growers,
            foragers and ranchers send us that week, in the precise French idiom.
          </p>
          <p>
            Nothing is rushed. The wine arrives a beat before the dish it was chosen
            for. The lighting softens as the night deepens. You leave having been
            somewhere, not simply having eaten.
          </p>
          <ul class="exp__list">
            <li>Sourced within the province, plated in the French canon</li>
            <li>A sommelier-led pairing for every course</li>
            <li>Last seating ninety minutes before close</li>
          </ul>
        </div>
      </section>

      <!-- Menu -->
      <section class="menu" id="menu" aria-labelledby="menu-h">
        <div class="menu__head">
          <p class="eyebrow">Tasting &amp; à la carte</p>
          <h2 id="menu-h">The seasonal menu</h2>
          <p class="menu__lede">Menus change with the season. A current selection below.</p>
        </div>

        <div class="menu__cols">
          <div class="course">
            <h3 class="course__title">The Tasting</h3>
            {tasting.map((i) => (
              <div class="line">
                <span class="line__name">{i.name}<em>{i.note}</em></span>
                <span class="line__dots" aria-hidden="true"></span>
                <span class="line__price">${i.price}</span>
              </div>
            ))}
          </div>

          <div class="course">
            <h3 class="course__title">À la Carte</h3>
            {alacarte.map((i) => (
              <div class="line">
                <span class="line__name">{i.name}<em>{i.note}</em></span>
                <span class="line__dots" aria-hidden="true"></span>
                <span class="line__price">${i.price}</span>
              </div>
            ))}
          </div>
        </div>
        <a class="btn btn--ghost menu__cta" href="#reserve">Reserve your evening</a>
      </section>

      <!-- Gallery (asymmetric) -->
      <section class="gallery" id="gallery" aria-labelledby="gal-h">
        <div class="gallery__head">
          <p class="eyebrow">Ambiance</p>
          <h2 id="gal-h">The room &amp; the plate</h2>
        </div>
        <div class="gallery__grid">
          {gallery.map((g) => (
            <figure class={`tile reveal ${g.span}`}>
              <img src={`https://picsum.photos/seed/${g.seed}/${g.w}/${g.h}`} alt={g.alt} loading="lazy" />
            </figure>
          ))}
        </div>
      </section>

      <!-- Press + testimonials -->
      <section class="press" id="press" aria-labelledby="press-h">
        <div class="press__bar">
          <h2 id="press-h" class="vh">Press &amp; accolades</h2>
          {press.map((p) => (
            <span class="press__item"><span class="star" aria-hidden="true">★</span>{p}</span>
          ))}
        </div>
        <div class="quotes">
          {testimonials.map((t) => (
            <figure class="quote reveal">
              <blockquote>“{t.quote}”</blockquote>
              <figcaption>{t.who}<span>{t.role}</span></figcaption>
            </figure>
          ))}
        </div>
      </section>

      <!-- Private dining -->
      <section class="private" aria-labelledby="priv-h">
        <div class="private__img" aria-hidden="true">
          <img src="https://picsum.photos/seed/lum-private-table/1200/700" alt="" loading="lazy" />
        </div>
        <div class="private__card reveal">
          <p class="eyebrow">Chef's table &amp; private dining</p>
          <h2 id="priv-h">Evenings for six to twelve.</h2>
          <p>
            A private room and a dedicated chef's table for celebrations, tastings
            and quiet company. Smart casual; bespoke menus on request.
          </p>
          <a class="btn btn--solid" href="#reserve">Enquire about private dining</a>
        </div>
      </section>

      <!-- Visit / Reserve -->
      <section class="visit" id="reserve" aria-labelledby="visit-h">
        <div class="visit__copy reveal">
          <p class="eyebrow">Visit</p>
          <h2 id="visit-h" class="visit__h">Reserve a table</h2>
          <p class="visit__lede">
            Reservations are held via Resy. Walk-ins welcome at the bar when seats allow.
          </p>
          <a class="btn btn--solid btn--lg" href="https://resy.com" target="_blank" rel="noopener">Reserve on Resy</a>

          <address class="nap">
            <p>
              <strong>Maison Lumiere</strong><br />
              1124 Stephen Avenue SW<br />
              Calgary, AB T2P 1J9
            </p>
            <p>
              <a class="call" href="tel:+14035550182">(403) 555-0182</a>
            </p>
            <p class="dress">Smart casual · Private dining for parties of 6–12</p>
          </address>
        </div>

        <div class="visit__hours reveal">
          <h3 class="hours__title">Hours</h3>
          <dl class="hours">
            {hours.map((h) => (
              <div><dt>{h.d}</dt><dd>{h.t}</dd></div>
            ))}
          </dl>
          <p class="hours__note">Last seating 90 minutes before close.</p>
          <a class="map" href="https://maps.google.com/?q=1124+Stephen+Avenue+SW+Calgary" target="_blank" rel="noopener">
            View on map →
          </a>
        </div>
      </section>
    </main>

    <footer class="foot">
      <div class="foot__in">
        <div class="foot__brand">
          <span class="brand__name">Maison Lumiere</span>
          <p>Contemporary French tasting house · Calgary, AB</p>
        </div>
        <form class="signup" onsubmit="return false">
          <label for="email">Join the list for seasonal menu releases</label>
          <div class="signup__row">
            <input id="email" type="email" placeholder="you@email.com" autocomplete="email" />
            <button type="submit">Subscribe</button>
          </div>
        </form>
      </div>
      <div class="foot__base">
        <span>© 2026 Maison Lumiere</span>
        <a href="#top">Back to top ↑</a>
      </div>
    </footer>

    <!-- Mobile sticky call/reserve strip -->
    <div class="mstrip" aria-hidden="false">
      <a href="tel:+14035550182">Call</a>
      <a class="mstrip__resv" href="#reserve">Reserve</a>
    </div>

    <script>
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add("in");
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.15 }
      );
      document.querySelectorAll(".reveal").forEach((el) => io.observe(el));

      const bar = document.querySelector(".bar");
      const onScroll = () => bar.classList.toggle("bar--scrolled", window.scrollY > 24);
      onScroll();
      window.addEventListener("scroll", onScroll, { passive: true });
    </script>
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  @media (prefers-reduced-motion: reduce) {
    html { scroll-behavior: auto; }
    *, *::before, *::after { animation: none !important; transition: none !important; }
  }
  body { margin: 0; }
  img { display: block; max-width: 100%; }
</style>

<style>
  :root {
    --bg: #fafaf8;
    --fg: #1a1b1a;
    --primary: #2f3a33;
    --primary-fg: #fafaf8;
    --accent: #8a9a86;
    --muted: #ededE9;
    --border: #dcdcd6;
    --display: "Cormorant", Georgia, serif;
    --body: "Inter", system-ui, sans-serif;
    --maxw: 1200px;
    --pad: clamp(1.25rem, 5vw, 4rem);
  }

  body {
    background: var(--bg);
    color: var(--fg);
    font-family: var(--body);
    font-weight: 300;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    letter-spacing: 0.01em;
  }

  .skip {
    position: absolute;
    left: -999px;
    top: 0;
    background: var(--primary);
    color: var(--primary-fg);
    padding: 0.75rem 1rem;
    z-index: 100;
    border-radius: 0 0 4px 0;
  }
  .skip:focus { left: 0; }

  a { color: inherit; }
  :focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .eyebrow {
    font-size: 0.72rem;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 500;
    margin: 0 0 1rem;
  }
  .vh {
    position: absolute;
    width: 1px; height: 1px;
    overflow: hidden; clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  h1, h2, h3 {
    font-family: var(--display);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin: 0;
  }
  h1 { font-size: clamp(2.7rem, 7.5vw, 5.6rem); }
  h1 em { font-style: italic; color: var(--accent); }
  h2 { font-size: clamp(2rem, 4.6vw, 3.4rem); }

  /* ---- Reservation bar ---- */
  .bar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklab, var(--bg) 86%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s, background 0.3s;
  }
  .bar--scrolled {
    border-color: var(--border);
    background: color-mix(in oklab, var(--bg) 94%, transparent);
  }
  .bar__in {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 0.85rem var(--pad);
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--primary);
  }
  .brand__mark { color: var(--accent); display: inline-flex; }
  .brand__name {
    font-family: var(--display);
    font-size: 1.35rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .bar__nav {
    display: none;
    list-style: none;
    margin: 0 auto;
    padding: 0;
    gap: 2rem;
  }
  .bar__nav a {
    text-decoration: none;
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg);
    opacity: 0.75;
    transition: opacity 0.2s;
  }
  .bar__nav a:hover { opacity: 1; }
  .resv {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    background: var(--primary);
    color: var(--primary-fg);
    text-decoration: none;
    padding: 0.7rem 1.4rem;
    border-radius: 2px;
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    min-height: 44px;
    transition: background 0.25s, transform 0.25s;
  }
  .resv:hover { background: #232c26; transform: translateY(-1px); }
  .resv__dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--accent);
  }
  @media (min-width: 900px) {
    .bar__nav { display: flex; }
    .resv { margin-left: 0; }
  }

  /* ---- Buttons ---- */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    min-height: 44px;
    padding: 0.85rem 1.6rem;
    font-size: 0.82rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border-radius: 2px;
    transition: transform 0.25s, background 0.25s, color 0.25s;
  }
  .btn--solid { background: var(--primary); color: var(--primary-fg); border: 1px solid var(--primary); }
  .btn--solid:hover { background: #232c26; transform: translateY(-2px); }
  .btn--ghost { background: transparent; color: var(--primary); border: 1px solid var(--border); }
  .btn--ghost:hover { border-color: var(--primary); transform: translateY(-2px); }
  .btn--lg { padding: 1.05rem 2.2rem; }

  /* ---- Hero ---- */
  .hero {
    position: relative;
    max-width: var(--maxw);
    margin: 0 auto;
    padding: clamp(2.5rem, 7vw, 5rem) var(--pad) clamp(3rem, 6vw, 5rem);
  }
  .hero__img {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }
  .hero__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: grayscale(0.18) contrast(1.02) brightness(1.05);
    opacity: 0.5;
    animation: kenburns 22s ease-in-out infinite alternate;
  }
  @keyframes kenburns {
    from { transform: scale(1.04); }
    to { transform: scale(1.12) translateY(-1.5%); }
  }
  .hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, var(--bg) 30%, transparent 72%),
      linear-gradient(to top, var(--bg), transparent 45%);
    pointer-events: none;
  }
  .hero__grid {
    position: relative;
    z-index: 2;
    max-width: 42rem;
  }
  .hero__sub {
    font-size: clamp(1rem, 1.6vw, 1.18rem);
    max-width: 30rem;
    margin: 1.6rem 0 2rem;
    color: color-mix(in oklab, var(--fg) 78%, var(--bg));
  }
  .hero__cta { display: flex; flex-wrap: wrap; gap: 0.9rem; }
  .hero__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 2.4rem;
    margin: 2.8rem 0 0;
    padding-top: 1.8rem;
    border-top: 1px solid var(--border);
  }
  .hero__meta div { margin: 0; }
  .hero__meta dt {
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .hero__meta dd {
    margin: 0.3rem 0 0;
    font-family: var(--display);
    font-size: 1.3rem;
  }

  /* ---- Marquee ---- */
  .marquee {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: var(--primary);
    color: var(--primary-fg);
    overflow: hidden;
    white-space: nowrap;
  }
  .marquee__track {
    display: inline-flex;
    animation: slide 30s linear infinite;
  }
  .marquee__track span {
    font-family: var(--display);
    font-style: italic;
    font-size: 1.35rem;
    padding: 0.9rem 0;
    letter-spacing: 0.02em;
  }
  @keyframes slide {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* ---- Reveal ---- */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .reveal.in { opacity: 1; transform: none; }

  /* ---- Experience ---- */
  .exp {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: clamp(4rem, 9vw, 7rem) var(--pad);
    display: grid;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }
  @media (min-width: 860px) {
    .exp { grid-template-columns: 0.85fr 1fr; }
  }
  .exp__media { position: relative; }
  .exp__media img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    filter: grayscale(0.1) brightness(1.02);
    border-radius: 2px;
  }
  .exp__tag {
    position: absolute;
    bottom: 1rem; left: 1rem;
    background: color-mix(in oklab, var(--bg) 90%, transparent);
    backdrop-filter: blur(6px);
    padding: 0.4rem 0.8rem;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--primary);
    border: 1px solid var(--border);
  }
  .exp__copy p { margin: 1.2rem 0; max-width: 34rem; color: color-mix(in oklab, var(--fg) 82%, var(--bg)); }
  .exp__list {
    list-style: none;
    padding: 0;
    margin: 1.8rem 0 0;
    border-top: 1px solid var(--border);
  }
  .exp__list li {
    padding: 0.9rem 0 0.9rem 1.6rem;
    border-bottom: 1px solid var(--border);
    position: relative;
    font-size: 0.95rem;
  }
  .exp__list li::before {
    content: "";
    position: absolute;
    left: 0; top: 1.35rem;
    width: 7px; height: 7px;
    background: var(--accent);
    transform: rotate(45deg);
  }

  /* ---- Menu ---- */
  .menu {
    background: var(--muted);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .menu__head {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: clamp(4rem, 8vw, 6rem) var(--pad) 0;
    text-align: center;
  }
  .menu__lede { margin: 1rem auto 0; color: color-mix(in oklab, var(--fg) 70%, var(--bg)); }
  .menu__cols {
    max-width: 64rem;
    margin: 0 auto;
    padding: clamp(2.5rem, 5vw, 4rem) var(--pad) 0;
    display: grid;
    gap: clamp(2.5rem, 5vw, 4rem);
  }
  @media (min-width: 760px) {
    .menu__cols { grid-template-columns: 1fr 1fr; }
  }
  .course__title {
    font-style: italic;
    font-size: 1.7rem;
