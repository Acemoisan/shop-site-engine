---
import { site } from "../content/site";
---
<section id="how" class="scroll-mt-20 bg-background">
  <div class="mx-auto max-w-6xl px-6 py-20 sm:py-28">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">How it works</p>
      <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
        Three steps. Days, not months.
      </h2>
    </div>
    <div class="mt-14 grid gap-8 md:grid-cols-3">
      {site.how.map((s) => (
        <div class="relative rounded-[var(--radius)] border border-border bg-card p-8 shadow-sm">
          <span class="font-display text-5xl font-bold text-primary/15">{s.n}</span>
          <h3 class="mt-3 font-display text-xl font-semibold text-foreground">{s.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{s.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
