---
import { site } from "../content/site";
import Icon from "./Icon.astro";
---
<section id="benefits" class="scroll-mt-20 bg-muted">
  <div class="mx-auto max-w-6xl px-6 py-20 sm:py-28">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">What you get &amp; why us</p>
      <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
        A site that works as hard as you do
      </h2>
      <p class="mt-4 text-muted-foreground">No lock-in, no monthly bills, no jargon — just a fast site you own and can run yourself, built by someone local who gets Calgary shops.</p>
    </div>
    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {site.benefits.map((b) => (
        <div class="group rounded-[var(--radius)] border border-border bg-card p-7 shadow-sm transition hover:-translate-y-1 hover:shadow-md">
          <div class="grid h-11 w-11 place-items-center rounded-xl bg-primary/10 text-primary transition group-hover:bg-primary group-hover:text-primary-foreground">
            <Icon name={b.icon} class="h-5 w-5" />
          </div>
          <h3 class="mt-5 font-display text-lg font-semibold text-foreground">{b.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{b.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
