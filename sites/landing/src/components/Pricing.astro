---
import { site } from "../content/site";
import Icon from "./Icon.astro";
const p = site.pricing;
---
<section id="pricing" class="scroll-mt-20 bg-muted">
  <div class="mx-auto max-w-6xl px-6 py-20 sm:py-28">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">Pricing</p>
      <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-foreground sm:text-4xl">{p.heading}</h2>
    </div>
    <div class="mt-14 grid items-stretch gap-7 lg:grid-cols-3">
      {p.tiers.map((t) => (
        <div class={`relative flex flex-col rounded-2xl border p-8 shadow-sm ${t.featured ? "border-primary bg-card shadow-lg ring-2 ring-primary lg:-mt-4 lg:mb-4" : "border-border bg-card"}`}>
          {t.featured && (
            <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-primary px-3 py-1 text-xs font-semibold uppercase tracking-wider text-primary-foreground">Most popular</span>
          )}
          <h3 class="font-display text-xl font-bold text-foreground">{t.name}</h3>
          <p class="mt-1 text-sm text-muted-foreground">{t.blurb}</p>
          <div class="mt-5 flex items-end gap-1">
            <span class="font-display text-4xl font-bold text-foreground">{t.price}</span>
            <span class="pb-1 text-sm text-muted-foreground">{t.cadence}</span>
          </div>
          <ul class="mt-6 flex-1 space-y-3 text-sm">
            {t.features.map((f) => (
              <li class="flex items-start gap-2.5 text-foreground/90">
                <Icon name="check" class="mt-0.5 h-4 w-4 shrink-0 text-primary" />{f}
              </li>
            ))}
          </ul>
          <a href="#contact" class={`mt-8 rounded-[var(--radius)] px-5 py-3 text-center text-sm font-semibold transition ${t.featured ? "bg-primary text-primary-foreground hover:opacity-90" : "border border-border text-foreground hover:bg-muted"}`}>
            {t.cta}
          </a>
        </div>
      ))}
    </div>
    <p class="mx-auto mt-6 max-w-xl text-center text-sm font-medium text-foreground/80">
      <Icon name="shield" class="mr-1.5 inline h-4 w-4 -translate-y-0.5 text-primary" />{p.guarantee}
    </p>

    <!-- Total-cost-of-ownership: our sharpest contrast vs. the subscription crowd -->
    <div class="mx-auto mt-12 max-w-3xl rounded-2xl border border-border bg-card p-8 shadow-sm">
      <h3 class="text-center font-display text-xl font-bold tracking-tight text-foreground sm:text-2xl">{p.compare.heading}</h3>
      <p class="mx-auto mt-3 max-w-2xl text-center text-sm leading-relaxed text-muted-foreground">{p.compare.body}</p>
      <div class="mt-7 grid gap-4 sm:grid-cols-2">
        <div class="rounded-[var(--radius)] border border-border bg-muted/60 p-5 text-center">
          <p class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">{p.compare.them.label}</p>
          <p class="mt-2 font-display text-3xl font-bold text-foreground/60 line-through decoration-muted-foreground/40">{p.compare.them.value}</p>
          <p class="mt-1 text-xs text-muted-foreground">{p.compare.them.sub}</p>
        </div>
        <div class="rounded-[var(--radius)] border-2 border-primary bg-primary/5 p-5 text-center">
          <p class="text-xs font-semibold uppercase tracking-wider text-primary">{p.compare.us.label}</p>
          <p class="mt-2 font-display text-3xl font-bold text-primary">{p.compare.us.value}</p>
          <p class="mt-1 text-xs text-muted-foreground">{p.compare.us.sub}</p>
        </div>
      </div>
    </div>

    <p class="mt-8 text-center text-sm text-muted-foreground">{p.note}</p>
  </div>
</section>
