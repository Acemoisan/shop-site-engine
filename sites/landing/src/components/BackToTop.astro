---
import Icon from "./Icon.astro";
// Small back-to-top affordance — appears once the visitor has scrolled past the
// first viewport, scrolls to #top. Hidden from a11y tree until shown.
---
<a
  id="backToTop"
  href="#top"
  aria-label="Back to top"
  title="Back to top"
  class="fixed bottom-5 right-5 z-40 grid h-11 w-11 translate-y-3 place-items-center rounded-full border border-border bg-card text-foreground opacity-0 shadow-lg transition hover:border-primary/50 hover:text-primary [&.is-visible]:translate-y-0 [&.is-visible]:opacity-100"
  tabindex="-1"
  aria-hidden="true"
>
  <Icon name="arrow-up" class="h-5 w-5" />
</a>
<script is:inline>
  (function () {
    var btn = document.getElementById("backToTop");
    if (!btn) return;
    function update() {
      var show = window.scrollY > window.innerHeight * 0.9;
      btn.classList.toggle("is-visible", show);
      btn.setAttribute("aria-hidden", show ? "false" : "true");
      btn.setAttribute("tabindex", show ? "0" : "-1");
    }
    update();
    window.addEventListener("scroll", update, { passive: true });
  })();
</script>
