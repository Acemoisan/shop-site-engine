---
import { site } from "../content/site";
const f = site.founder;
const initials = f.name.split(" ").map((p) => p[0]).join("").slice(0, 2);
---
<section id="founder" class="scroll-mt-20 bg-muted">
  <div class="mx-auto max-w-4xl px-6 py-20 sm:py-24">
    <div class="rounded-2xl border border-border bg-card p-8 shadow-sm sm:p-10">
      <div class="flex flex-col gap-7 sm:flex-row sm:items-start">
        <div class="shrink-0">
          {f.photo ? (
            <img src={f.photo} alt={f.name} width="96" height="96" class="h-24 w-24 rounded-2xl object-cover" loading="lazy" />
          ) : (
            <div class="grid h-24 w-24 place-items-center rounded-2xl bg-primary font-display text-3xl font-bold text-primary-foreground" aria-hidden="true">
              {initials}
            </div>
          )}
        </div>
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">Who you're hiring</p>
          {f.body.map((para) => (
            <p class="mt-4 text-lg leading-relaxed text-foreground/90">{para}</p>
          ))}
          <p class="mt-5 font-display text-base font-semibold text-foreground">{f.signature}</p>
          <p class="text-sm text-muted-foreground">{f.name} · {f.role}</p>
        </div>
      </div>
    </div>
  </div>
</section>
