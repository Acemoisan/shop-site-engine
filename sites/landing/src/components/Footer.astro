---
import { site } from "../content/site";
---
<footer class="border-t border-border bg-background">
  <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-6 px-6 py-10 sm:flex-row">
    <a href="#top" class="flex items-center gap-2 font-display text-base font-bold tracking-tight text-foreground">
      <span class="grid h-6 w-6 place-items-center rounded-full bg-primary text-primary-foreground">
        <span class="h-2 w-2 rounded-full bg-accent ring-2 ring-primary-foreground/40"></span>
      </span>
      {site.brand}
    </a>
    <nav class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-muted-foreground">
      {site.nav.map((n) => (
        <a href={n.href} class="transition hover:text-foreground">{n.label}</a>
      ))}
      <a href={`mailto:${site.email}`} class="transition hover:text-foreground">Contact</a>
      <a href="/privacy" class="transition hover:text-foreground">Privacy</a>
      {site.phone && (
        <a href={`tel:${site.phone.replace(/[^0-9+]/g, "")}`} class="transition hover:text-foreground">{site.phone}</a>
      )}
    </nav>
    <p class="text-xs text-muted-foreground">© {site.brand} · {site.location} · {site.serviceArea}</p>
  </div>
</footer>
