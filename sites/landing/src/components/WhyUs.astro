---
import { site } from "../content/site";
import Icon from "./Icon.astro";
const w = site.why;
---
<section class="bg-background">
  <div class="mx-auto max-w-6xl px-6 py-20 sm:py-28">
    <div class="grid gap-12 lg:grid-cols-[1fr_1.4fr] lg:items-start">
      <div class="lg:sticky lg:top-28">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">Why us</p>
        <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-foreground sm:text-4xl">{w.heading}</h2>
        <p class="mt-4 max-w-md text-muted-foreground">No lock-in, no monthly bills, no jargon. Just a great site you own and can run yourself.</p>
      </div>
      <div class="grid gap-5 sm:grid-cols-2">
        {w.points.map((pt) => (
          <div class="rounded-[var(--radius)] border border-border bg-card p-6 shadow-sm">
            <div class="grid h-9 w-9 place-items-center rounded-lg bg-accent/20 text-accent-foreground">
              <Icon name="check" class="h-5 w-5" />
            </div>
            <h3 class="mt-4 font-display text-base font-semibold text-foreground">{pt.title}</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">{pt.body}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
