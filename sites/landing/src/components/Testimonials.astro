---
import { site } from "../content/site";
const t = site.testimonials;
// Never render sample/placeholder reviews. Real quotes only: drop `placeholder` (or set it false)
// in site.ts once entries are real and client-approved. Until then this whole section is omitted.
const items = t.placeholder ? [] : (t.items ?? []);
---
{items.length > 0 && (
<section id="reviews" class="scroll-mt-20 bg-muted">
  <div class="mx-auto max-w-6xl px-6 py-20 sm:py-28">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">Reviews</p>
      <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-foreground sm:text-4xl">{t.heading}</h2>
      <p class="mt-4 text-muted-foreground">{t.sub}</p>
    </div>

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {items.map((r) => (
        <figure class="flex flex-col rounded-2xl border border-border bg-card p-7 shadow-sm">
          <div class="flex gap-0.5 text-accent" aria-label={`${r.rating} out of 5 stars`}>
            {Array.from({ length: 5 }).map((_, i) => (
              <span aria-hidden="true" class={i < r.rating ? "text-accent" : "text-muted-foreground/30"}>★</span>
            ))}
          </div>
          <blockquote class="mt-4 flex-1 text-sm leading-relaxed text-foreground/90">“{r.quote}”</blockquote>
          <figcaption class="mt-5 border-t border-border pt-4">
            <p class="font-display text-sm font-semibold text-foreground">{r.name}</p>
            <p class="text-xs text-muted-foreground">{r.business} · {r.area}</p>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
)}
