---
import { site } from "../content/site";
import Icon from "./Icon.astro";
const w = site.work;
---
<section id="work" class="scroll-mt-20 bg-muted">
  <div class="mx-auto max-w-6xl px-6 py-20 sm:py-28">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">Work</p>
      <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-foreground sm:text-4xl">{w.heading}</h2>
      <p class="mt-4 text-muted-foreground">{w.sub}</p>
    </div>
    <div class="mt-12 grid gap-7 sm:grid-cols-2">
      {w.items.map((item) => (
        <a href={item.href} class="group relative overflow-hidden rounded-2xl border border-border bg-card shadow-sm transition hover:shadow-lg">
          <div class="aspect-[16/10] overflow-hidden">
            <img src={item.image} alt={item.name} loading="lazy" class="h-full w-full object-cover transition duration-500 group-hover:scale-105" />
          </div>
          <div class="flex items-center justify-between p-6">
            <div>
              <h3 class="font-display text-lg font-semibold text-foreground">{item.name}</h3>
              <p class="text-sm text-muted-foreground">{item.vertical}</p>
            </div>
            <span class="grid h-9 w-9 place-items-center rounded-full bg-primary/10 text-primary transition group-hover:bg-primary group-hover:text-primary-foreground">
              <Icon name="arrow" class="h-4 w-4" />
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
