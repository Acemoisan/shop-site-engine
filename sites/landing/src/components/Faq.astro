---
import { site } from "../content/site";
import Icon from "./Icon.astro";
---
<section id="faq" class="scroll-mt-20 bg-background">
  <div class="mx-auto max-w-3xl px-6 py-20 sm:py-28">
    <div class="text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">FAQ</p>
      <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-foreground sm:text-4xl">Questions, answered</h2>
    </div>
    <div class="mt-12 divide-y divide-border rounded-2xl border border-border bg-card">
      {site.faqs.map((f) => (
        <details class="group px-6">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-5 font-medium text-foreground">
            {f.q}
            <Icon name="arrow" class="h-4 w-4 shrink-0 rotate-90 text-muted-foreground transition group-open:-rotate-90" />
          </summary>
          <p class="-mt-1 pb-5 text-sm leading-relaxed text-muted-foreground">{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>
