---
import "../../styles/base.css";
import "../../theme.css";
import { site } from "../../content/site";
import templates from "../../data/templates.json";

// Group templates by industry, preserving the manifest order.
const groups: { title: string; items: any[] }[] = [];
for (const t of templates as any[]) {
  let g = groups.find((x) => x.title === t.categoryTitle);
  if (!g) { g = { title: t.categoryTitle, items: [] }; groups.push(g); }
  g.items.push(t);
}
const title = `Website templates — ${site.brand}`;
const description = `Browse ${(templates as any[]).length} example website designs across ${groups.length} industries. Every one is fast, mobile-first, and built on our engine.`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#5b4fe6" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-background font-sans text-foreground antialiased">
    <header class="sticky top-0 z-50 border-b border-border/60 bg-background/85 backdrop-blur-md">
      <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
        <a href="/" class="flex items-center gap-2 font-display text-lg font-bold tracking-tight text-foreground">
          <span class="grid h-7 w-7 place-items-center rounded-full bg-primary text-primary-foreground">
            <span class="h-2.5 w-2.5 rounded-full bg-accent ring-2 ring-primary-foreground/40"></span>
          </span>
          {site.brand}
        </a>
        <div class="flex items-center gap-5 text-sm font-medium">
          <a href="/" class="text-muted-foreground transition hover:text-foreground">← Back to site</a>
          <a href="/#contact" class="rounded-[var(--radius)] bg-primary px-4 py-2 font-semibold text-primary-foreground shadow-sm transition hover:opacity-90">Free audit</a>
        </div>
      </nav>
    </header>

    <section class="border-b border-border bg-muted/40">
      <div class="mx-auto max-w-7xl px-6 py-16 sm:py-20">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">Template gallery</p>
        <h1 class="mt-3 max-w-3xl font-display text-4xl font-bold leading-tight tracking-tight sm:text-5xl">
          {(templates as any[]).length} website designs across {groups.length} industries.
        </h1>
        <p class="mt-5 max-w-2xl text-lg text-muted-foreground">
          Examples of what we build — three distinct directions per industry. Click any template to open the full live page. Your site is custom-built on the same fast, mobile-first engine and is yours to own and edit.
        </p>
        <a href="/#contact" class="mt-8 inline-flex items-center gap-2 rounded-[var(--radius)] bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground shadow transition hover:opacity-90">
          Get a free audit & quote
        </a>
      </div>
    </section>

    <main class="mx-auto max-w-7xl px-6 pb-24">
      {groups.map((g) => (
        <section class="mt-14">
          <h2 class="flex items-center gap-3 border-b border-border pb-3 font-display text-sm font-semibold uppercase tracking-[0.12em] text-foreground/80">
            {g.title}
            <span class="rounded-full bg-muted px-2.5 py-0.5 text-xs font-medium text-muted-foreground">{g.items.length}</span>
          </h2>
          <div class="tg-grid mt-6">
            {g.items.map((t) => (
              <a class="tg-card group" href={`/templates/g/${t.slug}/`} target="_blank" rel="noopener" aria-label={`Open ${t.brandName} (${t.variant}) template`}>
                <div class="tg-thumb">
                  <iframe class="tg-frame" src={`/templates/g/${t.slug}/`} loading="lazy" tabindex="-1" title={`${t.brandName} preview`} aria-hidden="true"></iframe>
                  <span class="tg-open">Open ↗</span>
                </div>
                <div class="p-4">
                  <div class="flex items-baseline justify-between gap-2">
                    <strong class="font-display text-sm font-semibold text-foreground">{t.brandName}</strong>
                    <span class="shrink-0 rounded-full bg-primary/10 px-2 py-0.5 text-[11px] font-medium capitalize text-primary">{t.variant}</span>
                  </div>
                  <p class="mt-1.5 line-clamp-2 text-xs leading-relaxed text-muted-foreground">{t.direction}</p>
                </div>
              </a>
            ))}
          </div>
        </section>
      ))}
    </main>

    <footer class="border-t border-border bg-foreground text-background">
      <div class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-4 px-6 py-12 text-center sm:flex-row sm:text-left">
        <div>
          <p class="font-display text-xl font-bold">See one you like?</p>
          <p class="mt-1 text-background/70">We'll tailor it to your shop, your brand, your content — and you own it.</p>
        </div>
        <a href="/#contact" class="rounded-[var(--radius)] bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground transition hover:opacity-90">Start with a free audit</a>
      </div>
    </footer>

    <style>
      .tg-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.25rem; }
      .tg-card { display: block; overflow: hidden; border: 1px solid var(--border); border-radius: 1rem; background: var(--card); box-shadow: 0 1px 2px rgba(0,0,0,.04); transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease; }
      .tg-card:hover { transform: translateY(-3px); box-shadow: 0 14px 34px rgba(0,0,0,.12); border-color: color-mix(in oklab, var(--primary) 45%, var(--border)); }
      .tg-thumb { position: relative; aspect-ratio: 16 / 10; overflow: hidden; background: var(--muted); border-bottom: 1px solid var(--border); }
      /* Render the live page at desktop width and scale it down as a thumbnail. */
      .tg-frame { position: absolute; top: 0; left: 0; width: 1440px; height: 900px; border: 0; transform: scale(0.212); transform-origin: top left; pointer-events: none; }
      .tg-open { position: absolute; right: .6rem; bottom: .6rem; opacity: 0; transform: translateY(4px); transition: opacity .18s ease, transform .18s ease; background: var(--primary); color: var(--primary-foreground); font-size: 11px; font-weight: 600; padding: .25rem .55rem; border-radius: 999px; }
      .tg-card:hover .tg-open { opacity: 1; transform: translateY(0); }
      .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
      @media (max-width: 640px) { .tg-frame { transform: scale(0.30); } }
    </style>
  </body>
</html>
