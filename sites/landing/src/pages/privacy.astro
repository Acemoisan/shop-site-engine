---
import "../styles/base.css";
import "../theme.css";
import Head from "../components/Head.astro";
import { site } from "../content/site";

// PIPA cross-border notice (Web3Forms + Netlify are US-based). Inlined rather than
// using the shared PrivacyNotice component because landing's base.css only @sources
// its own components/pages (not the shared package), so cross-package utility
// classes wouldn't be generated. Legal text mirrors docs/onboarding/privacy-notice-template.md.
const items = [
  { h: "What we collect", b: "When you use our contact form we collect the information you submit — typically your name, email, phone (if provided), and message. Our host may also log standard technical data (e.g. IP address) to serve the site." },
  { h: "Why we collect it", b: "We use it only to receive and respond to your enquiry. We do not sell it or use it for unrelated purposes without your consent." },
  { h: "Consent", b: "Submitting the form means you consent to this use." },
  { h: "Service providers outside Canada", b: "Our contact form is processed by Web3Forms and our website is hosted on Netlify, both based in the United States. As a result, your information may be stored, processed, or accessed outside Canada and may be subject to the laws of that country." },
  { h: "Access to our policies", b: "To learn more about how we use these service providers, contact us using the details below." },
  { h: "Privacy contact", b: `Questions, or to access or correct your information: ${site.brand} — ${site.email}.` },
  { h: "Retention", b: "We keep enquiry messages only as long as needed to respond and for reasonable follow-up, then delete them." },
];
---
<html lang="en">
  <head>
    <Head title="Privacy Notice — Studio0rbit" description="How Studio0rbit handles your personal information, in line with Alberta's Personal Information Protection Act (PIPA)." path="/privacy" />
  </head>
  <body class="bg-background text-foreground font-sans antialiased">
    <main class="mx-auto max-w-3xl px-6 py-16 sm:py-24">
      <a href="/" class="font-mono text-xs uppercase tracking-[0.2em] text-muted-foreground transition hover:text-primary">← Back to {site.brand}</a>
      <p class="mt-10 font-mono text-xs uppercase tracking-[0.3em] text-primary">Privacy</p>
      <h1 class="mt-3 font-display text-4xl font-bold tracking-tight text-foreground sm:text-5xl">Privacy notice</h1>
      <p class="mt-5 max-w-xl text-base leading-relaxed text-muted-foreground">
        We respect your privacy and handle personal information in line with Alberta's <em>Personal Information Protection Act</em> (PIPA).
      </p>
      <div class="mt-12 space-y-8">
        {items.map((it, i) => (
          <section>
            <h2 class="flex items-baseline gap-3 font-display text-xl font-bold text-foreground">
              <span class="font-mono text-sm text-accent">{String(i + 1).padStart(2, "0")}</span>
              {it.h}
            </h2>
            <p class="mt-2 leading-relaxed text-muted-foreground">{it.b}</p>
          </section>
        ))}
      </div>
      <p class="mt-14 border-t border-border pt-6 font-mono text-[0.7rem] uppercase tracking-[0.15em] text-muted-foreground">
        Last updated: June 2026 · {site.brand}
      </p>
    </main>
  </body>
</html>
