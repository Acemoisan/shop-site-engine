---
import "../styles/base.css";
import "../theme.css";
import { site } from "../content/site";
import Head from "../components/Head.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Problem from "../components/Problem.astro";
import Benefits from "../components/Benefits.astro";
import HowItWorks from "../components/HowItWorks.astro";
import Testimonials from "../components/Testimonials.astro";
import Pricing from "../components/Pricing.astro";
import Templates from "../components/Templates.astro";
import Faq from "../components/Faq.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import BackToTop from "../components/BackToTop.astro";

const title = `${site.brand} — Websites for ${site.city} shops, built fast & owned by you`;
const description = "A fast, mobile-first website for your Calgary shop — built once for one fair price, no monthly fees. You own the site, the domain, everything. Free audit, no obligation.";
const siteUrl = (Astro.site ?? new URL("https://studio0rbit-audit.netlify.app")).origin;
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "@id": `${siteUrl}/#business`,
  name: site.brand,
  description,
  areaServed: { "@type": "City", name: site.city },
  address: { "@type": "PostalAddress", addressLocality: site.city, addressRegion: "AB", addressCountry: "CA" },
  email: site.email,
  ...(site.phone ? { telephone: site.phone } : {}),
  founder: { "@type": "Person", name: site.founder.name },
  serviceType: "Web design for local businesses",
  url: siteUrl,
  image: `${siteUrl}/og.png`,
  priceRange: "$$",
  knowsAbout: ["Web design", "Local SEO", "Conversion optimization", "Small business websites"],
};
---
<!doctype html>
<html lang="en">
  <head>
    <Head title={title} description={description} path="/" jsonLd={jsonLd} />
  </head>
  <body id="top" class="bg-background font-sans text-foreground antialiased">
    <a href="#main" class="skip-link">Skip to content</a>
    <Nav />
    <main id="main">
      <Hero />
      <Problem />
      <Benefits />
      <HowItWorks />
      <Testimonials />
      <Pricing />
      <Templates />
      <Faq />
      <Contact />
    </main>
    <Footer />
    <BackToTop />
  </body>
</html>
