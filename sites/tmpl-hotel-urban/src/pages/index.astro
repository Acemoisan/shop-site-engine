---
const nav = [
  { label: "Rooms", href: "#rooms" },
  { label: "Dining", href: "#dining" },
  { label: "Experiences", href: "#amenities" },
  { label: "Gallery", href: "#gallery" },
  { label: "Offers", href: "#offers" },
  { label: "Contact", href: "#contact" },
];

const rooms = [
  {
    name: "The Loft",
    blurb: "Split-level corner suite with floor-to-ceiling skyline windows and a deep soaking tub above the lights.",
    rate: "510",
    seed: "marisol-loft",
    features: ["Skyline windows", "Soaking tub", "Split level"],
  },
  {
    name: "Signature Spa Suite",
    blurb: "In-room rainfall shower, plush robes, and daily turndown — a private spa suspended over the avenue.",
    rate: "560",
    seed: "marisol-spa",
    features: ["Rainfall shower", "Robes", "Turndown"],
  },
  {
    name: "Garden View King",
    blurb: "A calm, light-filled refuge opening to the courtyard — quiet within the hum of the city.",
    rate: "245",
    seed: "marisol-king",
    features: ["Courtyard view", "King bed", "Workspace"],
  },
];

const amenities = [
  { title: "Rooftop Spa", note: "Daily 9 AM – 8 PM", d: "M12 2a7 7 0 00-7 7c0 5 7 13 7 13s7-8 7-13a7 7 0 00-7-7z" },
  { title: "Concierge", note: "24-hour service", d: "M3 12h18M12 3v18" },
  { title: "Sky Bar", note: "Dinner 5:30–10 PM", d: "M5 3h14l-7 9v7m-3 0h6" },
  { title: "Fast Wi-Fi", note: "Throughout the tower", d: "M2 8c6-5 14-5 20 0M5 12c4-3 10-3 14 0M9 16c2-1.5 4-1.5 6 0" },
];

const offers = [
  { name: "Two-Night Slow Escape", note: "Breakfast + late checkout", price: "560" },
  { name: "Spa & Stay", note: "60-min treatment for two", price: "690" },
  { name: "Romance Retreat", note: "Champagne, rose turndown, dinner for two", price: "740" },
];

const testimonials = [
  { quote: "The most restful three nights we've had in years. The staff remembered our names by morning.", who: "Priya & Daniel R." },
  { quote: "Every window framed something beautiful. We're already planning our return.", who: "Marcus T." },
  { quote: "Quiet, warm, and effortlessly elegant — exactly what a getaway should feel like.", who: "Lena O." },
];

const gallery = ["g-foyer", "g-bar", "g-suite", "g-pool", "g-detail", "g-night"];
const awards = ["Condé Nast Gold List", "Travel + Leisure 2025", "Michelin Key", "Forbes Five-Star"];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>The Marisol — Your Sanctuary Above the City | Boutique Urban Hotel</title>
    <meta
      name="description"
      content="The Marisol is a boutique urban tower hotel — a sanctuary above the city. Skyline suites, a rooftop spa, and a candlelit sky bar. Reserve your escape."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Jost:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>

    <header class="nav" id="top">
      <div class="nav-inner">
        <a class="brand" href="#top" aria-label="The Marisol home">
          <span class="brand-mark" aria-hidden="true"></span>
          <span class="brand-name">The Marisol</span>
        </a>
        <nav class="nav-links" aria-label="Primary">
          {nav.map((n) => <a href={n.href}>{n.label}</a>)}
        </nav>
        <a class="btn btn-sm" href="#book">Book</a>
        <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
          <span></span><span></span>
        </button>
      </div>
      <nav class="nav-drawer" aria-label="Mobile">
        {nav.map((n) => <a href={n.href}>{n.label}</a>)}
        <a class="btn" href="#book">Book a Stay</a>
      </nav>
    </header>

    <main id="main">
      <!-- HERO -->
      <section class="hero">
        <div class="hero-img" aria-hidden="true"></div>
        <div class="hero-scrim" aria-hidden="true"></div>
        <div class="hero-content">
          <p class="eyebrow reveal">Marisol Hotels &amp; Retreats · Urban Tower</p>
          <h1 class="reveal">Your sanctuary<br /><em>above the city.</em></h1>
          <p class="hero-tag reveal">A boutique escape, intimately yours — forty floors over the avenue.</p>
        </div>

        <!-- BOOKING BAR -->
        <form class="bookbar reveal" id="book" aria-label="Check availability">
          <div class="field">
            <label for="ci">Check in</label>
            <input id="ci" type="date" value="2026-07-10" />
          </div>
          <div class="field">
            <label for="co">Check out</label>
            <input id="co" type="date" value="2026-07-12" />
          </div>
          <div class="field">
            <label for="g">Guests</label>
            <select id="g">
              <option>2 guests</option>
              <option>1 guest</option>
              <option>3 guests</option>
              <option>4 guests</option>
            </select>
          </div>
          <button class="btn" type="submit">Check Availability</button>
        </form>
      </section>

      <!-- STORY -->
      <section class="story" aria-labelledby="story-h">
        <div class="story-text reveal">
          <p class="eyebrow">The Property</p>
          <h2 id="story-h">Stay a while.<br />The world can wait.</h2>
          <p>
            Set within a restored deco tower, The Marisol trades the lobby crush for hush and brass.
            Tungsten light pools against dark walnut, the city flickers below the glass, and every
            suite is a low-lit room of one's own — high above the noise it answers.
          </p>
          <p class="story-sign">— Marisol Hotels &amp; Retreats</p>
        </div>
        <div class="story-img reveal" aria-hidden="true"></div>
      </section>

      <!-- ROOMS -->
      <section class="rooms" id="rooms" aria-labelledby="rooms-h">
        <div class="section-head">
          <p class="eyebrow">Rooms &amp; Suites</p>
          <h2 id="rooms-h">Rooms with a view of the night.</h2>
        </div>
        <div class="room-grid">
          {rooms.map((r) => (
            <article class="room reveal">
              <div class="room-img" style={`background-image:url(https://picsum.photos/seed/${r.seed}/720/560)`} role="img" aria-label={`${r.name} interior`}></div>
              <div class="room-body">
                <h3>{r.name}</h3>
                <p>{r.blurb}</p>
                <ul class="room-feats">
                  {r.features.map((f) => <li>{f}</li>)}
                </ul>
                <div class="room-foot">
                  <span class="rate"><small>from</small> ${r.rate}<small>/night</small></span>
                  <a class="btn btn-outline btn-sm" href="#book">Reserve</a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>

      <!-- AMENITIES -->
      <section class="amen" id="amenities" aria-labelledby="amen-h">
        <div class="section-head">
          <p class="eyebrow">Experiences</p>
          <h2 id="amen-h">Everything within reach, nothing out of place.</h2>
        </div>
        <div class="amen-grid">
          {amenities.map((a) => (
            <div class="amen-card reveal">
              <svg viewBox="0 0 24 24" aria-hidden="true" class="amen-icon">
                <path d={a.d} fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <h3>{a.title}</h3>
              <p>{a.note}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- DINING -->
      <section class="dining" id="dining" aria-labelledby="dining-h">
        <div class="dining-img reveal" aria-hidden="true"></div>
        <div class="dining-text reveal">
          <p class="eyebrow">The Sky Bar</p>
          <h2 id="dining-h">Dinner, served at altitude.</h2>
          <p>
            Forty floors up, our candlelit room turns the skyline into a centerpiece. A short,
            seasonal menu, a deep cellar, and a bar that runs late — long after the avenue dims.
          </p>
          <ul class="menu">
            <li><span>Charred octopus, smoked paprika</span><span class="dot"></span><strong>$28</strong></li>
            <li><span>Dry-aged ribeye, bone marrow</span><span class="dot"></span><strong>$62</strong></li>
            <li><span>Brass Negroni, barrel-aged</span><span class="dot"></span><strong>$19</strong></li>
          </ul>
          <p class="hours-note">Breakfast 7–11 AM · Dinner 5:30–10 PM</p>
        </div>
      </section>

      <!-- GALLERY -->
      <section class="gallery" id="gallery" aria-labelledby="gallery-h">
        <div class="section-head">
          <p class="eyebrow">Gallery</p>
          <h2 id="gallery-h">A look inside the tower.</h2>
        </div>
        <div class="masonry">
          {gallery.map((g, i) => (
            <figure class={`tile tile-${i % 3} reveal`}>
              <img src={`https://picsum.photos/seed/${g}/600/${i % 2 ? 760 : 540}`} alt="The Marisol interiors and views" loading="lazy" />
            </figure>
          ))}
        </div>
      </section>

      <!-- OFFERS -->
      <section class="offers" id="offers" aria-labelledby="offers-h">
        <div class="section-head">
          <p class="eyebrow">Offers &amp; Packages</p>
          <h2 id="offers-h">Book direct, stay better.</h2>
          <p class="brg">Best-rate guarantee on every direct reservation.</p>
        </div>
        <div class="offer-grid">
          {offers.map((o, i) => (
            <article class={`offer reveal ${i === 0 ? "offer-feat" : ""}`}>
              {i === 0 && <span class="badge">Most booked</span>}
              <h3>{o.name}</h3>
              <p>{o.note}</p>
              <span class="rate"><small>from</small> ${o.price}</span>
              <a class="btn btn-sm" href="#book">Add this package</a>
            </article>
          ))}
        </div>
      </section>

      <!-- SOCIAL PROOF -->
      <section class="proof" aria-labelledby="proof-h">
        <div class="awards" aria-label="Awards and press">
          {awards.map((a) => <span class="award">{a}</span>)}
        </div>
        <h2 id="proof-h" class="sr-only">Guest reviews</h2>
        <div class="slider" data-slider>
          {testimonials.map((t, i) => (
            <blockquote class={`slide ${i === 0 ? "active" : ""}`} data-slide={i}>
              <div class="stars" aria-label="Five stars">★★★★★</div>
              <p>“{t.quote}”</p>
              <cite>{t.who}</cite>
            </blockquote>
          ))}
        </div>
        <div class="dots" role="tablist" aria-label="Reviews">
          {testimonials.map((_, i) => (
            <button class={`dot-btn ${i === 0 ? "active" : ""}`} data-dot={i} aria-label={`Review ${i + 1}`}></button>
          ))}
        </div>
      </section>

      <!-- CONTACT / NAP -->
      <section class="contact" id="contact" aria-labelledby="contact-h">
        <div class="contact-text reveal">
          <p class="eyebrow">Location &amp; Contact</p>
          <h2 id="contact-h">Find us in the heart of it all.</h2>
          <address>
            The Marisol<br />
            148 Shoreline Drive, Tofino, BC V0R 2Z0
          </address>
          <dl class="hours">
            <div><dt>Front Desk</dt><dd>24 hours</dd></div>
            <div><dt>Check-in</dt><dd>3:00 PM</dd></div>
            <div><dt>Check-out</dt><dd>11:00 AM</dd></div>
            <div><dt>Spa</dt><dd>Daily 9 AM – 8 PM</dd></div>
          </dl>
          <div class="contact-cta">
            <a class="btn" href="tel:+12505550192">Call (250) 555-0192</a>
            <a class="btn btn-outline" href="mailto:hello@marisolhotels.com">Email Reservations</a>
          </div>
        </div>
        <a
          class="map reveal"
          href="https://maps.google.com/?q=148+Shoreline+Drive+Tofino+BC"
          target="_blank"
          rel="noopener"
          aria-label="View The Marisol on the map"
        >
          <span class="map-pin" aria-hidden="true"></span>
          <span class="map-label">Open map</span>
        </a>
      </section>
    </main>

    <footer class="foot">
      <div class="foot-inner">
        <div>
          <span class="brand-name">The Marisol</span>
          <p>A boutique escape, intimately yours.</p>
        </div>
        <p class="foot-nap">148 Shoreline Drive, Tofino, BC · (250) 555-0192</p>
        <p class="foot-copy">© 2026 Marisol Hotels &amp; Retreats. All rights reserved.</p>
      </div>
    </footer>

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Hotel",
        name: "The Marisol",
        description: "A boutique urban tower hotel — your sanctuary above the city.",
        telephone: "+1-250-555-0192",
        email: "hello@marisolhotels.com",
        address: {
          "@type": "PostalAddress",
          streetAddress: "148 Shoreline Drive",
          addressLocality: "Tofino",
          addressRegion: "BC",
          postalCode: "V0R 2Z0",
          addressCountry: "CA",
        },
        starRating: { "@type": "Rating", ratingValue: "5" },
      })}
    />

    <script>
      // Mobile nav
      const toggle = document.querySelector(".nav-toggle");
      const drawer = document.querySelector(".nav-drawer");
      toggle?.addEventListener("click", () => {
        const open = drawer?.classList.toggle("open");
        toggle.setAttribute("aria-expanded", String(!!open));
      });
      drawer?.querySelectorAll("a").forEach((a) =>
        a.addEventListener("click", () => {
          drawer.classList.remove("open");
          toggle?.setAttribute("aria-expanded", "false");
        })
      );

      // Sticky nav state
      const header = document.querySelector(".nav");
      const onScroll = () => header?.classList.toggle("scrolled", window.scrollY > 40);
      onScroll();
      window.addEventListener("scroll", onScroll, { passive: true });

      // Scroll reveal
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const items = document.querySelectorAll(".reveal");
      if (reduce) {
        items.forEach((el) => el.classList.add("in"));
      } else {
        const io = new IntersectionObserver(
          (entries) => entries.forEach((e) => e.isIntersecting && e.target.classList.add("in")),
          { threshold: 0.12 }
        );
        items.forEach((el) => io.observe(el));
      }

      // Testimonial slider
      const slides = Array.from(document.querySelectorAll("[data-slide]"));
      const dots = Array.from(document.querySelectorAll("[data-dot]"));
      let cur = 0;
      const go = (n) => {
        cur = (n + slides.length) % slides.length;
        slides.forEach((s, i) => s.classList.toggle("active", i === cur));
        dots.forEach((d, i) => d.classList.toggle("active", i === cur));
      };
      dots.forEach((d, i) => d.addEventListener("click", () => go(i)));
      if (slides.length > 1 && !reduce) setInterval(() => go(cur + 1), 5500);
    </script>

    <style is:global>
      *, *::before, *::after { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body { margin: 0; }
      img { display: block; max-width: 100%; }
      @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
        * { animation: none !important; transition: none !important; }
      }
    </style>

    <style>
      :root {
        --bg: #16181c;
        --fg: #ece8e1;
        --primary: #c2a36b;
        --primary-fg: #16181c;
        --accent: #7e8b94;
        --muted: #23262c;
        --border: #33373e;
        --font-display: "Cormorant Garamond", Georgia, serif;
        --font-body: "Jost", system-ui, sans-serif;
        --maxw: 1200px;
      }

      body {
        background: var(--bg);
        color: var(--fg);
        font-family: var(--font-body);
        font-weight: 300;
        line-height: 1.7;
        letter-spacing: 0.01em;
        -webkit-font-smoothing: antialiased;
      }

      h1, h2, h3 { font-family: var(--font-display); font-weight: 500; line-height: 1.05; margin: 0; }
      h2 { font-size: clamp(2rem, 5vw, 3.4rem); }
      h3 { font-size: clamp(1.3rem, 2.4vw, 1.7rem); }
      p { margin: 0 0 1rem; }
      em { font-style: italic; color: var(--primary); }

      .eyebrow {
        font-size: 0.72rem; letter-spacing: 0.32em; text-transform: uppercase;
        color: var(--primary); font-weight: 500; margin: 0 0 1rem;
      }

      .sr-only {
        position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
        overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0;
      }
      .skip {
        position: absolute; left: 1rem; top: -3rem; z-index: 100;
        background: var(--primary); color: var(--primary-fg);
        padding: 0.6rem 1rem; border-radius: 4px; transition: top 0.2s;
      }
      .skip:focus { top: 1rem; }

      a { color: inherit; }
      :focus-visible { outline: 2px solid var(--primary); outline-offset: 3px; border-radius: 2px; }

      .btn {
        display: inline-flex; align-items: center; justify-content: center;
        min-height: 44px; padding: 0 1.6rem;
        background: var(--primary); color: var(--primary-fg);
        font-family: var(--font-body); font-weight: 500; font-size: 0.82rem;
        letter-spacing: 0.16em; text-transform: uppercase; text-decoration: none;
        border: 1px solid var(--primary); border-radius: 2px; cursor: pointer;
        transition: background 0.25s, color 0.25s, transform 0.25s;
      }
      .btn:hover { background: transparent; color: var(--primary); transform: translateY(-2px); }
      .btn-sm { min-height: 40px; padding: 0 1.1rem; font-size: 0.72rem; }
      .btn-outline { background: transparent; color: var(--fg); border-color: var(--border); }
      .btn-outline:hover { border-color: var(--primary); color: var(--primary); background: transparent; }

      /* NAV */
      .nav { position: sticky; top: 0; z-index: 50; transition: background 0.3s, border-color 0.3s; border-bottom: 1px solid transparent; }
      .nav.scrolled { background: rgba(22, 24, 28, 0.9); backdrop-filter: blur(12px); border-bottom-color: var(--border); }
      .nav-inner {
        max-width: var(--maxw); margin: 0 auto; padding: 1.1rem 1.4rem;
        display: flex; align-items: center; gap: 1.5rem;
      }
      .brand { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; margin-right: auto; }
      .brand-mark {
        width: 22px; height: 22px; border: 1px solid var(--primary); border-radius: 50%;
        position: relative;
      }
      .brand-mark::after {
        content: ""; position: absolute; inset: 5px; background: var(--primary);
        border-radius: 50%;
      }
      .brand-name { font-family: var(--font-display); font-size: 1.35rem; letter-spacing: 0.04em; }
      .nav-links { display: none; gap: 1.8rem; }
      .nav-links a {
        text-decoration: none; font-size: 0.78rem; letter-spacing: 0.14em;
        text-transform: uppercase; color: var(--fg); opacity: 0.8; transition: opacity 0.2s, color 0.2s;
      }
      .nav-links a:hover { opacity: 1; color: var(--primary); }
      .nav .btn-sm { display: none; }
      .nav-toggle {
        display: flex; flex-direction: column; gap: 5px; width: 44px; height: 44px;
        align-items: center; justify-content: center; background: none; border: 0; cursor: pointer;
      }
      .nav-toggle span { width: 24px; height: 1.5px; background: var(--fg); transition: 0.3s; }
      .nav-drawer { display: none; flex-direction: column; gap: 0.4rem; padding: 0 1.4rem 1.2rem; }
      .nav-drawer.open { display: flex; }
      .nav-drawer a { text-decoration: none; padding: 0.7rem 0; border-bottom: 1px solid var(--border); letter-spacing: 0.1em; text-transform: uppercase; font-size: 0.85rem; }
      .nav-drawer .btn { margin-top: 0.6rem; border-bottom: none; }

      @media (min-width: 880px) {
        .nav-links { display: flex; }
        .nav .btn-sm { display: inline-flex; }
        .nav-toggle { display: none; }
      }

      /* HERO */
      .hero { position: relative; min-height: 92vh; display: flex; flex-direction: column; justify-content: flex-end; overflow: hidden; }
      .hero-img {
        position: absolute; inset: 0;
        background-image: url(https://picsum.photos/seed/marisol-tower-night/1600/1100);
        background-size: cover; background-position: center;
        filter: brightness(0.55) saturate(0.85) contrast(1.05);
        transform: scale(1.05); animation: heroZoom 18s ease-out forwards;
      }
      @keyframes heroZoom { to { transform: scale(1.16); } }
      .hero-scrim {
        position: absolute; inset: 0;
        background:
          linear-gradient(180deg, rgba(22,24,28,0.4) 0%, rgba(22,24,28,0.1) 35%, rgba(22,24,28,0.95) 100%),
          linear-gradient(105deg, rgba(126,139,148,0.18), rgba(194,163,107,0.12));
        mix-blend-mode: normal;
      }
      .hero-content { position: relative; max-width: var(--maxw); width: 100%; margin: 0 auto; padding: 0 1.4rem 2rem; }
      .hero h1 { font-size: clamp(2.8rem, 9vw, 6rem); letter-spacing: 0.01em; margin-bottom: 1rem; }
      .hero-tag { font-size: clamp(1rem, 2.5vw, 1.25rem); max-width: 32ch; color: var(--fg); opacity: 0.88; }

      /* BOOKING BAR */
      .bookbar {
        position: relative; z-index: 2;
        max-width: var(--maxw); margin: 0 auto -2.5rem; width: calc(100% - 2.8rem);
        background: rgba(35, 38, 44, 0.92); backdrop-filter: blur(10px);
        border: 1px solid var(--border); border-radius: 4px;
        padding: 1.1rem; display: grid; gap: 0.8rem;
        grid-template-columns: 1fr; box-shadow: 0 24px 60px rgba(0,0,0,0.5);
      }
      .field { display: flex; flex-direction: column; gap: 0.3rem; }
      .field label { font-size: 0.68rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); }
      .field input, .field select {
        background: var(--bg); border: 1px solid var(--border); color: var(--fg);
        font-family: var(--font-body); padding: 0.65rem 0.7rem; border-radius: 2px;
        min-height: 44px; font-size: 0.9rem; color-scheme: dark;
      }
      .field input:focus, .field select:focus { border-color: var(--primary); outline: none; }
      .bookbar .btn { align-self: end; min-height: 48px; }
      @media (min-width: 760px) {
        .bookbar { grid-template-columns: 1fr 1fr 1fr auto; align-items: end; }
      }

      /* SECTION SHELL */
      section { padding: 5rem 1.4rem; }
      .section-head { max-width: var(--maxw); margin: 0 auto 3rem; }
      .section-head h2 { max-width: 18ch; }

      /* STORY */
      .story {
        max-width: var(--maxw); margin: 0 auto; display: grid; gap: 2.5rem;
        align-items: center; padding-top: 7rem;
      }
      .story h2 { margin-bottom: 1.5rem; }
      .story-text p { max-width: 46ch; color: var(--fg); opacity: 0.85; }
      .story-sign { font-family: var(--font-display); font-style: italic; color: var(--primary); opacity: 1; }
      .story-img {
        min-height: 420px; border: 1px solid var(--border); border-radius: 4px;
        background-image: linear-gradient(160deg, rgba(194,163,107,0.12), rgba(22,24,28,0.5)), url(https://picsum.photos/seed/marisol-story/800/1000);
        background-size: cover; background-position: center; filter: contrast(1.05) brightness(0.85);
      }
      @media (min-width: 880px) { .story { grid-template-columns: 1.05fr 0.95fr; } }

      /* ROOMS */
      .room-grid { max-width: var(--maxw); margin: 0 auto; display: grid; gap: 1.8rem; grid-template-columns: 1fr; }
      .room {
        background: var(--muted); border: 1px solid var(--border); border-radius: 4px;
        overflow: hidden; display: flex; flex-direction: column;
        transition: transform 0.35s, border-color 0.35s;
      }
      .room:hover { transform: translateY(-6px); border-color: var(--primary); }
      .room-img {
        height: 240px; background-size: cover; background-position: center;
        filter: brightness(0.8) contrast(1.05); transition: filter 0.4s, transform 0.6s;
      }
      .room:hover .room-img { filter: brightness(1) contrast(1.05); transform: scale(1.04); }
      .room-body { padding: 1.6rem; display: flex; flex-direction: column; flex: 1; }
      .room-body p { color: var(--fg); opacity: 0.82; font-size: 0.95rem; }
      .room-feats { list-style: none; margin: 0 0 1.4rem; padding: 0; display: flex; flex-wrap: wrap; gap: 0.4rem; }
      .room-feats li {
        font-size: 0.68rem; letter-spacing: 0.08em; text-transform: uppercase;
        border: 1px solid var(--border); color: var(--accent); padding: 0.3rem 0.6rem; border-radius: 999px;
      }
      .room-foot { margin-top: auto; display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
      .rate { font-family: var(--font-display); font-size: 1.7rem; color: var(--fg); }
      .rate small { font-family: var(--font-body); font-size: 0.66rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); }
      @media (min-width: 720px) { .room-grid { grid-template-columns: repeat(3, 1fr); } }

      /* AMENITIES */
      .amen { background: var(--muted); }
      .amen-grid { max-width: var(--maxw); margin: 0 auto; display: grid; gap: 1.2rem; grid-template-columns: repeat(2, 1fr); }
      .amen-card { padding: 2rem 1.4rem; border: 1px solid var(--border); border-radius: 4px; text-align: center; background: var(--bg); transition: border-color 0.3s, transform 0.3s; }
      .amen-card:hover { border-color: var(--primary); transform: translateY(-4px); }
      .amen-icon { width: 34px; height: 34px; color: var(--primary); margin-bottom: 0.8rem; }
      .amen-card h3 { font-size: 1.25rem; margin-bottom: 0.3rem; }
      .amen-card p { font-size: 0.78rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent); margin: 0; }
      @media (min-width: 760px) { .amen-grid { grid-template-columns: repeat(4, 1fr); } }

      /* DINING */
      .dining { max-width: var(--maxw); margin: 0 auto; display: grid; gap: 2.5rem; align-items: center; }
      .dining-img {
        min-height: 440px; border-radius: 4px; border: 1px solid var(--border);
        background-image: linear-gradient(200deg, rgba(126,139,148,0.16), rgba(22,24,28,0.55)), url(https://picsum.photos/seed/marisol-dining/900/1000);
        background-size: cover; background-position: center; filter: brightness(0.82) contrast(1.08);
      }
      .dining-text p { color: var(--fg); opacity: 0.85; max-width: 44ch; }
      .menu { list-style: none; padding: 0; margin: 1.8rem 0 1rem; }
      .menu li { display: flex; align-items: baseline; gap: 0.6rem; padding: 0.6rem 0; border-bottom: 1px solid var(--border); }
      .menu li span:first-child { font-size: 0.98rem; }
      .menu .dot { flex: 1; border-bottom: 1px dotted var(--border); transform: translateY(-4px); }
      .menu strong { font-family: var(--font-display); font-size: 1.2rem; color: var(--primary); font-weight: 500; }
      .hours-note { font-size: 0.78rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent); }
      @media (min-width: 880px) { .dining { grid-template-columns: 0.9fr 1.1fr; } }

      /* GALLERY */
      .masonry { max-width: var(--maxw); margin: 0 auto; columns: 2; column-gap: 1rem; }
      .tile { margin: 0 0 1rem; break-inside: avoid; overflow: hidden; border-radius: 4px; border: 1px solid var(--border); }
      .tile img {
        width: 100%; height: auto; filter: grayscale(0.4) brightness(0.82) contrast(1.05);
        transition: filter 0.5s, transform 0.6s;
      }
      .tile:hover img { filter: grayscale(0) brightness(1) contrast(1.05); transform: scale(1.05); }
      @media (min-width: 760px) { .masonry { columns: 3; } }

      /* OFFERS */
      .offers { background: var(--muted); }
      .brg { color: var(--accent); font-size: 0.9rem; letter-spacing: 0.04em; }
      .offer-grid { max-width: var(--maxw); margin: 0 auto; display: grid; gap: 1.4rem; grid-template-columns: 1fr; }
      .offer {
        position: relative; background: var(--bg); border: 1px solid var(--border);
        border-radius: 4px; padding: 2rem 1.6rem; display: flex; flex-direction: column; gap: 0.5rem;
        transition: transform 0.3s, border-color 0.3s;
      }
      .offer:hover { transform: translateY(-5px); border-color: var(--primary); }
      .offer-feat { border-color: var(--primary); }
      .offer p { color: var(--fg); opacity: 0.8; font-size: 0.92rem; margin: 0; }
      .offer .rate { margin: 0.4rem 0 1rem; }
      .offer .btn { margin-top: auto; }
      .badge {
        position: absolute; top: -0.7rem; left: 1.6rem;
        background: var(--primary); color: var(--primary-fg);
        font-size: 0.6rem; letter-spacing: 0.18em; text-transform: uppercase;
        padding: 0.35rem 0.7rem; border-radius: 999px; font-weight: 500;
      }
      @media (min-width: 760px) { .offer-grid { grid-template-columns: repeat(3, 1fr); } }

      /* PROOF */
      .proof { text-align: center; }
      .awards {
        max-width: var(--maxw); margin: 0 auto 3.5rem; display: flex; flex-wrap: wrap;
        justify-content: center; gap: 1rem 2.2rem; padding-bottom: 2.5rem; border-bottom: 1px solid var(--border);
      }
      .award {
        font-family: var(--font-display); font-style: italic; font-size: 1.05rem;
        color: var(--accent); letter-spacing: 0.02em;
      }
      .slider { max-width: 720px; margin: 0 auto; position: relative; min-height: 200px; }
      .slide {
        margin: 0; opacity: 0; visibility: hidden; position: absolute; inset: 0;
        transition: opacity 0.6s; display: flex; flex-direction: column; align-items: center; gap: 1rem;
      }
      .slide.active { opacity: 1; visibility: visible; position: relative; }
      .stars { color: var(--primary); letter-spacing: 0.2em; }
      .slide p { font-family: var(--font-display); font-size: clamp(1.3rem, 3vw, 1.9rem); font-style: italic; line-height: 1.4; max-width: 28ch; }
      .slide cite { font-style: normal; font-size: 0.78rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--accent); }
      .dots { display: flex; gap: 0.6rem; justify-content: center; margin-top: 2rem; }
      .dot-btn { width: 44px; height: 44px; padding: 0; background: none; border: 0; cursor: pointer; position: relative; }
      .dot-btn::after { content: ""; position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%); width: 9px; height: 9px; border-radius: 50%; border: 1px solid var(--accent); transition: 0.3s; }
      .dot-btn.active::after { background: var(--primary); border-color: var(--primary); }

      /* CONTACT */
      .contact { max-width: var(--maxw); margin: 0 auto; display: grid; gap: 2.5rem; align-items: stretch; }
      .contact-text address { font-style: normal; font-size: 1.05rem; margin: 0 0 1.5rem; line-height: 1.8; }
      .hours { display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem 1.5rem; margin: 0 0 2rem; max-width: 360px; }
      .hours div { display: flex; flex-direction: column; gap: 0.1rem; border-top: 1px solid var(--border); padding-top: 0.6rem; }
      .hours dt { font-size: 0.66rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--accent); margin: 0; }
      .hours dd { margin: 0; font-size: 0.95rem; }
      .contact-cta { display: flex; flex-wrap: wrap; gap: 0.8rem; }
      .map {
        position: relative; min-height: 320px; border-radius: 4px; border: 1px solid var(--border);
        text-decoration: none; overflow: hidden; display: flex; align-items: center; justify-content: center;
        background-image: linear-gradient(135deg, rgba(126,139,148,0.22), rgba(22,24,28,0.7)), url(https://picsum.photos/seed/marisol-map/900/700?grayscale);
        background-size: cover; background-position: center; transition: filter 0.3s;
      }
      .map:hover { filter: brightness(1.15); }
      .map-pin { width: 18px; height: 18px; border-radius: 50% 50% 50% 0; background: var(--primary); transform: rotate(-45deg); box-shadow: 0 0 0 6px rgba(194,163,107,0.25); }
      .map-label {
        position: absolute; bottom: 1.2rem; font-size: 0.72rem; letter-spacing: 0.18em;
        text-transform: uppercase; color: var(--fg); background: rgba(22,24,28,0.8);
        padding: 0.5rem 1rem; border-radius: 999px; border: 1px solid var(--border);
      }
      @media (min-width: 880px) { .contact { grid-template-columns: 1fr 1fr; } }

      /* FOOTER */
      .foot { border-top: 1px solid var(--border); background: var(--muted); padding: 3rem 1.4rem; }
      .foot-inner { max-width: var(--maxw); margin: 0 auto; display: flex; flex-wrap: wrap; gap: 1rem 2rem; align-items: center; justify-content: space-between; }
      .foot .brand-name { font-size: 1.5rem; }
      .foot p { margin: 0.3rem 0 0; color: var(--accent); font-size: 0.85rem; }
      .foot-nap, .foot-copy { font-size: 0.8rem; }

      /* REVEAL */
      .reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.8s ease, transform 0.8s ease; }
      .reveal.in { opacity: 1; transform: none; }
    </style>
  </body>
</html>
